{% comment %}
  Kwispelbox — Breadcrumbs
  Herbruikbaar: rendert visuele breadcrumb + BreadcrumbList JSON-LD.
  Detecteert paginatype zelf. Niet tonen op de homepage.
  Gebruik: {% render 'breadcrumbs' %}
{% endcomment %}

{%- unless template.name == 'index' or template.name == 'cart' or template.name == '404' -%}

  <nav class="kw-crumbs full-width" aria-label="Kruimelpad">
    <ol class="kw-crumbs__list" role="list">

      {%- comment -%} Altijd: Home (huis-icoon) {%- endcomment -%}
      <li class="kw-crumbs__item">
        <a href="{{ routes.root_url }}" class="kw-crumbs__link kw-crumbs__home" aria-label="Home">
          {{- 'icon-home.svg' | inline_asset_content -}}
        </a>
        <span class="kw-crumbs__sep" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </li>

      {%- case template.name -%}

        {%- when 'collection' -%}
          <li class="kw-crumbs__item">
            <span class="kw-crumbs__current" aria-current="page">{{ collection.title }}</span>
          </li>

        {%- when 'product' -%}
          {%- if collection -%}
            <li class="kw-crumbs__item">
              <a href="{{ collection.url }}" class="kw-crumbs__link">{{ collection.title }}</a>
              <span class="kw-crumbs__sep" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </li>
          {%- endif -%}
          <li class="kw-crumbs__item">
            <span class="kw-crumbs__current" aria-current="page">{{ product.title }}</span>
          </li>

        {%- when 'page' -%}
          <li class="kw-crumbs__item">
            <span class="kw-crumbs__current" aria-current="page">{{ page.title }}</span>
          </li>

        {%- when 'search' -%}
          <li class="kw-crumbs__item">
            <span class="kw-crumbs__current" aria-current="page">Zoekresultaten</span>
          </li>

        {%- when 'blog' -%}
          <li class="kw-crumbs__item">
            <span class="kw-crumbs__current" aria-current="page">{{ blog.title }}</span>
          </li>

        {%- when 'article' -%}
          <li class="kw-crumbs__item">
            <a href="{{ blog.url }}" class="kw-crumbs__link">{{ blog.title }}</a>
            <span class="kw-crumbs__sep" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </li>
          <li class="kw-crumbs__item">
            <span class="kw-crumbs__current" aria-current="page">{{ article.title }}</span>
          </li>

        {%- when 'list-collections' -%}
          <li class="kw-crumbs__item">
            <span class="kw-crumbs__current" aria-current="page">Collecties</span>
          </li>

        {%- else -%}
          {%- if page_title != blank -%}
            <li class="kw-crumbs__item">
              <span class="kw-crumbs__current" aria-current="page">{{ page_title }}</span>
            </li>
          {%- endif -%}

      {%- endcase -%}

    </ol>
  </nav>

  {%- comment -%} ── JSON-LD BreadcrumbList ─────────────────────── {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | append: routes.root_url | json }} }
      {%- case template.name -%}
        {%- when 'collection' -%}
          ,{ "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ collection.url | prepend: shop.url | json }} }
        {%- when 'product' -%}
          {%- if collection -%}
            ,{ "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ collection.url | prepend: shop.url | json }} }
            ,{ "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ product.url | prepend: shop.url | json }} }
          {%- else -%}
            ,{ "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": {{ product.url | prepend: shop.url | json }} }
          {%- endif -%}
        {%- when 'page' -%}
          ,{ "@type": "ListItem", "position": 2, "name": {{ page.title | json }}, "item": {{ page.url | prepend: shop.url | json }} }
        {%- when 'article' -%}
          ,{ "@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ blog.url | prepend: shop.url | json }} }
          ,{ "@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ article.url | prepend: shop.url | json }} }
      {%- endcase -%}
    ]
  }
  </script>

  {%- comment -%} CSS {%- endcomment -%}
  <style>
    .kw-crumbs{max-width:1280px;margin:0 auto;padding:0 20px}
    .kw-crumbs__list{list-style:none;margin:16px 0 0;padding:14px 18px;display:flex;flex-wrap:wrap;align-items:center;gap:2px;font-family:'Karla',sans-serif;font-size:.9rem;background:#fff;border-radius:18px;box-shadow:0 4px 18px rgba(96,58,21,.08)}
    .kw-crumbs__item{display:inline-flex;align-items:center;gap:2px;min-width:0}
    .kw-crumbs__link{display:inline-flex;align-items:center;color:#66AA44;font-weight:700;text-decoration:none;padding:4px 6px;border-radius:8px;transition:color 140ms,background 140ms;white-space:nowrap}
    .kw-crumbs__link:hover{color:#4d8833;background:#e8f5e2}
    .kw-crumbs__home{padding:4px}
    .kw-crumbs__home svg{width:20px;height:20px}
    .kw-crumbs__sep{display:inline-flex;color:#DAC9A1;margin:0 2px}
    .kw-crumbs__sep svg{width:14px;height:14px;stroke-width:2}
    .kw-crumbs__current{color:#66AA44;font-weight:700;padding:4px 6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:55vw}
    @media(min-width:768px){
      .kw-crumbs{padding:0 60px}
      .kw-crumbs__list{margin-top:20px;padding:16px 24px;font-size:.95rem}
      .kw-crumbs__current{max-width:none}
    }
  </style>

{%- endunless -%}
