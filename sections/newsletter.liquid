{%- assign form_posted = false -%}
{%- form 'customer', id: 'KwClubCheck' -%}
  {%- assign form_posted = form.posted_successfully? -%}
{%- endform -%}

<section class="kclub">

  <!-- ═══ TOP: copy links + foto rechts ══════════════════ -->
  <div class="kclub__top">

    <!-- Links ──────────────────────────────────────────── -->
    <div class="kclub__copy">

      <!-- Eyebrow -->
      {%- if section.settings.eyebrow != blank -%}
        <p class="kclub__eyebrow">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      <!-- Titel -->
      <h2 class="kclub__title">
        <span class="kclub__title-plain">{{ section.settings.title_line1 }}</span><br>
        <span class="kclub__title-accent">{{ section.settings.title_line2 }}</span>
        <span class="kclub__title-paw" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
      </h2>

      <!-- Intro -->
      {%- if section.settings.intro != blank -%}
        <p class="kclub__intro">{{ section.settings.intro }}</p>
      {%- endif -%}

      <!-- Perks 2×2 grid -->
      {%- assign perk_blocks = section.blocks | where: 'type', 'perk' -%}
      {%- if perk_blocks.size > 0 -%}
        <div class="kclub__perks">
          {%- for block in perk_blocks -%}
            <div class="kclub__perk" {{ block.shopify_attributes }}>
              <span class="kclub__perk-icon kclub__perk-icon--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <div>
                <strong>{{ block.settings.title }}</strong>
                <p>{{ block.settings.description }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <!-- Email formulier -->
      {%- if form_posted -%}
        <div class="kclub__success" role="alert">
          <span style="color:#66AA44;display:flex;flex-shrink:0">{{- 'icon-check-circle.svg' | inline_asset_content -}}</span>
          <div>
            <strong>{{ section.settings.success_title }}</strong>
            <p>{{ section.settings.success_text }}</p>
          </div>
        </div>
      {%- else -%}
        {%- form 'customer', id: 'KwClubForm' -%}
          <input type="hidden" name="contact[tags]" value="newsletter,kwispelclub">
          <div class="kclub__form">
            <div class="kclub__input-wrap">
              <span class="kclub__input-icon" aria-hidden="true">{{- 'icon-mail.svg' | inline_asset_content -}}</span>
              <label for="KwClubEmail" class="kclub__sr-only">E-mailadres</label>
              <input
                type="email" id="KwClubEmail" name="contact[email]"
                class="kclub__input"
                placeholder="{{ section.settings.input_placeholder }}"
                required autocomplete="email"
              >
            </div>
            <button type="submit" class="kclub__btn">
              {{ section.settings.btn_label }}
              <span aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
            </button>
          </div>
          <p class="kclub__privacy">
            {{- 'icon-lock.svg' | inline_asset_content -}}
            {{ section.settings.privacy_text }}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" style="color:#e75480;flex-shrink:0"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </p>
        {%- endform -%}
      {%- endif -%}

    </div>

    <!-- Rechts: foto + speech bubble + decoratie ───────── -->
    <div class="kclub__img-col">

      <!-- Decoratieve roze streepjes linksboven (buiten foto) -->
      <div class="kclub__img-deco" aria-hidden="true">
        <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="20" y1="2" x2="20" y2="14" stroke="#e75480" stroke-width="3" stroke-linecap="round"/>
          <line x1="28" y1="6" x2="22" y2="16" stroke="#e75480" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="12" y1="6" x2="18" y2="16" stroke="#e75480" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </div>

      <!-- Decoratieve roze lijntjes rechts van foto -->
      <div class="kclub__img-lines" aria-hidden="true">
        <svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="25" y1="5" x2="25" y2="20" stroke="#e75480" stroke-width="3" stroke-linecap="round"/>
          <line x1="35" y1="10" x2="27" y2="22" stroke="#e75480" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="15" y1="10" x2="23" y2="22" stroke="#e75480" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="40" y1="20" x2="30" y2="26" stroke="#FFB8CD" stroke-width="2" stroke-linecap="round"/>
          <line x1="10" y1="20" x2="20" y2="26" stroke="#FFB8CD" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>

      <!-- Grote foto -->
      <div class="kclub__img-wrap">
        {%- if section.settings.hero_image != blank -%}
          <img
            src="{{ section.settings.hero_image | image_url: width: 900 }}"
            srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w,
                    {{ section.settings.hero_image | image_url: width: 900 }} 900w"
            sizes="(max-width: 899px) 100vw, 45vw"
            alt="{{ section.settings.hero_image.alt | default: 'Kwispelclub' | escape }}"
            width="900" loading="lazy" class="kclub__img"
          >
        {%- else -%}
          <div class="kclub__img-ph">
            {{- 'icon-paw.svg' | inline_asset_content -}}
            <span>Voeg foto toe</span>
          </div>
        {%- endif -%}

        <!-- Speech bubble rechtsboven op foto -->
        {%- if section.settings.speech_bubble != blank -%}
          <div class="kclub__bubble" aria-hidden="true">
            <span>{{ section.settings.speech_bubble }}</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none" style="color:#e75480;flex-shrink:0"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>

  <!-- ═══ BOTTOM: community links + trust rechts ═════════ -->
  <div class="kclub__bottom">

    <!-- Links: community ───────────────────────────────── -->
    <div class="kclub__community">

      <div class="kclub__community-head">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" style="color:#e75480;flex-shrink:0"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        <div>
          <strong>{{ section.settings.community_title }}</strong>
          <p>{{ section.settings.community_sub }}</p>
        </div>
      </div>

      {%- if section.settings.instagram_handle != blank -%}
        <a href="https://instagram.com/{{ section.settings.instagram_handle | remove: '@' }}"
           class="kclub__insta" rel="noopener" target="_blank">
          {{- 'icon-instagram.svg' | inline_asset_content -}}
          {{ section.settings.instagram_handle }}
        </a>
      {%- endif -%}

      <!-- Polaroid foto's -->
      {%- assign photo_blocks = section.blocks | where: 'type', 'community_photo' -%}
      {%- if photo_blocks.size > 0 -%}
        <div class="kclub__polaroids">
          {%- for block in photo_blocks -%}
            <div class="kclub__polaroid kclub__polaroid--{{ forloop.index }}" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 200 }}"
                     alt="" width="200" height="200" loading="lazy"
                     class="kclub__polaroid-img">
              {%- else -%}
                <div class="kclub__polaroid-ph">{{- 'icon-camera.svg' | inline_asset_content -}}</div>
              {%- endif -%}
            </div>
          {%- endfor -%}
          <!-- Hartje badge op laatste polaroid -->
          <div class="kclub__polaroid-heart-badge" aria-hidden="true">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="36" height="36" rx="9" fill="#e75480"/>
              <path d="M18 28 C18 28 9 20 9 13.5 C9 10.5 11.2 8 14 8 C16 8 17.5 9 18 10.5 C18.5 9 20 8 22 8 C24.8 8 27 10.5 27 13.5 C27 20 18 28 18 28Z" fill="white"/>
            </svg>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.hashtag != blank -%}
        <p class="kclub__hashtag">
          {{ section.settings.hashtag }}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" style="color:#e75480"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        </p>
      {%- endif -%}

    </div>

    <!-- Rechts: trust 2×2 ──────────────────────────────── -->
    <div class="kclub__trust-col">

      <p class="kclub__trust-title">
        <span style="display:flex;align-items:center;color:#F7A048">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
        {{ section.settings.trust_title }}
      </p>

      {%- assign trust_blocks = section.blocks | where: 'type', 'trust' -%}
      <div class="kclub__trust-grid">
        {%- for block in trust_blocks -%}
          <div class="kclub__trust-item" {{ block.shopify_attributes }}>
            <span class="kclub__trust-icon kclub__trust-icon--{{ block.settings.color }}" aria-hidden="true">
              {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
            </span>
            <div>
              <strong>{{ block.settings.title }}</strong>
              {%- if block.settings.subtitle != blank -%}
                <span>{{ block.settings.subtitle }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>

  <!-- ═══ FOOTER BALK ════════════════════════════════════ -->
  <div class="kclub__footer">
    <span class="kclub__footer-paw" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
    <span class="kclub__footer-brand">{{ shop.name }}</span>
    <span class="kclub__footer-paw" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" style="color:#FFB8CD"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
  </div>

</section>

{% stylesheet %}
.kclub { background: #F8EFDD; overflow: hidden; }
.kclub__sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0 }

/* ══ TOP ══════════════════════════════════════════════ */
.kclub__top {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  padding: 60px 20px 48px;
  max-width: 1280px; margin: 0 auto;
}
@media(min-width: 900px) {
  .kclub__top {
    grid-template-columns: 52% 44%;
    gap: 40px;
    padding: 72px 60px 56px;
    align-items: stretch;
  }
}

/* ── Copy links ──────────────────────────────────────── */
.kclub__copy { display: flex; flex-direction: column; gap: 20px; }

.kclub__eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: 'Karla', sans-serif;
  font-size: .75rem; font-weight: 800;
  letter-spacing: .1em; text-transform: uppercase;
  color: #e75480;
}
.kclub__eyebrow svg { flex-shrink: 0; }

.kclub__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(2.2rem, 5vw, 3.4rem);
  line-height: 1.05; margin: 0;
}
.kclub__title-plain { color: #3d2209; }
.kclub__title-accent { color: #e75480; }
.kclub__title-paw {
  display: inline-flex; align-items: center;
  vertical-align: middle; margin-left: 6px;
}
.kclub__title-paw svg { width: 32px; height: 32px; color: #F7A048; }

.kclub__intro {
  font-family: 'Karla', sans-serif;
  font-size: .95rem; color: #A88259; line-height: 1.75; max-width: 44ch;
}

/* Perks 2×2 */
.kclub__perks {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}
@media(max-width: 600px) {
  .kclub__perks { grid-template-columns: repeat(2, 1fr); }
}
.kclub__perk {
  display: flex; flex-direction: column;
  align-items: center; text-align: center;
  gap: 8px;
  background: rgba(255,255,255,.7);
  border: 1.5px solid #EDE2C9;
  border-radius: 16px; padding: 14px 10px;
}
.kclub__perk-icon {
  width: 44px; height: 44px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.kclub__perk-icon svg { width: 20px; height: 20px; }
.kclub__perk-icon--green  { background: #e8f5e2; color: #66AA44; }
.kclub__perk-icon--pink   { background: #fff0f5; color: #e75480; }
.kclub__perk-icon--orange { background: #fff0e4; color: #F7A048; }
.kclub__perk-icon--yellow { background: #fffae0; color: #c49000; }
.kclub__perk strong {
  display: block; font-family: 'Lilita One', cursive;
  font-size: .85rem; color: #3d2209; line-height: 1.2;
}
.kclub__perk p {
  font-family: 'Karla', sans-serif;
  font-size: .7rem; color: #A88259; line-height: 1.45; margin: 0;
}

/* Formulier */
.kclub__form {
  display: flex; gap: 0;
  background: #fff;
  border: 2px solid #DAC9A1;
  border-radius: 999px;
  overflow: hidden; height: 54px;
  transition: border-color 200ms, box-shadow 200ms;
}
.kclub__form:focus-within {
  border-color: #66AA44;
  box-shadow: 0 0 0 4px rgba(102,170,68,.12);
}
.kclub__input-wrap {
  display: flex; align-items: center; gap: 10px;
  flex: 1; padding: 0 16px; min-width: 0;
}
.kclub__input-icon { display: flex; color: #A88259; flex-shrink: 0; }
.kclub__input-icon svg { width: 16px; height: 16px; }
.kclub__input {
  flex: 1; border: none; outline: none; background: transparent;
  font-family: 'Karla', sans-serif; font-size: .9rem; color: #3d2209; min-width: 0;
}
.kclub__input::placeholder { color: #A88259; }
.kclub__btn {
  height: 100%; padding: 0 22px;
  background: #66AA44; color: #fff;
  font-family: 'Lilita One', cursive; font-size: .92rem;
  border: none; border-radius: 0 999px 999px 0; cursor: pointer;
  display: flex; align-items: center; gap: 7px; white-space: nowrap; flex-shrink: 0;
  transition: background 160ms;
}
.kclub__btn:hover { background: #4d8833; }
.kclub__btn svg { width: 16px; height: 16px; }

.kclub__privacy {
  display: flex; align-items: center; gap: 6px;
  font-family: 'Karla', sans-serif; font-size: .75rem; color: #A88259;
}
.kclub__privacy svg { width: 12px; height: 12px; color: #A88259; flex-shrink: 0; }

.kclub__success {
  display: flex; align-items: flex-start; gap: 12px;
  background: #e8f5e2; border: 1.5px solid #66AA44;
  border-radius: 16px; padding: 16px 18px;
}
.kclub__success svg { width: 22px; height: 22px; flex-shrink: 0; }
.kclub__success strong { display: block; font-family: 'Lilita One', cursive; color: #2d7a1a; margin-bottom: 3px; }
.kclub__success p { font-family: 'Karla', sans-serif; font-size: .82rem; color: #2d7a1a; margin: 0; }

/* ── Foto rechts ─────────────────────────────────────── */
.kclub__img-col {
  position: relative;
  display: flex;
  flex-direction: column;
}
@media(min-width: 900px) {
  .kclub__img-col { min-height: 520px; }
}

.kclub__img-deco {
  position: absolute;
  top: -16px; left: -8px;
  width: 40px; height: 40px;
  z-index: 2; pointer-events: none;
}
.kclub__img-lines {
  position: absolute;
  top: 8px; right: -24px;
  width: 50px; height: 50px;
  z-index: 2; pointer-events: none;
}
@media(max-width: 899px) { .kclub__img-lines { display: none; } }

.kclub__img-wrap {
  position: relative;
  border-radius: 48% 24px 24px 0% / 40% 24px 24px 0%;
  overflow: hidden;
  box-shadow: 0 16px 56px rgba(96,58,21,.16);
  height: 100%;
}
@media(max-width: 899px) {
  .kclub__img-wrap { border-radius: 24px; }
}
.kclub__img {
  width: 100%; height: 100%; min-height: 400px;
  display: block; object-fit: cover;
  object-position: center top;
}
.kclub__img-ph {
  width: 100%; aspect-ratio: 4/3;
  background: #EDE2C9; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 10px; color: #A88259;
}

/* Speech bubble */
.kclub__bubble {
  position: absolute;
  top: 24px; right: 16px;
  background: #fff;
  border-radius: 999px 999px 999px 16px;
  padding: 16px 18px;
  box-shadow: 0 6px 28px rgba(96,58,21,.2);
  border: 2px solid #EDE2C9;
  display: flex; flex-direction: column;
  align-items: center; gap: 6px;
  width: 118px; text-align: center; z-index: 4;
  /* Lichte roze achtergrond tint */
  background: linear-gradient(145deg, #fff 60%, #fff5f8 100%);
}
/* Staartje pijl linksonder */
.kclub__bubble::after {
  content: '';
  position: absolute;
  bottom: 8px; left: -12px;
  width: 0; height: 0;
  border-top: 8px solid transparent;
  border-bottom: 8px solid transparent;
  border-right: 12px solid #fff;
  filter: drop-shadow(-2px 0 2px rgba(96,58,21,.06));
}
.kclub__bubble span {
  font-family: 'Lilita One', cursive;
  font-size: .85rem; color: #3d2209; line-height: 1.3;
}
.kclub__bubble svg { width: 16px; height: 16px; }

/* ══ BOTTOM ══════════════════════════════════════════ */
.kclub__bottom {
  display: grid;
  grid-template-columns: 1fr;
  border-top: 1.5px solid #EDE2C9;
  background: rgba(255,255,255,.5);
}
@media(min-width: 768px) {
  .kclub__bottom { grid-template-columns: 1fr 1fr; }
}

/* Community links */
.kclub__community {
  padding: 32px 20px;
  display: flex; flex-direction: column; gap: 14px;
  border-right: 1.5px solid #EDE2C9;
  background: rgba(255,240,245,.4);
}
@media(min-width: 1200px) { .kclub__community { padding: 32px 60px 32px 60px; } }
@media(max-width: 767px)  { .kclub__community { border-right: none; border-bottom: 1.5px solid #EDE2C9; } }

.kclub__community-head {
  display: flex; align-items: flex-start; gap: 10px;
}
.kclub__community-head > svg { margin-top: 3px; }
.kclub__community-head strong {
  display: block; font-family: 'Lilita One', cursive;
  font-size: 1.05rem; color: #3d2209; margin-bottom: 3px;
}
.kclub__community-head p {
  font-family: 'Karla', sans-serif; font-size: .82rem; color: #A88259; margin: 0;
}

.kclub__insta {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: 'Karla', sans-serif; font-size: .82rem; font-weight: 700;
  color: #3d2209; background: #EDE2C9; border-radius: 999px;
  padding: 7px 14px; text-decoration: none; border: 1.5px solid #DAC9A1;
  align-self: flex-start; transition: background 160ms;
}
.kclub__insta:hover { background: #DAC9A1; }
.kclub__insta svg { width: 15px; height: 15px; color: #A88259; }

/* Polaroids */
.kclub__polaroids {
  display: flex; align-items: flex-end; gap: 6px;
  position: relative;
}
.kclub__polaroid {
  background: #fff; padding: 5px 5px 18px;
  border-radius: 4px;
  box-shadow: 0 3px 12px rgba(96,58,21,.12);
  flex: 1; max-width: 90px;
  transition: transform 200ms cubic-bezier(.34,1.56,.64,1);
}
.kclub__polaroid:hover { transform: scale(1.06) rotate(0deg) !important; }
.kclub__polaroid--1 { transform: rotate(-3deg); }
.kclub__polaroid--2 { transform: rotate(1.5deg); }
.kclub__polaroid--3 { transform: rotate(-1deg); }
.kclub__polaroid--4 { transform: rotate(2.5deg); }
.kclub__polaroid-img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 2px; display: block; }
.kclub__polaroid-ph {
  width: 100%; aspect-ratio: 1; background: #EDE2C9;
  display: flex; align-items: center; justify-content: center; color: #DAC9A1;
  border-radius: 2px;
}
.kclub__polaroid-ph svg { width: 20px; height: 20px; }

/* Zweefhart boven laatste polaroid */
.kclub__polaroid-heart-badge {
  position: absolute;
  top: -10px; right: -10px;
  width: 36px; height: 36px;
  z-index: 5;
  filter: drop-shadow(0 3px 8px rgba(231,84,128,.35));
  animation: kclub-pop 2s ease-in-out infinite;
}
.kclub__polaroid-heart-badge svg { width: 100%; height: 100%; }
@keyframes kclub-pop {
  0%, 100% { transform: scale(1) rotate(-5deg); }
  50%       { transform: scale(1.1) rotate(5deg); }
}
@media(prefers-reduced-motion: reduce) { .kclub__polaroid-heart-badge { animation: none; } }

.kclub__hashtag {
  display: flex; align-items: center; gap: 6px;
  font-family: 'Karla', sans-serif; font-size: .82rem; font-weight: 700; color: #A88259;
}

/* Trust rechts */
.kclub__trust-col {
  padding: 32px 20px;
  display: flex; flex-direction: column; gap: 16px;
}
@media(min-width: 1200px) { .kclub__trust-col { padding: 32px 60px; } }

.kclub__trust-title {
  display: flex; align-items: center; gap: 8px;
  font-family: 'Karla', sans-serif; font-size: .88rem; font-weight: 800;
  color: #e75480; line-height: 1.4;
}
.kclub__trust-title svg { width: 16px; height: 16px; flex-shrink: 0; }

.kclub__trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}
@media(max-width: 600px) {
  .kclub__trust-grid { grid-template-columns: repeat(2, 1fr); }
}
.kclub__trust-item {
  display: flex; flex-direction: column;
  align-items: flex-start; gap: 8px;
}
.kclub__trust-icon {
  width: 46px; height: 46px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  margin-bottom: 2px;
}
.kclub__trust-icon svg { width: 20px; height: 20px; }
.kclub__trust-icon--green  { background: #e8f5e2; color: #66AA44; }
.kclub__trust-icon--pink   { background: #fff0f5; color: #e75480; }
.kclub__trust-icon--orange { background: #fff0e4; color: #F7A048; }
.kclub__trust-icon--yellow { background: #fffae0; color: #c49000; }
.kclub__trust-item > div { display: flex; flex-direction: column; gap: 2px; }
.kclub__trust-item strong {
  font-family: 'Karla', sans-serif; font-size: .82rem; font-weight: 800; color: #3d2209; line-height: 1.2;
}
.kclub__trust-item span { font-size: .72rem; color: #A88259; line-height: 1.35; }

/* ══ FOOTER BALK ════════════════════════════════════ */
.kclub__footer {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  padding: 18px 20px;
  border-top: 1.5px solid #EDE2C9;
  background: rgba(255,255,255,.4);
}
.kclub__footer-paw svg { width: 16px; height: 16px; color: #A88259; }
.kclub__footer-brand {
  font-family: 'Lilita One', cursive; font-size: .95rem; color: #603A15;
}
{% endstylesheet %}

