      {"type":"trust","settings":{"icon":"truck","color":"orange","title":"Snelle levering",         "subtitle":"Voor 15:00 besteld, morgen in huis."}},
      {"type":"trust","settings":{"icon":"lock","color":"yellow", "title":"Veilig betalen",          "subtitle":"Betaal veilig en vertrouwd."}}
    ]
  }]
}
{% endschema %}
