<div class="trust-bar full-width">
  <div class="trust-bar__inner">
    {%- for block in section.blocks -%}
      {%- if block.type == 'item' -%}
        <div class="trust-bar__item" {{ block.shopify_attributes }}>
          <span class="trust-bar__icon trust-bar__icon--{{ block.settings.color }}" aria-hidden="true">
            {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
          </span>
          <span class="trust-bar__text">
            <strong>{{ block.settings.title }}</strong>
            <span>{{ block.settings.subtitle }}</span>
          </span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.trust-bar {
  background: #fff;
  border-top: 1px solid #EDE2C9;
  border-bottom: 1px solid #EDE2C9;
}
.trust-bar__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
}
@media(min-width: 768px) {
  .trust-bar__inner {
    grid-template-columns: repeat(4, 1fr);
    padding: 0 60px;
  }
}
.trust-bar__item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  border-right: 1px solid #EDE2C9;
  border-bottom: 1px solid #EDE2C9;
}
@media(min-width: 768px) {
  .trust-bar__item { border-bottom: none; }
}
.trust-bar__item:nth-child(2n) { border-right: none; }
@media(min-width: 768px) {
  .trust-bar__item:nth-child(2n) { border-right: 1px solid #EDE2C9; }
  .trust-bar__item:last-child    { border-right: none; }
}
.trust-bar__icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.trust-bar__icon svg { width: 22px; height: 22px; }
.trust-bar__icon--green  { background: #e8f5e2; color: #66AA44; }
.trust-bar__icon--orange { background: #fff0e4; color: #F7A048; }
.trust-bar__icon--pink   { background: #fff0f5; color: #e75480; }
.trust-bar__icon--yellow { background: #fffae0; color: #c49000; }
.trust-bar__text { display: flex; flex-direction: column; gap: 2px; }
.trust-bar__text strong { font-family: 'Karla', sans-serif; font-size: .85rem; font-weight: 800; color: #603A15; line-height: 1.2; }
.trust-bar__text span   { font-size: .75rem; color: #A88259; line-height: 1.3; }
{% endstylesheet %}

{% schema %}
{
  "name": "Vertrouwensbalk",
  "tag": "section",
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icoon", "default": "gift",
          "options": [
            { "value": "gift",    "label": "Cadeau" },
            { "value": "paw",     "label": "Poot" },
            { "value": "heart",   "label": "Hart" },
            { "value": "star",    "label": "Ster" },
            { "value": "truck",   "label": "Vrachtwagen" },
            { "value": "shield",  "label": "Schild" },
            { "value": "refresh", "label": "Retour" }
          ]
        },
        {
          "type": "select", "id": "color", "label": "Kleur", "default": "green",
          "options": [
            { "value": "green",  "label": "Groen" },
            { "value": "orange", "label": "Oranje" },
            { "value": "pink",   "label": "Roze" },
            { "value": "yellow", "label": "Geel" }
          ]
        },
        { "type": "text", "id": "title",    "label": "Titel",    "default": "Duurzaam & bewust" },
        { "type": "text", "id": "subtitle", "label": "Subtitel", "default": "Geselecteerd met zorg" }
      ]
    }
  ],
  "presets": [{
    "name": "Vertrouwensbalk",
    "blocks": [
      { "type": "item", "settings": { "icon": "gift",   "color": "green",  "title": "Duurzaam & bewust",       "subtitle": "Geselecteerd met zorg" }},
      { "type": "item", "settings": { "icon": "paw",    "color": "orange", "title": "Alleen het allerleukste", "subtitle": "Speelplezier gegarandeerd" }},
      { "type": "item", "settings": { "icon": "heart",  "color": "pink",   "title": "Voor elke hond",          "subtitle": "Puppy, volwassen & senior" }},
      { "type": "item", "settings": { "icon": "star",   "color": "yellow", "title": "Elke box uniek",          "subtitle": "Geen twee zijn hetzelfde" }}
    ]
  }]
}
{% endschema %}
