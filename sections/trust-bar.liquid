  "name": "Vertrouwensbalk",
  "tag": "section",
  "blocks": [
    {
      "type": "desktop_item",
      "name": "Desktop item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icoon", "default": "gift",
          "options": [
            {"value":"gift","label":"Cadeau"},{"value":"paw","label":"Poot"},
            {"value":"heart","label":"Hart"},{"value":"star","label":"Ster"},
            {"value":"truck","label":"Vrachtwagen"},{"value":"shield","label":"Schild"},
            {"value":"refresh","label":"Retour"},{"value":"toy","label":"Speeltje"}
          ]
        },
        { "type": "select", "id": "color", "label": "Kleur", "default": "green",
          "options": [
            {"value":"green","label":"Groen"},{"value":"orange","label":"Oranje"},
            {"value":"pink","label":"Roze"},{"value":"yellow","label":"Geel"},
            {"value":"brown","label":"Bruin"},{"value":"teal","label":"Turquoise"}
          ]
        },
        { "type": "text", "id": "title",    "label": "Titel",    "default": "Duurzaam & bewust" },
        { "type": "text", "id": "subtitle", "label": "Subtitel", "default": "Geselecteerd met zorg" }
      ]
    },
    {
      "type": "mobile_item",
      "name": "Mobiel item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icoon", "default": "truck",
          "options": [
            {"value":"truck","label":"Vrachtwagen"},{"value":"shield","label":"Schild"},
            {"value":"refresh","label":"Retour"},{"value":"gift","label":"Cadeau"},
            {"value":"paw","label":"Poot"},{"value":"heart","label":"Hart"},
            {"value":"star","label":"Ster"}
          ]
        },
        { "type": "select", "id": "color", "label": "Kleur", "default": "green",
          "options": [
            {"value":"green","label":"Groen"},{"value":"orange","label":"Oranje"},
            {"value":"pink","label":"Roze"},{"value":"yellow","label":"Geel"}
          ]
        },
        { "type": "text", "id": "title",    "label": "Titel",    "default": "Snelle levering" },
        { "type": "text", "id": "subtitle", "label": "Subtitel", "default": "1-2 werkdagen" }
      ]
    }
  ],
  "presets": [{
    "name": "Vertrouwensbalk"
  }]
}
{% endschema %}
