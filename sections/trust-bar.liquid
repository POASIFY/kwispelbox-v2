<section class="trust-bar full-width">
  <div class="trust-bar__inner">

    {%- comment -%} Desktop: 4 merkwaarden items {%- endcomment -%}
    {%- assign desktop_blocks = section.blocks | where: 'type', 'desktop_item' -%}
    {%- for block in desktop_blocks -%}
      <div class="trust-bar__item trust-bar__item--desktop" {{ block.shopify_attributes }}>
        <span class="trust-bar__icon trust-bar__icon--{{ block.settings.color }}" aria-hidden="true">
          {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
        </span>
        <span class="trust-bar__text">
          <strong>{{ block.settings.title }}</strong>
          <span>{{ block.settings.subtitle }}</span>
        </span>
      </div>
    {%- endfor -%}

    {%- comment -%} Mobiel: 3 USP items {%- endcomment -%}
    {%- assign mobile_blocks = section.blocks | where: 'type', 'mobile_item' -%}
    {%- for block in mobile_blocks -%}
      <div class="trust-bar__item trust-bar__item--mobile" {{ block.shopify_attributes }}>
        <span class="trust-bar__icon trust-bar__icon--{{ block.settings.color }}" aria-hidden="true">
          {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
        </span>
        <span class="trust-bar__text">
          <strong>{{ block.settings.title }}</strong>
          <span>{{ block.settings.subtitle }}</span>
        </span>
      </div>
    {%- endfor -%}

  </div>
</section>

{% stylesheet %}
.trust-bar {
  background: #ffffff;
  border-top: 1px solid #EDE2C9;
  border-bottom: 1px solid #EDE2C9;
}
.trust-bar__inner {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
}

/* Desktop items */
.trust-bar__item--desktop {
  display: none;
  flex: 1;
  align-items: center;
  gap: 14px;
  padding: 20px 24px;
  border-right: 1px solid #EDE2C9;
}
.trust-bar__item--desktop:last-of-type { border-right: none; }

/* Mobiel items */
.trust-bar__item--mobile {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10px;
  padding: 20px 8px;
  border-right: 1px solid #EDE2C9;
}
.trust-bar__item--mobile:last-of-type { border-right: none; }

/* Icon */
.trust-bar__icon {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
/* Desktop: grote ronde gekleurde cirkel */
.trust-bar__item--desktop .trust-bar__icon {
  width: 48px; height: 48px;
}
/* Mobiel: kleiner, geen achtergrond */
.trust-bar__item--mobile .trust-bar__icon {
  width: 32px; height: 32px;
  background: transparent !important;
}
.trust-bar__icon svg { width: 22px; height: 22px; }
.trust-bar__item--mobile .trust-bar__icon svg { width: 26px; height: 26px; }

.trust-bar__icon--green  { background: #e8f5e2; color: #66AA44; }
.trust-bar__icon--orange { background: #fff0e4; color: #F7A048; }
.trust-bar__icon--pink   { background: #fff0f5; color: #e75480; }
.trust-bar__icon--yellow { background: #fffae0; color: #c49000; }
.trust-bar__icon--brown  { background: #F8EFDD; color: #A88259; }
.trust-bar__icon--teal   { background: #e0f5f0; color: #2a9d8f; }

.trust-bar__text { display: flex; flex-direction: column; gap: 2px; }
.trust-bar__text strong { font-family: 'Karla', sans-serif; font-size: .875rem; font-weight: 800; color: #603A15; line-height: 1.2; }
.trust-bar__text span   { font-size: .75rem; color: #A88259; line-height: 1.3; }

/* Mobiel layout */
@media (max-width: 767px) {
  .trust-bar__item--desktop { display: none !important; }
  .trust-bar__item--mobile  { display: flex; }
  .trust-bar__inner { padding: 0; }
}

/* Desktop layout */
@media (min-width: 768px) {
  .trust-bar__item--desktop { display: flex; }
  .trust-bar__item--mobile  { display: none !important; }
  .trust-bar__inner { padding: 0 60px; }
}
{% endstylesheet %}

{% schema %}
