<header class="kw-header full-width" id="KwHeader">

  <!-- RIJ 1: Logo + Zoek + Acties ──────────────────────────────── -->
  <div class="kw-header__top">
    <div class="kw-header__inner">

      <!-- Hamburger — alleen mobiel, staat links -->
      <button type="button" class="kw-icon-btn kw-menu-btn"
              aria-expanded="false" aria-controls="KwDrawer"
              aria-label="{{ 'header.menu_open' | t }}">
        {{- 'icon-menu.svg' | inline_asset_content -}}
      </button>

      <a href="{{ routes.root_url }}" class="kw-logo" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 220 }}"
               alt="{{ shop.name }}" width="160" height="52"
               loading="eager" fetchpriority="high">
        {%- else -%}
          <span class="kw-logo__text">
            {{ shop.name }}<span class="kw-logo__paw" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
          </span>
        {%- endif -%}
      </a>

      <form action="{{ routes.search_url }}" method="get"
            class="kw-search" role="search" aria-label="Zoeken">
        <input type="hidden" name="type" value="product">
        <div class="kw-search__field">
          <span class="kw-search__ico" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
          <label for="KwSearchInput" class="kw-sr-only">Zoekterm</label>
          <input type="search" id="KwSearchInput" name="q"
                 class="kw-search__input"
                 placeholder="{{ section.settings.search_placeholder }}"
                 autocomplete="off" value="{{ search.terms | escape }}">
        </div>
        <button type="submit" class="kw-search__submit">Zoeken</button>
      </form>

      <div class="kw-actions">
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_url }}" class="kw-account-btn" aria-label="Mijn account">
            <span class="kw-account-btn__icon">{{- 'icon-account.svg' | inline_asset_content -}}</span>
            <span class="kw-account-btn__labels">
              <span class="kw-account-btn__title">Mijn account</span>
              <span class="kw-account-btn__sub">Inloggen / Registreren</span>
            </span>
          </a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="kw-cart-btn"
           aria-label="Winkelwagen, {{ cart.item_count }} items">
          {{- 'icon-cart.svg' | inline_asset_content -}}
          <span class="kw-cart-btn__label">Winkelwagen</span>
          {%- if cart.item_count > 0 -%}
            <span class="kw-cart-btn__badge" data-cart-count>{{- cart.item_count -}}</span>
          {%- endif -%}
        </a>
      </div>

    </div>
  </div>

  <!-- RIJ 2: Mobiele zoekbalk ────────────────────────────────────── -->
  <div class="kw-search-mob full-width">
    <form action="{{ routes.search_url }}" method="get" role="search" aria-label="Zoeken">
      <input type="hidden" name="type" value="product">
      <span class="kw-search__ico" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
      <label for="KwSearchMob" class="kw-sr-only">Zoekterm</label>
      <input type="search" id="KwSearchMob" name="q"
             class="kw-search__input"
             placeholder="{{ section.settings.search_placeholder }}"
             autocomplete="off" value="{{ search.terms | escape }}">
    </form>
  </div>

  <!-- RIJ 3: Mobiele snelkoppelingen ─────────────────────────────── -->
  {%- assign shortcut_blocks = section.blocks | where: 'type', 'shortcut' -%}
  {%- if shortcut_blocks.size > 0 -%}
    <div class="kw-shortcuts full-width">
      <ul class="kw-shortcuts__list" role="list">
        {%- for block in shortcut_blocks -%}
          <li {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}" class="kw-shortcut">
              <span class="kw-shortcut__icon kw-shortcut__icon--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <span class="kw-shortcut__label">{{ block.settings.title }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}

  <!-- RIJ 4: Navigatie + Trust trio (desktop) ────────────────────── -->
  <nav class="kw-nav full-width" aria-label="{{ 'general.header' | t }}">
    <div class="kw-nav__inner">

      <ul class="kw-nav__list" role="list">
        {%- assign nav_blocks = section.blocks | where: 'type', 'nav_item' -%}
        {%- if nav_blocks.size > 0 -%}
          {%- for block in nav_blocks -%}
            <li class="kw-nav__item" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.url }}"
                 class="kw-nav__link kw-nav__link--pill{% if request.path == block.settings.url %} is-active{% endif %}">
                {%- if block.settings.icon != blank -%}
                  <span class="kw-nav__pill-icon kw-nav__pill-icon--{{ block.settings.color }}" aria-hidden="true">
                    {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
                  </span>
                {%- endif -%}
                {{ block.settings.title }}
                {%- if block.settings.show_chevron -%}
                  <span class="kw-nav__chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for link in section.settings.menu.links -%}
            <li class="kw-nav__item{% if link.child_links.size > 0 %} has-sub{% endif %}">
              <a href="{{ link.url }}"
                 class="kw-nav__link{% if link.active %} is-active{% endif %}"
                 {%- if link.child_links.size > 0 %} aria-haspopup="true" aria-expanded="false"{%- endif %}>
                {{- link.title -}}
                {%- if link.child_links.size > 0 -%}
                  <span class="kw-nav__chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                {%- endif -%}
              </a>
              {%- if link.child_links.size > 0 -%}
                <ul class="kw-dropdown" role="list">
                  {%- for child in link.child_links -%}
                    <li><a href="{{ child.url }}" class="kw-dropdown__link{% if child.active %} is-active{% endif %}">{{- child.title -}}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>

      <!-- Trust trio -->
      <ul class="kw-trust" role="list">
        <li class="kw-trust__item">
          <span class="kw-trust__icon" aria-hidden="true">{{- 'icon-truck.svg' | inline_asset_content -}}</span>
          <span class="kw-trust__text"><strong>Snelle levering</strong><span>1-2 werkdagen</span></span>
        </li>
        <li class="kw-trust__item">
          <span class="kw-trust__icon" aria-hidden="true">{{- 'icon-refresh.svg' | inline_asset_content -}}</span>
          <span class="kw-trust__text"><strong>Niet goed?</strong><span>Geld terug</span></span>
        </li>
        <li class="kw-trust__item">
          <span class="kw-trust__icon" aria-hidden="true">{{- 'icon-shield.svg' | inline_asset_content -}}</span>
          <span class="kw-trust__text"><strong>Veilig betalen</strong><span>100% veilig</span></span>
        </li>
      </ul>

    </div>
  </nav>

</header>

<!-- Mobiel drawer ──────────────────────────────────────────────── -->
<dialog class="kw-drawer" id="KwDrawer" aria-label="{{ 'general.header' | t }}">
  <div class="kw-drawer__panel">

    <!-- Head: merk + tagline + sluitknop -->
    <div class="kw-drawer__head">
      <button type="button" class="kw-icon-btn kw-drawer__close" aria-label="{{ 'header.menu_close' | t }}" autofocus>
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
      <a href="{{ routes.root_url }}" class="kw-drawer__brand" aria-label="{{ shop.name }}">
        <span class="kw-drawer__brand-paw" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
        <span class="kw-drawer__brand-text">
          <span class="kw-drawer__brand-name">{{ shop.name }}</span>
          {%- if section.settings.drawer_tagline != blank -%}
            <span class="kw-drawer__brand-tag">
              {{ section.settings.drawer_tagline }}
              <span class="kw-drawer__brand-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
            </span>
          {%- endif -%}
        </span>
      </a>
    </div>

    <div class="kw-drawer__scroll">

      <!-- Categorie-rijen (gevoed door nav_item-blocks) -->
      <nav class="kw-drawer__nav" aria-label="{{ 'general.header' | t }}">
        <ul role="list">
          {%- if nav_blocks.size > 0 -%}
            {%- for block in nav_blocks -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url }}" class="kw-drawer__row{% if request.path == block.settings.url %} is-active{% endif %}">
                  {%- if block.settings.icon != blank -%}
                    <span class="kw-drawer__row-icon kw-icon--{{ block.settings.color }}" aria-hidden="true">
                      {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
                    </span>
                  {%- endif -%}
                  <span class="kw-drawer__row-label">{{ block.settings.title }}</span>
                  {%- if block.settings.badge != blank -%}
                    <span class="kw-drawer__row-badge">{{ block.settings.badge }}</span>
                  {%- endif -%}
                  <span class="kw-drawer__row-chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endfor -%}
          {%- else -%}
            {%- for link in section.settings.menu.links -%}
              <li>
                <a href="{{ link.url }}" class="kw-drawer__row{% if link.active %} is-active{% endif %}">
                  <span class="kw-drawer__row-label">{{- link.title -}}</span>
                  <span class="kw-drawer__row-chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </nav>

      <!-- Kwispelclub-kaart -->
      {%- if section.settings.club_title != blank -%}
        <a href="{{ section.settings.club_url }}" class="kw-drawer__club">
          <span class="kw-drawer__club-icon" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
          <span class="kw-drawer__club-text">
            <span class="kw-drawer__club-title">{{ section.settings.club_title }}</span>
            {%- if section.settings.club_body != blank -%}
              <span class="kw-drawer__club-body">{{ section.settings.club_body }}</span>
            {%- endif -%}
          </span>
          <span class="kw-drawer__club-arrow" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
        </a>
      {%- endif -%}

      <!-- Secundaire links -->
      <ul class="kw-drawer__links" role="list">
        {%- if shop.customer_accounts_enabled -%}
          <li><a href="{{ routes.account_url }}" class="kw-drawer__minilink">
            <span aria-hidden="true">{{- 'icon-account.svg' | inline_asset_content -}}</span>Mijn account
          </a></li>
          <li><a href="{{ routes.account_url }}" class="kw-drawer__minilink">
            <span aria-hidden="true">{{- 'icon-box.svg' | inline_asset_content -}}</span>Mijn bestellingen
          </a></li>
        {%- endif -%}
        {%- if section.settings.faq_url != blank -%}
          <li><a href="{{ section.settings.faq_url }}" class="kw-drawer__minilink">
            <span aria-hidden="true">{{- 'icon-shield.svg' | inline_asset_content -}}</span>Veelgestelde vragen
          </a></li>
        {%- endif -%}
        {%- if section.settings.contact_url != blank -%}
          <li><a href="{{ section.settings.contact_url }}" class="kw-drawer__minilink">
            <span aria-hidden="true">{{- 'icon-mail.svg' | inline_asset_content -}}</span>Contact
          </a></li>
        {%- endif -%}
      </ul>

      <!-- CTA-kaart onderaan -->
      {%- if section.settings.cta_title != blank -%}
        <a href="{{ section.settings.cta_url }}" class="kw-drawer__cta">
          <span class="kw-drawer__cta-body">
            <span class="kw-drawer__cta-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
            <span class="kw-drawer__cta-title">{{ section.settings.cta_title }}</span>
            {%- if section.settings.cta_button != blank -%}
              <span class="kw-drawer__cta-btn">
                {{ section.settings.cta_button }}
                <span class="kw-drawer__cta-btn-arrow" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
              </span>
            {%- endif -%}
          </span>
          {%- if section.settings.cta_image != blank -%}
            <span class="kw-drawer__cta-img" aria-hidden="true">
              {{ section.settings.cta_image | image_url: width: 320 | image_tag:
                 widths: '160, 320', sizes: '160px',
                 loading: 'lazy', alt: '' }}
            </span>
          {%- endif -%}
        </a>
      {%- endif -%}

    </div>
  </div>
</dialog>

{% stylesheet %}
.kw-sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

/* Header */
.kw-header{background:#fff;position:sticky;top:0;z-index:100;box-shadow:0 1px 0 #EDE2C9;transition:box-shadow 240ms ease}
.kw-header.scrolled{box-shadow:0 4px 20px rgba(96,58,21,.12)}
.kw-header__top{border-bottom:1px solid #EDE2C9}
.kw-header__inner{
  max-width:1280px;margin:0 auto;padding:12px 20px;
  display:grid;
  grid-template-columns: 44px 1fr auto;
  align-items:center;gap:8px;
}
@media(min-width:768px){
  .kw-header__inner{
    display:flex;
    gap:16px;
  }
  .kw-menu-btn{ display:none!important; }
}
@media(min-width:1200px){.kw-header__inner{padding:12px 60px}}

/* Logo */
.kw-logo{text-decoration:none;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.kw-logo img{height:48px;width:auto}
.kw-logo__text{font-family:'Lilita One',cursive;font-size:1.8rem;color:#F7A048;line-height:1;white-space:nowrap;display:flex;align-items:center;gap:3px}
.kw-logo__paw{display:flex;align-items:flex-end;margin-bottom:4px}
.kw-logo__paw svg{width:20px;height:20px;color:#F7A048}

/* Zoekbalk */
.kw-search{display:none;flex:1;max-width:600px}
.kw-search__field{display:flex;align-items:center;background:#F8EFDD;border:2px solid #DAC9A1;border-radius:999px 0 0 999px;height:50px;padding:0 16px;flex:1;transition:border-color 200ms,box-shadow 200ms}
.kw-search__field:focus-within{border-color:#F7A048;box-shadow:0 0 0 3px rgba(247,160,72,.15)}
.kw-search__ico{color:#A88259;flex-shrink:0;display:flex;align-items:center;margin-right:10px}
.kw-search__ico svg{width:18px;height:18px}
.kw-search__input{flex:1;border:none;outline:none;background:transparent;font-family:'Karla',sans-serif;font-size:.95rem;color:#603A15;min-width:0}
.kw-search__input::placeholder{color:#A88259}
.kw-search__input::-webkit-search-cancel-button{display:none}
.kw-search__submit{height:50px;padding:0 24px;background:#F7A048;color:#fff;font-family:'Lilita One',cursive;font-size:.95rem;border:none;border-radius:0 999px 999px 0;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:background 160ms}
.kw-search__submit:hover{background:#d9823a}

/* Acties */
.kw-actions{display:flex;align-items:center;gap:10px;margin-left:auto;flex-shrink:0}
.kw-account-btn{display:none;align-items:center;gap:10px;text-decoration:none;color:#603A15;padding:6px 12px;border-radius:12px;transition:background 160ms}
.kw-account-btn:hover{background:#F8EFDD}
.kw-account-btn__icon{display:flex;color:#603A15}
.kw-account-btn__icon svg{width:24px;height:24px}
.kw-account-btn__labels{display:flex;flex-direction:column;gap:1px}
.kw-account-btn__title{font-family:'Karla',sans-serif;font-size:.8rem;font-weight:700;color:#603A15;line-height:1.2}
.kw-account-btn__sub{font-family:'Karla',sans-serif;font-size:.7rem;color:#A88259;line-height:1.2}
.kw-cart-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;height:44px;width:44px;padding:0;background:#66AA44;color:#fff;border-radius:50%;text-decoration:none;font-family:'Lilita One',cursive;font-size:.95rem;position:relative;flex-shrink:0;transition:background 160ms,transform 200ms cubic-bezier(.34,1.56,.64,1)}
@media(min-width:768px){
  .kw-cart-btn{height:48px;width:auto;padding:0 20px;border-radius:999px}
}
.kw-cart-btn:hover{background:#4d8833;transform:translateY(-2px)}
.kw-cart-btn svg{width:20px;height:20px}
.kw-cart-btn__label{display:none}
.kw-cart-btn--full{width:100%}
.kw-cart-btn__badge{background:#F7A048;color:#fff;font-family:'Lilita One',cursive;font-size:.75rem;min-width:22px;height:22px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;padding:0 5px}
.kw-icon-btn{display:flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:50%;background:transparent;border:none;cursor:pointer;color:#603A15;text-decoration:none;transition:background 160ms,color 160ms}
.kw-icon-btn:hover{background:#EDE2C9;color:#F7A048}
.kw-icon-btn svg{width:22px;height:22px}
.kw-menu-btn{display:flex;order:-1}
@media(min-width:768px){.kw-menu-btn{order:0}}

/* Mobiele zoekbalk */
.kw-search-mob{background:#F8EFDD;border-top:1px solid #EDE2C9;padding:10px 20px}
.kw-search-mob form{display:flex;align-items:center;gap:8px;background:#fff;border:2px solid #DAC9A1;border-radius:999px;height:42px;padding:0 16px;width:100%;transition:border-color 200ms}
.kw-search-mob form:focus-within{border-color:#F7A048}
.kw-search-mob .kw-search__input{flex:1;border:none;outline:none;background:transparent;font-family:'Karla',sans-serif;font-size:.9rem;color:#603A15;min-width:0}
.kw-search-mob .kw-search__ico{color:#A88259;display:flex;flex-shrink:0}
.kw-search-mob .kw-search__ico svg{width:16px;height:16px}

/* Mobiele snelkoppelingen */
.kw-shortcuts{background:#fff;border-top:1px solid #EDE2C9;padding:8px 0;}
.kw-shortcuts__list{display:grid;grid-template-columns:repeat(4,1fr);list-style:none;margin:0;padding:0 8px;width:100%;box-sizing:border-box;}
.kw-shortcut{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;text-decoration:none;padding:6px 0;}
.kw-shortcut__icon{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform 200ms cubic-bezier(.34,1.56,.64,1)}
.kw-shortcut:hover .kw-shortcut__icon{transform:scale(1.08)}
.kw-shortcut__icon svg{width:24px;height:24px}
.kw-shortcut__label{font-family:'Karla',sans-serif;font-size:.7rem;font-weight:700;color:#603A15;text-align:center;white-space:nowrap}
.kw-shortcuts__list li:nth-child(n+5){display:none;}

/* Icon kleuren */
.kw-shortcut__icon--green,.kw-nav__pill-icon--green{background:#e8f5e2;color:#66AA44}
.kw-shortcut__icon--orange,.kw-nav__pill-icon--orange{background:#fff0e4;color:#F7A048}
.kw-shortcut__icon--pink,.kw-nav__pill-icon--pink{background:#fff0f5;color:#e75480}
.kw-shortcut__icon--yellow,.kw-nav__pill-icon--yellow{background:#fffae0;color:#c49000}
.kw-shortcut__icon--brown,.kw-nav__pill-icon--brown{background:#F8EFDD;color:#A88259}

/* Nav balk */
.kw-nav{background:#fff;border-top:1px solid #EDE2C9;display:none}
.kw-nav__inner{max-width:1280px;margin:0 auto;padding:0 20px;display:flex;align-items:center;gap:0}
@media(min-width:1200px){.kw-nav__inner{padding:0 60px}}
.kw-nav__list{display:flex;align-items:center;list-style:none;height:56px;gap:4px}
.kw-nav__item{position:relative}

/* Standaard nav link */
.kw-nav__link{display:inline-flex;align-items:center;gap:6px;padding:0 16px;height:56px;font-family:'Karla',sans-serif;font-size:.9rem;font-weight:700;color:#A88259;text-decoration:none;white-space:nowrap;position:relative;transition:color 160ms}
.kw-nav__link::after{content:'';position:absolute;bottom:0;left:16px;right:16px;height:3px;background:#F7A048;border-radius:3px 3px 0 0;transform:scaleX(0);transition:transform 220ms cubic-bezier(.34,1.56,.64,1)}
.kw-nav__link:hover{color:#603A15}
.kw-nav__link:hover::after,.kw-nav__link.is-active::after{transform:scaleX(1)}
.kw-nav__link.is-active{color:#F7A048}

/* Pill nav link */
.kw-nav__link--pill{height:40px;margin:8px 2px;padding:0 14px;border-radius:999px;background:#F8EFDD;color:#603A15;font-weight:700}
.kw-nav__link--pill::after{display:none}
.kw-nav__link--pill:hover{background:#EDE2C9;color:#603A15;transform:none}
.kw-nav__link--pill.is-active{background:#F7A048;color:#fff}
.kw-nav__pill-icon{width:22px;height:22px;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.kw-nav__pill-icon svg{width:13px;height:13px}
.kw-nav__chevron{display:flex;align-items:center}
.kw-nav__chevron svg{width:11px;height:11px}

/* Dropdown */
.kw-dropdown{position:absolute;top:calc(100% + 4px);left:0;min-width:200px;background:#fff;border:1.5px solid #DAC9A1;border-radius:16px;box-shadow:0 4px 20px rgba(96,58,21,.12);padding:8px;list-style:none;z-index:10;opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity 200ms,visibility 200ms,transform 200ms}
.kw-nav__item.has-sub:hover .kw-dropdown,.kw-nav__item.has-sub:focus-within .kw-dropdown{opacity:1;visibility:visible;transform:translateY(0)}
.kw-dropdown__link{display:block;padding:10px 16px;font-family:'Karla',sans-serif;font-size:.9rem;font-weight:600;color:#603A15;text-decoration:none;border-radius:10px;transition:background 140ms,color 140ms}
.kw-dropdown__link:hover,.kw-dropdown__link.is-active{background:#fff0e4;color:#d9823a}

/* Trust trio */
.kw-trust{display:flex;align-items:center;list-style:none;border-left:1px solid #EDE2C9;margin-left:auto;flex-shrink:0}
.kw-trust__item{display:flex;align-items:center;gap:8px;padding:8px 16px;border-right:1px solid #EDE2C9}
.kw-trust__item:last-child{border-right:none}
.kw-trust__icon{display:flex;align-items:center;color:#66AA44;flex-shrink:0}
.kw-trust__icon svg{width:18px;height:18px}
.kw-trust__text{display:flex;flex-direction:column;gap:1px}
.kw-trust__text strong{font-family:'Karla',sans-serif;font-size:.75rem;font-weight:700;color:#603A15;line-height:1.2}
.kw-trust__text span{font-size:.65rem;color:#A88259;line-height:1.2}

/* Desktop */
@media(min-width:768px){
  .kw-search{display:flex}
  .kw-search-mob{display:none}
  .kw-shortcuts{display:none}
  .kw-nav{display:block}
  .kw-actions{margin-left:0}
  .kw-account-btn{display:flex}
  .kw-cart-btn__label{display:inline}
  .kw-cart-btn{height:48px;width:auto;padding:0 20px;border-radius:999px}
  .kw-cart-btn__badge{position:absolute;top:-6px;right:-6px}
}
@media(max-width:767px){
  .kw-account-btn{display:none!important}
  .kw-cart-btn__label{display:none!important}
  .kw-cart-btn{
    background:transparent!important;
    color:#603A15!important;
    width:44px;height:44px;padding:0;
    box-shadow:none!important;
    transform:none!important;
  }
  .kw-cart-btn:hover{background:transparent!important;transform:none!important}
  .kw-cart-btn svg{width:26px;height:26px}
  .kw-cart-btn__badge{
    position:absolute;top:-4px;right:-4px;
    min-width:18px;height:18px;font-size:.65rem;
    border:2px solid #F8EFDD;
  }
}

/* Drawer */
.kw-drawer{position:fixed;inset:0;z-index:200;padding:0;border:none;background:transparent;max-width:100%;max-height:100%;width:100%;height:100%;touch-action:none}
.kw-drawer::backdrop{background:rgba(61,34,9,.5)}
.kw-drawer:not([open]){display:none}
.kw-drawer[open]{display:flex;justify-content:flex-start}
.kw-drawer__panel{background:#FCF6EC;width:340px;max-width:90vw;height:100%;display:flex;flex-direction:column;animation:kw-panel-in 300ms ease forwards;overscroll-behavior:contain}
@keyframes kw-panel-in{from{transform:translateX(-100%)}to{transform:translateX(0)}}
.kw-drawer__scroll{flex:1;overflow-y:auto;overscroll-behavior:contain;-webkit-overflow-scrolling:touch;padding:8px 16px 20px;display:flex;flex-direction:column}

/* Head */
.kw-drawer__head{display:flex;align-items:center;gap:14px;padding:14px 16px 10px;flex-shrink:0}
.kw-drawer__close{background:transparent;flex-shrink:0}
.kw-drawer__close:hover{background:#EDE2C9}
.kw-drawer__brand{display:flex;align-items:center;gap:10px;text-decoration:none;min-width:0}
.kw-drawer__brand-paw{display:flex;align-items:center;justify-content:center;color:#3d2209;flex-shrink:0}
.kw-drawer__brand-paw svg{width:34px;height:34px}
.kw-drawer__brand-text{display:flex;flex-direction:column;gap:2px;min-width:0}
.kw-drawer__brand-name{font-family:'Lilita One',cursive;font-size:1.6rem;color:#3d2209;line-height:1}
.kw-drawer__brand-tag{display:flex;align-items:center;gap:5px;font-family:'Karla',sans-serif;font-size:.85rem;font-weight:700;color:#66AA44;line-height:1}
.kw-drawer__brand-heart{display:flex;color:#FFB8CD}
.kw-drawer__brand-heart svg{width:14px;height:14px}

/* Categorie-rijen */
.kw-drawer__nav ul{list-style:none;margin:0;padding:0}
.kw-drawer__row{display:flex;align-items:center;gap:14px;padding:14px 8px;text-decoration:none;border-bottom:1px solid #EDE2C9;transition:background 140ms}
.kw-drawer__nav li:last-child .kw-drawer__row{border-bottom:none}
.kw-drawer__row:hover,.kw-drawer__row.is-active{background:#fff}
.kw-drawer__row-icon{width:38px;height:38px;border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:transparent}
.kw-drawer__row-icon svg{width:26px;height:26px}
.kw-drawer__row-icon.kw-icon--green{color:#66AA44}
.kw-drawer__row-icon.kw-icon--orange{color:#F7A048}
.kw-drawer__row-icon.kw-icon--pink{color:#e75480}
.kw-drawer__row-icon.kw-icon--yellow{color:#c49000}
.kw-drawer__row-icon.kw-icon--brown{color:#A88259}
.kw-drawer__row-label{flex:1;font-family:'Lilita One',cursive;font-size:1.15rem;color:#3d2209;line-height:1.1}
.kw-drawer__row-badge{flex-shrink:0;background:#F7A048;color:#fff;font-family:'Karla',sans-serif;font-size:.7rem;font-weight:800;padding:3px 10px;border-radius:999px;text-transform:uppercase;letter-spacing:.02em}
.kw-drawer__row-chevron{flex-shrink:0;display:flex;color:#A88259;transform:rotate(-90deg)}
.kw-drawer__row-chevron svg{width:18px;height:18px}

/* Kwispelclub-kaart */
.kw-drawer__club{display:flex;align-items:center;gap:14px;margin-top:16px;padding:16px;background:#e8f5e2;border-radius:18px;text-decoration:none;transition:background 160ms}
.kw-drawer__club:hover{background:#daefcf}
.kw-drawer__club-icon{width:44px;height:44px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#66AA44}
.kw-drawer__club-icon svg{width:22px;height:22px}
.kw-drawer__club-text{flex:1;display:flex;flex-direction:column;gap:2px;min-width:0}
.kw-drawer__club-title{font-family:'Lilita One',cursive;font-size:1.05rem;color:#3d2209;line-height:1.1}
.kw-drawer__club-body{font-family:'Karla',sans-serif;font-size:.82rem;font-weight:600;color:#4d8833;line-height:1.25}
.kw-drawer__club-arrow{width:38px;height:38px;border-radius:50%;background:#66AA44;color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;transform:rotate(-90deg)}
.kw-drawer__club-arrow svg{width:18px;height:18px}

/* Secundaire links */
.kw-drawer__links{list-style:none;margin:18px 0 0;padding:0;display:flex;flex-direction:column;gap:2px}
.kw-drawer__minilink{display:flex;align-items:center;gap:14px;padding:11px 8px;font-family:'Karla',sans-serif;font-size:1rem;font-weight:700;color:#3d2209;text-decoration:none;border-radius:12px;transition:background 140ms,color 140ms}
.kw-drawer__minilink:hover{background:#fff;color:#d9823a}
.kw-drawer__minilink span{display:flex;align-items:center;justify-content:center;color:#3d2209;flex-shrink:0}
.kw-drawer__minilink:hover span{color:#d9823a}
.kw-drawer__minilink svg{width:22px;height:22px}

/* CTA-kaart */
.kw-drawer__cta{position:relative;display:flex;align-items:flex-end;justify-content:space-between;gap:8px;margin-top:18px;min-height:130px;padding:18px;background:#4d7a30;border-radius:22px;overflow:hidden;text-decoration:none}
.kw-drawer__cta-body{position:relative;z-index:1;display:flex;flex-direction:column;align-items:flex-start;gap:10px;max-width:60%}
.kw-drawer__cta-heart{display:flex;color:#fff}
.kw-drawer__cta-heart svg{width:20px;height:20px}
.kw-drawer__cta-title{font-family:'Lilita One',cursive;font-size:1.25rem;color:#fff;line-height:1.1}
.kw-drawer__cta-btn{display:inline-flex;align-items:center;gap:6px;background:#fff;color:#3d2209;font-family:'Lilita One',cursive;font-size:.85rem;padding:9px 16px;border-radius:999px}
.kw-drawer__cta-btn-arrow{display:flex;transform:rotate(-90deg)}
.kw-drawer__cta-btn-arrow svg{width:14px;height:14px}
.kw-drawer__cta-img{position:absolute;right:-6px;bottom:0;width:48%;max-width:170px;display:flex;align-items:flex-end;z-index:0}
.kw-drawer__cta-img img{width:100%;height:auto;object-fit:contain}

@media(prefers-reduced-motion:reduce){
  .kw-header,.kw-cart-btn,.kw-nav__link::after,.kw-dropdown,.kw-drawer__panel{transition:none;animation:none}
}
{% endstylesheet %}

{% javascript %}
(function () {
  var header  = document.getElementById('KwHeader');
  var drawer  = document.getElementById('KwDrawer');
  var menuBtn = document.querySelector('.kw-menu-btn');
  var closeBtn = document.querySelector('.kw-drawer__close');

  if (header) {
    window.addEventListener('scroll', function () {
      header.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });
  }

  function openDrawer() {
    if (!drawer) return;
    drawer.showModal();
    document.body.style.overflow = 'hidden';
    if (menuBtn) menuBtn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    if (!drawer) return;
    drawer.close();
    document.body.style.overflow = '';
    if (menuBtn) menuBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (menuBtn)  menuBtn.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (drawer) {
    drawer.addEventListener('click', function (e) { if (e.target === drawer) closeDrawer(); });
    drawer.addEventListener('cancel', function () {
      if (menuBtn) menuBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  }
})();
{% endjavascript %}

