{% comment %}
  ─────────────────────────────────────────────────────────────────
  KWISPELBOX — HEADER
  ─────────────────────────────────────────────────────────────────
  Structuur
    Rij 1  Logo · Zoekbalk (desktop) · Klantenservice/Account/Cart
    Rij 2  Zoekbalk (mobiel)
    Rij 3  Snelkoppelingen (mobiel, optionele blocks)
    Rij 4  Categorie-chips + trust-trio (desktop)
    Drawer Mobiel menu (dialog)

  Conventies
    · Design-tokens als CSS custom properties op .kw-header
    · Mobile-first; desktop-overrides in min-width queries
    · Geen !important; cascade geregeld via mobile-first opbouw
    · JS: predictive search (suggest.json) + drawer, vanilla ES5
  ─────────────────────────────────────────────────────────────────
{% endcomment %}

{%- assign nav_blocks      = section.blocks | where: 'type', 'nav_item' -%}
{%- assign shortcut_blocks = section.blocks | where: 'type', 'shortcut' -%}

<header class="kw-header full-width" id="KwHeader">

  {%- comment -%} ── RIJ 1 · Hoofdbalk ─────────────────────────── {%- endcomment -%}
  <div class="kw-header__main">
    <div class="kw-container kw-main">

      <button type="button" class="kw-iconbtn kw-burger"
              aria-expanded="false" aria-controls="KwDrawer"
              aria-label="{{ 'header.menu_open' | t }}">
        {{- 'icon-menu.svg' | inline_asset_content -}}
      </button>

      <a href="{{ routes.root_url }}" class="kw-logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_h   = section.settings.logo_height | default: 48 -%}
          {%- assign logo_alt = shop.name | escape -%}
          <img
            src="{{ section.settings.logo | image_url: width: 440 }}"
            srcset="{{ section.settings.logo | image_url: width: 220 }} 220w,
                    {{ section.settings.logo | image_url: width: 440 }} 440w"
            sizes="220px"
            alt="{{ logo_alt }}"
            class="kw-logo__img"
            style="height:{{ logo_h }}px"
            width="220" height="{{ logo_h }}"
            loading="eager" fetchpriority="high">
        {%- else -%}
          <span class="kw-logo__text">
            {{- shop.name -}}
            <span class="kw-logo__paw" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
          </span>
        {%- endif -%}
      </a>

      {%- comment -%} Zoekbalk · desktop — knop ín de pill (mockup) {%- endcomment -%}
      <form action="{{ routes.search_url }}" method="get"
            class="kw-search" role="search" aria-label="Zoeken" data-kw-search>
        <input type="hidden" name="type" value="product">
        <div class="kw-search__field">
          <span class="kw-search__ico" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
          <label for="KwSearchInput" class="kw-sr-only">Zoekterm</label>
          <input type="search" id="KwSearchInput" name="q"
                 class="kw-search__input" data-kw-search-input
                 placeholder="{{ section.settings.search_placeholder }}"
                 autocomplete="off" autocorrect="off" spellcheck="false"
                 role="combobox" aria-expanded="false" aria-autocomplete="list"
                 aria-controls="KwSearchResults" aria-label="Zoekterm"
                 value="{{ search.terms | escape }}">
          <button type="button" class="kw-search__clear" data-kw-search-clear
                  aria-label="Zoekterm wissen" hidden>{{- 'icon-close.svg' | inline_asset_content -}}</button>
          <button type="submit" class="kw-search__submit">Zoeken</button>
        </div>
        <div class="kw-search__results" id="KwSearchResults" data-kw-search-results role="listbox" hidden></div>
      </form>

      <div class="kw-actions">
        {%- if section.settings.service_url != blank -%}
          <a href="{{ section.settings.service_url }}" class="kw-textbtn" aria-label="Klantenservice">
            <span class="kw-textbtn__icon kw-textbtn__icon--green">{{- 'icon-shield.svg' | inline_asset_content -}}</span>
            <span class="kw-textbtn__labels">
              <span class="kw-textbtn__title">Klantenservice</span>
              <span class="kw-textbtn__sub">Hulp &amp; contact</span>
            </span>
          </a>
        {%- endif -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_url }}" class="kw-textbtn" aria-label="Mijn account">
            <span class="kw-textbtn__icon">{{- 'icon-account.svg' | inline_asset_content -}}</span>
            <span class="kw-textbtn__labels">
              <span class="kw-textbtn__title">Mijn account</span>
              <span class="kw-textbtn__sub">Inloggen / Registreren</span>
            </span>
          </a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="kw-cart" aria-label="Winkelwagen, {{ cart.item_count }} items">
          {{- 'icon-cart.svg' | inline_asset_content -}}
          <span class="kw-cart__label">Winkelwagen</span>
          {%- if cart.item_count > 0 -%}
            <span class="kw-cart__badge" data-cart-count>{{- cart.item_count -}}</span>
          {%- endif -%}
        </a>
      </div>

    </div>
  </div>

  {%- comment -%} ── RIJ 2 · Zoekbalk mobiel ───────────────────── {%- endcomment -%}
  <div class="kw-msearch full-width">
    <form action="{{ routes.search_url }}" method="get" role="search" aria-label="Zoeken"
          class="kw-msearch__form" data-kw-search>
      <input type="hidden" name="type" value="product">
      <div class="kw-msearch__field">
        <span class="kw-search__ico" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
        <label for="KwSearchMob" class="kw-sr-only">Zoekterm</label>
        <input type="search" id="KwSearchMob" name="q"
               class="kw-search__input" data-kw-search-input
               placeholder="{{ section.settings.search_placeholder }}"
               autocomplete="off" autocorrect="off" spellcheck="false"
               role="combobox" aria-expanded="false" aria-autocomplete="list"
               aria-controls="KwSearchResultsMob" aria-label="Zoekterm"
               value="{{ search.terms | escape }}">
        <button type="button" class="kw-search__clear" data-kw-search-clear
                aria-label="Zoekterm wissen" hidden>{{- 'icon-close.svg' | inline_asset_content -}}</button>
      </div>
      <button type="submit" class="kw-msearch__submit" aria-label="Zoeken">{{- 'icon-search.svg' | inline_asset_content -}}</button>
      <div class="kw-search__results" id="KwSearchResultsMob" data-kw-search-results role="listbox" hidden></div>
    </form>
  </div>

  {%- comment -%} ── RIJ 3 · Snelkoppelingen mobiel ────────────── {%- endcomment -%}
  {%- if shortcut_blocks.size > 0 -%}
    <div class="kw-shortcuts full-width">
      <ul class="kw-shortcuts__list" role="list">
        {%- for block in shortcut_blocks -%}
          <li {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}" class="kw-shortcut">
              <span class="kw-shortcut__icon kw-tint--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <span class="kw-shortcut__label">{{ block.settings.title }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}

  {%- comment -%} ── RIJ 4 · Chips + trust (desktop) ───────────── {%- endcomment -%}
  <nav class="kw-nav full-width" aria-label="{{ 'general.header' | t }}">
    <div class="kw-container kw-nav__bar">

      <ul class="kw-chips" role="list">
        {%- if nav_blocks.size > 0 -%}
          {%- for block in nav_blocks -%}
            <li {{ block.shopify_attributes }}>
              <a href="{{ block.settings.url }}"
                 class="kw-chip{% if request.path == block.settings.url %} is-active{% endif %}">
                {%- if block.settings.icon != blank -%}
                  <span class="kw-chip__icon kw-ink--{{ block.settings.color }}" aria-hidden="true">
                    {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
                  </span>
                {%- endif -%}
                {{ block.settings.title }}
                {%- if block.settings.show_chevron -%}
                  <span class="kw-chip__chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for link in section.settings.menu.links -%}
            <li{% if link.child_links.size > 0 %} class="has-sub"{% endif %}>
              <a href="{{ link.url }}" class="kw-chip{% if link.active %} is-active{% endif %}"
                 {%- if link.child_links.size > 0 %} aria-haspopup="true" aria-expanded="false"{%- endif %}>
                {{- link.title -}}
                {%- if link.child_links.size > 0 -%}
                  <span class="kw-chip__chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                {%- endif -%}
              </a>
              {%- if link.child_links.size > 0 -%}
                <ul class="kw-dropdown" role="list">
                  {%- for child in link.child_links -%}
                    <li><a href="{{ child.url }}" class="kw-dropdown__link{% if child.active %} is-active{% endif %}">{{- child.title -}}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>

      <ul class="kw-trust" role="list">
        <li class="kw-trust__item">
          <span class="kw-trust__icon" aria-hidden="true">{{- 'icon-truck.svg' | inline_asset_content -}}</span>
          <span class="kw-trust__text"><strong>Snelle levering</strong><span>1-2 werkdagen</span></span>
        </li>
        <li class="kw-trust__item">
          <span class="kw-trust__icon" aria-hidden="true">{{- 'icon-refresh.svg' | inline_asset_content -}}</span>
          <span class="kw-trust__text"><strong>Niet goed?</strong><span>Geld terug</span></span>
        </li>
        <li class="kw-trust__item">
          <span class="kw-trust__icon" aria-hidden="true">{{- 'icon-shield.svg' | inline_asset_content -}}</span>
          <span class="kw-trust__text"><strong>Veilig betalen</strong><span>100% veilig</span></span>
        </li>
      </ul>

    </div>
  </nav>

</header>

{%- comment -%} ── DRAWER · mobiel menu ──────────────────────────── {%- endcomment -%}
<dialog class="kw-drawer" id="KwDrawer" aria-label="{{ 'general.header' | t }}">
  <div class="kw-drawer__panel">

    <div class="kw-drawer__head">
      <button type="button" class="kw-iconbtn kw-drawer__close" aria-label="{{ 'header.menu_close' | t }}" autofocus>
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
      <a href="{{ routes.root_url }}" class="kw-drawer__brand" aria-label="{{ shop.name }}">
        <span class="kw-drawer__brand-paw" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
        <span class="kw-drawer__brand-text">
          <span class="kw-drawer__brand-name">{{ shop.name }}</span>
          {%- if section.settings.drawer_tagline != blank -%}
            <span class="kw-drawer__brand-tag">
              {{ section.settings.drawer_tagline }}
              <span class="kw-drawer__brand-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
            </span>
          {%- endif -%}
        </span>
      </a>
    </div>

    <div class="kw-drawer__scroll">

      <nav class="kw-drawer__nav" aria-label="{{ 'general.header' | t }}">
        <ul role="list">
          {%- if nav_blocks.size > 0 -%}
            {%- for block in nav_blocks -%}
              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.url }}" class="kw-drawer__row{% if request.path == block.settings.url %} is-active{% endif %}">
                  {%- if block.settings.icon != blank -%}
                    <span class="kw-drawer__row-icon kw-ink--{{ block.settings.color }}" aria-hidden="true">
                      {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
                    </span>
                  {%- endif -%}
                  <span class="kw-drawer__row-label">{{ block.settings.title }}</span>
                  {%- if block.settings.badge != blank -%}
                    <span class="kw-drawer__row-badge">{{ block.settings.badge }}</span>
                  {%- endif -%}
                  <span class="kw-drawer__row-chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endfor -%}
          {%- else -%}
            {%- for link in section.settings.menu.links -%}
              <li>
                <a href="{{ link.url }}" class="kw-drawer__row{% if link.active %} is-active{% endif %}">
                  <span class="kw-drawer__row-label">{{- link.title -}}</span>
                  <span class="kw-drawer__row-chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                </a>
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </nav>

      {%- if section.settings.club_title != blank -%}
        <a href="{{ section.settings.club_url }}" class="kw-drawer__club">
          <span class="kw-drawer__club-icon" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
          <span class="kw-drawer__club-text">
            <span class="kw-drawer__club-title">{{ section.settings.club_title }}</span>
            {%- if section.settings.club_body != blank -%}
              <span class="kw-drawer__club-body">{{ section.settings.club_body }}</span>
            {%- endif -%}
          </span>
          <span class="kw-drawer__club-arrow" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
        </a>
      {%- endif -%}

      <ul class="kw-drawer__links" role="list">
        {%- if shop.customer_accounts_enabled -%}
          <li><a href="{{ routes.account_url }}" class="kw-drawer__minilink">
            <span aria-hidden="true">{{- 'icon-account.svg' | inline_asset_content -}}</span>Mijn account
          </a></li>
        {%- endif -%}
        {%- if section.settings.service_url != blank -%}
          <li><a href="{{ section.settings.service_url }}" class="kw-drawer__minilink">
            <span aria-hidden="true">{{- 'icon-shield.svg' | inline_asset_content -}}</span>Klantenservice
          </a></li>
        {%- endif -%}
        {%- if section.settings.faq_url != blank -%}
          <li><a href="{{ section.settings.faq_url }}" class="kw-drawer__minilink">
            <span aria-hidden="true">{{- 'icon-bell.svg' | inline_asset_content -}}</span>Veelgestelde vragen
          </a></li>
        {%- endif -%}
        {%- if section.settings.contact_url != blank -%}
          <li><a href="{{ section.settings.contact_url }}" class="kw-drawer__minilink">
            <span aria-hidden="true">{{- 'icon-mail.svg' | inline_asset_content -}}</span>Contact
          </a></li>
        {%- endif -%}
      </ul>

      {%- if section.settings.cta_title != blank -%}
        <a href="{{ section.settings.cta_url }}" class="kw-drawer__cta">
          <span class="kw-drawer__cta-body">
            <span class="kw-drawer__cta-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
            <span class="kw-drawer__cta-title">{{ section.settings.cta_title }}</span>
            {%- if section.settings.cta_button != blank -%}
              <span class="kw-drawer__cta-btn">
                {{ section.settings.cta_button }}
                <span class="kw-drawer__cta-btn-arrow" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
              </span>
            {%- endif -%}
          </span>
          {%- if section.settings.cta_image != blank -%}
            <span class="kw-drawer__cta-img" aria-hidden="true">
              {{ section.settings.cta_image | image_url: width: 320 | image_tag:
                 widths: '160, 320', sizes: '160px',
                 loading: 'lazy', alt: '' }}
            </span>
          {%- endif -%}
        </a>
      {%- endif -%}

    </div>
  </div>
</dialog>

{% stylesheet %}
/* ════════════════════════════════════════════════════════════════
   TOKENS
   ════════════════════════════════════════════════════════════════ */
.kw-header{
  --green:#66AA44; --green-dark:#4d8833; --green-soft:#e8f5e2;
  --orange:#F7A048; --orange-dark:#d9823a;
  --pink:#e75480; --yellow:#e0a800;
  --ink:#3d2209; --body:#603A15; --soft:#A88259;
  --line:#EDE2C9; --line-strong:#DAC9A1;
  --cream:#F8EFDD; --cream-soft:#FBF6EC;
  --font-head:'Lilita One',cursive;
  --font-body:'Karla',sans-serif;
  --gutter:20px;
  --speed:160ms;
}
@media(min-width:1024px){.kw-header{--gutter:60px}}

.kw-container{max-width:1280px;margin-inline:auto;padding-inline:var(--gutter)}
.kw-sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

/* Kleur-utilities (iconen) */
.kw-ink--green{color:var(--green)}
.kw-ink--orange{color:var(--orange)}
.kw-ink--pink{color:var(--pink)}
.kw-ink--yellow{color:var(--yellow)}
.kw-ink--brown{color:var(--soft)}
.kw-tint--green{background:var(--green-soft);color:var(--green)}
.kw-tint--orange{background:#fff0e4;color:var(--orange)}
.kw-tint--pink{background:#fff0f5;color:var(--pink)}
.kw-tint--yellow{background:#fffae0;color:#c49000}
.kw-tint--brown{background:var(--cream);color:var(--soft)}

/* ════════════════════════════════════════════════════════════════
   SHELL
   ════════════════════════════════════════════════════════════════ */
.kw-header{background:#fff;position:sticky;top:0;z-index:100;box-shadow:0 1px 0 var(--line);transition:box-shadow 240ms ease}
.kw-header.scrolled{box-shadow:0 4px 20px rgba(96,58,21,.12)}
.kw-header__main{border-bottom:1px solid var(--line)}

/* ════════════════════════════════════════════════════════════════
   RIJ 1 · HOOFDBALK    mobiel: [burger][logo][cart] · desktop: flex
   ════════════════════════════════════════════════════════════════ */
.kw-main{display:grid;grid-template-columns:44px 1fr 44px;align-items:center;gap:8px;padding-block:10px}

.kw-iconbtn{display:flex;align-items:center;justify-content:center;width:44px;height:44px;border:none;border-radius:50%;background:transparent;color:var(--body);cursor:pointer;transition:background var(--speed)}
.kw-iconbtn:hover{background:var(--cream)}
.kw-iconbtn svg{width:24px;height:24px}

.kw-logo{display:flex;align-items:center;justify-content:center;min-width:0;text-decoration:none}
.kw-logo__img{width:auto;display:block;object-fit:contain}
.kw-logo__text{display:flex;align-items:center;gap:2px;font-family:var(--font-head);font-size:1.7rem;color:var(--orange);line-height:1;white-space:nowrap}
.kw-logo__paw{display:flex;align-self:flex-start;margin-top:-2px}
.kw-logo__paw svg{width:16px;height:16px}

/* Zoekbalk desktop — verborgen op mobiel */
.kw-search{display:none;position:relative;flex:1 1 auto;max-width:620px}
.kw-search__field{display:flex;align-items:center;gap:10px;height:52px;padding:4px 4px 4px 20px;background:var(--cream);border:1.5px solid var(--line);border-radius:999px;transition:border-color 200ms,box-shadow 200ms}
.kw-search__field:focus-within{border-color:var(--orange);box-shadow:0 0 0 3px rgba(247,160,72,.15)}
.kw-search__ico{display:flex;flex-shrink:0;color:var(--soft)}
.kw-search__ico svg{width:18px;height:18px}
.kw-search__input{flex:1;min-width:0;border:none;outline:none;background:transparent;font-family:var(--font-body);font-size:.95rem;color:var(--body)}
.kw-search__input::placeholder{color:var(--soft)}
.kw-search__input::-webkit-search-cancel-button{display:none}
.kw-search__clear{display:flex;align-items:center;justify-content:center;width:26px;height:26px;flex-shrink:0;border:none;border-radius:50%;background:var(--line-strong);color:var(--body);cursor:pointer;transition:background 140ms}
.kw-search__clear:hover{background:var(--soft);color:#fff}
.kw-search__clear svg{width:12px;height:12px}
.kw-search__submit{height:42px;padding:0 26px;flex-shrink:0;border:none;border-radius:999px;background:var(--orange);color:#fff;font-family:var(--font-head);font-size:.95rem;cursor:pointer;transition:background var(--speed)}
.kw-search__submit:hover{background:var(--orange-dark)}

/* Acties */
.kw-actions{display:flex;align-items:center;gap:6px;justify-self:end}

.kw-textbtn{display:none;align-items:center;gap:10px;padding:6px 12px;border-radius:12px;text-decoration:none;transition:background var(--speed)}
.kw-textbtn:hover{background:var(--cream)}
.kw-textbtn__icon{display:flex;color:var(--body)}
.kw-textbtn__icon--green{color:var(--green)}
.kw-textbtn__icon svg{width:25px;height:25px}
.kw-textbtn__labels{display:flex;flex-direction:column;gap:1px}
.kw-textbtn__title{font-family:var(--font-body);font-size:.85rem;font-weight:800;color:var(--ink);line-height:1.2;white-space:nowrap}
.kw-textbtn__sub{font-family:var(--font-body);font-size:.72rem;color:var(--soft);line-height:1.2;white-space:nowrap}

/* Cart — mobile-first: icoon, desktop: groene pill */
.kw-cart{position:relative;display:inline-flex;align-items:center;justify-content:center;gap:9px;width:44px;height:44px;border-radius:50%;background:transparent;color:var(--body);text-decoration:none;font-family:var(--font-head);font-size:.95rem;flex-shrink:0}
.kw-cart svg{width:25px;height:25px}
.kw-cart__label{display:none}
.kw-cart__badge{position:absolute;top:-4px;right:-4px;display:inline-flex;align-items:center;justify-content:center;min-width:19px;height:19px;padding:0 5px;border-radius:999px;border:2px solid #fff;background:var(--orange);color:#fff;font-family:var(--font-head);font-size:.68rem}

/* ════════════════════════════════════════════════════════════════
   RIJ 2 · ZOEKBALK MOBIEL
   ════════════════════════════════════════════════════════════════ */
.kw-msearch{background:var(--cream);border-top:1px solid var(--line);padding:10px var(--gutter)}
.kw-msearch__form{position:relative;display:flex;align-items:center;gap:8px}
.kw-msearch__field{display:flex;align-items:center;gap:8px;flex:1;min-width:0;height:44px;padding:0 16px;background:#fff;border:1.5px solid var(--line-strong);border-radius:999px;transition:border-color 200ms,box-shadow 200ms}
.kw-msearch__field:focus-within{border-color:var(--orange);box-shadow:0 0 0 3px rgba(247,160,72,.15)}
.kw-msearch .kw-search__ico svg{width:16px;height:16px}
.kw-msearch .kw-search__input{font-size:16px} /* voorkomt iOS-zoom */
.kw-msearch__submit{display:flex;align-items:center;justify-content:center;width:44px;height:44px;flex-shrink:0;border:none;border-radius:50%;background:var(--orange);color:#fff;cursor:pointer;transition:background var(--speed)}
.kw-msearch__submit:hover{background:var(--orange-dark)}
.kw-msearch__submit svg{width:18px;height:18px}

/* ════════════════════════════════════════════════════════════════
   ZOEKRESULTATEN-DROPDOWN (gedeeld desktop/mobiel)
   ════════════════════════════════════════════════════════════════ */
.kw-search__results{position:absolute;top:calc(100% + 10px);left:0;right:0;z-index:120;max-height:70vh;overflow-y:auto;overscroll-behavior:contain;padding:8px;background:#fff;border:1.5px solid var(--line-strong);border-radius:18px;box-shadow:0 8px 28px rgba(96,58,21,.16)}
.kw-sr__list{list-style:none;margin:0;padding:0}
.kw-sr__item{display:flex;align-items:center;gap:12px;padding:9px 10px;border-radius:12px;text-decoration:none;transition:background 130ms}
.kw-sr__item:hover,.kw-sr__item.is-active{background:var(--cream)}
.kw-sr__thumb{display:flex;align-items:center;justify-content:center;width:48px;height:48px;flex-shrink:0;overflow:hidden;border-radius:10px;background:var(--cream)}
.kw-sr__thumb img{width:100%;height:100%;object-fit:cover}
.kw-sr__thumb--empty{background:var(--line)}
.kw-sr__info{display:flex;flex-direction:column;gap:2px;min-width:0}
.kw-sr__title{font-family:var(--font-body);font-size:.92rem;font-weight:700;color:var(--ink);line-height:1.25;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.kw-sr__price{font-family:var(--font-body);font-size:.85rem;font-weight:600;color:var(--green)}
.kw-sr__all{display:block;margin-top:6px;padding:11px;border-radius:12px;background:var(--green);color:#fff;font-family:var(--font-head);font-size:.9rem;text-align:center;text-decoration:none;transition:background 150ms}
.kw-sr__all:hover,.kw-sr__all.is-active{background:var(--green-dark)}
.kw-sr__empty{margin:0;padding:20px 12px;color:var(--soft);font-family:var(--font-body);font-size:.92rem;text-align:center}

/* ════════════════════════════════════════════════════════════════
   RIJ 3 · SNELKOPPELINGEN MOBIEL
   ════════════════════════════════════════════════════════════════ */
.kw-shortcuts{background:#fff;border-top:1px solid var(--line);padding:10px 0}
.kw-shortcuts__list{display:flex;gap:4px;list-style:none;margin:0;padding:0 12px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.kw-shortcuts__list::-webkit-scrollbar{display:none}
.kw-shortcuts__list li{flex:1 0 auto;min-width:72px}
.kw-shortcut{display:flex;flex-direction:column;align-items:center;gap:6px;padding:4px 6px;text-decoration:none}
.kw-shortcut__icon{display:flex;align-items:center;justify-content:center;width:54px;height:54px;border-radius:50%;transition:transform 200ms cubic-bezier(.34,1.56,.64,1)}
.kw-shortcut:active .kw-shortcut__icon{transform:scale(.92)}
.kw-shortcut__icon svg{width:26px;height:26px}
.kw-shortcut__label{font-family:var(--font-body);font-size:.72rem;font-weight:700;color:var(--ink);text-align:center;white-space:nowrap}

/* ════════════════════════════════════════════════════════════════
   RIJ 4 · CHIPS + TRUST (desktop)
   ════════════════════════════════════════════════════════════════ */
.kw-nav{display:none;background:#fff}
.kw-nav__bar{display:flex;align-items:center;gap:12px;padding-block:10px}

.kw-chips{display:flex;align-items:center;gap:8px;list-style:none;margin:0;padding:0;min-width:0}
.kw-chips li{position:relative}
.kw-chip{display:inline-flex;align-items:center;gap:7px;height:40px;padding:0 14px;border-radius:999px;background:#fff;border:1.5px solid var(--line);font-family:var(--font-body);font-size:.95rem;font-weight:800;color:var(--ink);text-decoration:none;white-space:nowrap;transition:background var(--speed),border-color var(--speed)}
.kw-chip:hover{background:var(--cream-soft);border-color:var(--line-strong)}
.kw-chip.is-active{border-color:var(--green);background:var(--green-soft)}
.kw-chip__icon{display:flex;flex-shrink:0}
.kw-chip__icon svg{width:18px;height:18px}
.kw-chip__chevron{display:flex;color:var(--soft)}
.kw-chip__chevron svg{width:13px;height:13px}

/* Dropdown (fallback-menu met submenu's) */
.kw-dropdown{position:absolute;top:calc(100% + 8px);left:0;z-index:110;min-width:200px;list-style:none;margin:0;padding:8px;background:#fff;border:1.5px solid var(--line);border-radius:14px;box-shadow:0 8px 24px rgba(96,58,21,.14);opacity:0;visibility:hidden;transform:translateY(-4px);transition:opacity var(--speed),transform var(--speed),visibility var(--speed)}
.kw-chips li.has-sub:hover .kw-dropdown,.kw-chips li.has-sub:focus-within .kw-dropdown{opacity:1;visibility:visible;transform:translateY(0)}
.kw-dropdown__link{display:block;padding:9px 12px;border-radius:9px;font-family:var(--font-body);font-size:.92rem;font-weight:700;color:var(--body);text-decoration:none;transition:background 130ms,color 130ms}
.kw-dropdown__link:hover,.kw-dropdown__link.is-active{background:var(--cream);color:var(--ink)}

.kw-trust{display:flex;align-items:center;list-style:none;margin:0 0 0 auto;padding:0;flex-shrink:0}
.kw-trust__item{display:flex;align-items:center;gap:8px;padding:0 13px;border-left:1px solid var(--line)}
.kw-trust__item:last-child{padding-right:0}
.kw-trust__icon{display:flex;flex-shrink:0;color:var(--green)}
.kw-trust__icon svg{width:22px;height:22px}
.kw-trust__text{display:flex;flex-direction:column;line-height:1.25}
.kw-trust__text strong{font-family:var(--font-body);font-size:.85rem;font-weight:800;color:var(--ink);white-space:nowrap}
.kw-trust__text span{font-family:var(--font-body);font-size:.73rem;color:var(--soft);white-space:nowrap}

/* ════════════════════════════════════════════════════════════════
   DESKTOP-OVERRIDES (≥768px)
   ════════════════════════════════════════════════════════════════ */
@media(min-width:768px){
  .kw-main{display:flex;gap:24px;padding-block:14px}
  .kw-burger{display:none}
  .kw-logo{justify-content:flex-start}
  .kw-logo__text{font-size:2rem}
  .kw-logo__paw svg{width:18px;height:18px}
  .kw-search{display:block}
  .kw-actions{margin-left:auto;gap:8px}
  .kw-textbtn{display:flex}
  .kw-cart{width:auto;height:48px;padding:0 22px;border-radius:999px;background:var(--green);color:#fff;transition:background var(--speed),transform 200ms cubic-bezier(.34,1.56,.64,1)}
  .kw-cart:hover{background:var(--green-dark);transform:translateY(-2px)}
  .kw-cart svg{width:20px;height:20px}
  .kw-cart__label{display:inline}
  .kw-cart__badge{top:-6px;right:-6px;border-color:#fff}
  .kw-msearch{display:none}
  .kw-shortcuts{display:none}
  .kw-nav{display:block}
}

/* Tussenmaat: trust-subtekst weg zodat alles past */
@media(min-width:768px) and (max-width:1180px){
  .kw-trust__item{padding:0 14px}
  .kw-trust__text span{display:none}
  .kw-chip{padding:0 13px;font-size:.9rem}
}

@media(prefers-reduced-motion:reduce){
  .kw-header,.kw-cart,.kw-chip,.kw-dropdown,.kw-drawer__panel,.kw-shortcut__icon{transition:none;animation:none}
}

/* ════════════════════════════════════════════════════════════════
   DRAWER
   ════════════════════════════════════════════════════════════════ */
.kw-drawer{position:fixed;inset:0;z-index:200;width:100%;height:100%;max-width:100%;max-height:100%;padding:0;border:none;background:transparent;touch-action:none}
.kw-drawer::backdrop{background:rgba(61,34,9,.5)}
.kw-drawer:not([open]){display:none}
.kw-drawer[open]{display:flex;justify-content:flex-start}
.kw-drawer__panel{display:flex;flex-direction:column;width:340px;max-width:90vw;height:100%;background:#FCF6EC;overscroll-behavior:contain;animation:kw-panel-in 300ms ease forwards}
@keyframes kw-panel-in{from{transform:translateX(-100%)}to{transform:translateX(0)}}
.kw-drawer__scroll{flex:1;display:flex;flex-direction:column;padding:8px 16px 20px;overflow-y:auto;overscroll-behavior:contain;-webkit-overflow-scrolling:touch}

.kw-drawer__head{display:flex;align-items:center;gap:14px;padding:14px 16px 10px;flex-shrink:0}
.kw-drawer__close{background:transparent;flex-shrink:0}
.kw-drawer__close:hover{background:#EDE2C9}
.kw-drawer__brand{display:flex;align-items:center;gap:10px;min-width:0;text-decoration:none}
.kw-drawer__brand-paw{display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#3d2209}
.kw-drawer__brand-paw svg{width:34px;height:34px}
.kw-drawer__brand-text{display:flex;flex-direction:column;gap:2px;min-width:0}
.kw-drawer__brand-name{font-family:'Lilita One',cursive;font-size:1.6rem;color:#3d2209;line-height:1}
.kw-drawer__brand-tag{display:flex;align-items:center;gap:5px;font-family:'Karla',sans-serif;font-size:.85rem;font-weight:700;color:#66AA44;line-height:1}
.kw-drawer__brand-heart{display:flex;color:#FFB8CD}
.kw-drawer__brand-heart svg{width:14px;height:14px}

.kw-drawer__nav ul{list-style:none;margin:0;padding:0}
.kw-drawer__row{display:flex;align-items:center;gap:14px;padding:14px 8px;border-bottom:1px solid #EDE2C9;text-decoration:none;transition:background 140ms}
.kw-drawer__nav li:last-child .kw-drawer__row{border-bottom:none}
.kw-drawer__row:hover,.kw-drawer__row.is-active{background:#fff}
.kw-drawer__row-icon{display:flex;align-items:center;justify-content:center;width:38px;height:38px;flex-shrink:0;border-radius:11px}
.kw-drawer__row-icon svg{width:26px;height:26px}
.kw-drawer__row-label{flex:1;font-family:'Lilita One',cursive;font-size:1.15rem;color:#3d2209;line-height:1.1}
.kw-drawer__row-badge{flex-shrink:0;padding:3px 10px;border-radius:999px;background:#F7A048;color:#fff;font-family:'Karla',sans-serif;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.02em}
.kw-drawer__row-chevron{display:flex;flex-shrink:0;color:#A88259;transform:rotate(-90deg)}
.kw-drawer__row-chevron svg{width:18px;height:18px}

.kw-drawer__club{display:flex;align-items:center;gap:14px;margin-top:16px;padding:16px;border-radius:18px;background:#e8f5e2;text-decoration:none;transition:background 160ms}
.kw-drawer__club:hover{background:#daefcf}
.kw-drawer__club-icon{display:flex;align-items:center;justify-content:center;width:44px;height:44px;flex-shrink:0;border-radius:50%;background:#fff;color:#66AA44}
.kw-drawer__club-icon svg{width:22px;height:22px}
.kw-drawer__club-text{flex:1;display:flex;flex-direction:column;gap:2px;min-width:0}
.kw-drawer__club-title{font-family:'Lilita One',cursive;font-size:1.05rem;color:#3d2209;line-height:1.1}
.kw-drawer__club-body{font-family:'Karla',sans-serif;font-size:.82rem;font-weight:600;color:#4d8833;line-height:1.25}
.kw-drawer__club-arrow{display:flex;align-items:center;justify-content:center;width:38px;height:38px;flex-shrink:0;border-radius:50%;background:#66AA44;color:#fff;transform:rotate(-90deg)}
.kw-drawer__club-arrow svg{width:18px;height:18px}

.kw-drawer__links{display:flex;flex-direction:column;gap:2px;list-style:none;margin:18px 0 0;padding:0}
.kw-drawer__minilink{display:flex;align-items:center;gap:14px;padding:11px 8px;border-radius:12px;font-family:'Karla',sans-serif;font-size:1rem;font-weight:700;color:#3d2209;text-decoration:none;transition:background 140ms,color 140ms}
.kw-drawer__minilink:hover{background:#fff;color:#d9823a}
.kw-drawer__minilink span{display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#3d2209}
.kw-drawer__minilink:hover span{color:#d9823a}
.kw-drawer__minilink svg{width:22px;height:22px}

.kw-drawer__cta{position:relative;display:flex;align-items:flex-end;justify-content:space-between;gap:8px;margin-top:18px;min-height:130px;padding:18px;border-radius:22px;background:#4d7a30;overflow:hidden;text-decoration:none}
.kw-drawer__cta-body{position:relative;z-index:1;display:flex;flex-direction:column;align-items:flex-start;gap:10px;max-width:60%}
.kw-drawer__cta-heart{display:flex;color:#fff}
.kw-drawer__cta-heart svg{width:20px;height:20px}
.kw-drawer__cta-title{font-family:'Lilita One',cursive;font-size:1.25rem;color:#fff;line-height:1.1}
.kw-drawer__cta-btn{display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:999px;background:#fff;color:#3d2209;font-family:'Lilita One',cursive;font-size:.85rem}
.kw-drawer__cta-btn-arrow{display:flex;transform:rotate(-90deg)}
.kw-drawer__cta-btn-arrow svg{width:14px;height:14px}
.kw-drawer__cta-img{position:absolute;right:-6px;bottom:0;z-index:0;display:flex;align-items:flex-end;width:48%;max-width:170px}
.kw-drawer__cta-img img{width:100%;height:auto;object-fit:contain}
{% endstylesheet %}

{% javascript %}
(function () {
  'use strict';

  /* ── Sticky-schaduw ─────────────────────────────────────────── */
  var header = document.getElementById('KwHeader');
  if (header) {
    window.addEventListener('scroll', function () {
      header.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });
  }

  /* ── Drawer ─────────────────────────────────────────────────── */
  var drawer   = document.getElementById('KwDrawer');
  var burger   = document.querySelector('.kw-burger');
  var closeBtn = document.querySelector('.kw-drawer__close');

  function setExpanded(state) {
    if (burger) burger.setAttribute('aria-expanded', state ? 'true' : 'false');
    document.body.style.overflow = state ? 'hidden' : '';
  }
  function openDrawer()  { if (drawer) { drawer.showModal(); setExpanded(true); } }
  function closeDrawer() { if (drawer) { drawer.close();     setExpanded(false); } }

  if (burger)   burger.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (drawer) {
    drawer.addEventListener('click',  function (e) { if (e.target === drawer) closeDrawer(); });
    drawer.addEventListener('cancel', function () { setExpanded(false); });
  }

  /* ── Predictive search ──────────────────────────────────────── */
  var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';

  function money(cents) {
    try {
      return new Intl.NumberFormat('nl-NL', { style: 'currency', currency: 'EUR' }).format(cents / 100);
    } catch (e) {
      return '\u20ac' + (cents / 100).toFixed(2).replace('.', ',');
    }
  }

  function initSearch(form) {
    var input   = form.querySelector('[data-kw-search-input]');
    var results = form.querySelector('[data-kw-search-results]');
    var clear   = form.querySelector('[data-kw-search-clear]');
    if (!input || !results) return;

    var controller = null;
    var timer      = null;
    var active     = -1;

    function hide() {
      results.hidden = true;
      results.innerHTML = '';
      input.setAttribute('aria-expanded', 'false');
      active = -1;
    }

    function toggleClear() {
      if (clear) clear.hidden = input.value.length === 0;
    }

    function render(data, term) {
      var products = (data.resources && data.resources.results && data.resources.results.products) || [];
      var html = '';

      if (products.length) {
        html += '<ul class="kw-sr__list" role="presentation">';
        products.slice(0, 6).forEach(function (p) {
          var img   = p.featured_image && p.featured_image.url ? p.featured_image.url : (p.image || '');
          var price = (p.price !== undefined) ? money(p.price) : '';
          html += '<li role="option"><a class="kw-sr__item" href="' + p.url + '">' +
            (img
              ? '<span class="kw-sr__thumb"><img src="' + img + '&width=80" alt="" width="48" height="48" loading="lazy"></span>'
              : '<span class="kw-sr__thumb kw-sr__thumb--empty"></span>') +
            '<span class="kw-sr__info"><span class="kw-sr__title">' + p.title + '</span>' +
            (price ? '<span class="kw-sr__price">' + price + '</span>' : '') +
            '</span></a></li>';
        });
        html += '</ul>';
        html += '<a class="kw-sr__all" href="' + root + 'search?q=' + encodeURIComponent(term) +
                '&type=product">Alle resultaten voor &ldquo;' + term + '&rdquo;</a>';
      } else {
        html += '<p class="kw-sr__empty">Geen resultaten voor &ldquo;' + term + '&rdquo;</p>';
      }

      results.innerHTML = html;
      results.hidden = false;
      input.setAttribute('aria-expanded', 'true');
      active = -1;
    }

    function search(term) {
      if (controller) controller.abort();
      controller = new AbortController();
      var url = root + 'search/suggest.json?q=' + encodeURIComponent(term) +
        '&resources[type]=product&resources[limit]=6' +
        '&resources[options][unavailable_products]=last' +
        '&resources[options][fields]=title,product_type,variants.title,vendor';
      fetch(url, { signal: controller.signal })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
        .then(function (data) { render(data, term); })
        .catch(function () { /* abort/netwerk: stil */ });
    }

    function setActive(items) {
      items.forEach(function (el, i) { el.classList.toggle('is-active', i === active); });
      if (items[active]) items[active].scrollIntoView({ block: 'nearest' });
    }

    input.addEventListener('input', function () {
      toggleClear();
      var term = input.value.trim();
      clearTimeout(timer);
      if (term.length < 2) { hide(); return; }
      timer = setTimeout(function () { search(term); }, 200);
    });

    input.addEventListener('keydown', function (e) {
      var items = results.querySelectorAll('.kw-sr__item, .kw-sr__all');
      if (results.hidden || !items.length) return;
      if (e.key === 'ArrowDown')      { e.preventDefault(); active = Math.min(active + 1, items.length - 1); setActive(items); }
      else if (e.key === 'ArrowUp')   { e.preventDefault(); active = Math.max(active - 1, 0); setActive(items); }
      else if (e.key === 'Enter')     { if (active >= 0 && items[active]) { e.preventDefault(); window.location.href = items[active].href; } }
      else if (e.key === 'Escape')    { hide(); input.blur(); }
    });

    input.addEventListener('focus', function () {
      if (input.value.trim().length >= 2 && results.innerHTML) results.hidden = false;
    });

    if (clear) clear.addEventListener('click', function () {
      input.value = ''; toggleClear(); hide(); input.focus();
    });

    document.addEventListener('click', function (e) {
      if (!form.contains(e.target)) hide();
    });

    toggleClear();
  }

  document.querySelectorAll('[data-kw-search]').forEach(initSearch);
})();
{% endjavascript %}

