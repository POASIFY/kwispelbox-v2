<section class="rv">

  <!-- ── HEADER ──────────────────────────────────────────── -->
  <div class="rv__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="rv__eyebrow">
        {{- 'icon-heart.svg' | inline_asset_content -}}
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}
    <h2 class="rv__title">{{ section.settings.title }}</h2>
    {%- if section.settings.subtitle_plain != blank -%}
      <p class="rv__sub">
        {{ section.settings.subtitle_plain }}
        {%- if section.settings.subtitle_accent != blank -%}
          <span class="rv__sub-accent">{{ section.settings.subtitle_accent }}</span>
        {%- endif -%}
        {{ section.settings.subtitle_tail }}
      </p>
    {%- endif -%}
  </div>

  <!-- ── REVIEW KAARTEN ──────────────────────────────────── -->
  {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
  {%- if review_blocks.size > 0 -%}
    <div class="rv__grid">
      {%- for block in review_blocks -%}
        <article class="rcard" {{ block.shopify_attributes }}>

          <!-- Kaart top: avatar + info + sterren -->
          <div class="rcard__top">

            <!-- Circulaire avatar -->
            <div class="rcard__avatar-wrap">
              {%- if block.settings.avatar != blank -%}
                <img
                  src="{{ block.settings.avatar | image_url: width: 220 }}"
                  srcset="{{ block.settings.avatar | image_url: width: 110 }} 110w,
                          {{ block.settings.avatar | image_url: width: 220 }} 220w"
                  sizes="110px"
                  alt="{{ block.settings.dog_name | default: 'Blije hond' | escape }}"
                  width="110" height="110"
                  loading="lazy"
                  class="rcard__avatar"
                >
              {%- else -%}
                <div class="rcard__avatar-ph">
                  {{- 'icon-paw.svg' | inline_asset_content -}}
                </div>
              {%- endif -%}
            </div>

            <!-- Naam · ras · box · sterren -->
            <div class="rcard__info">
              <strong class="rcard__dog-name">{{ block.settings.dog_name }}</strong>
              {%- if block.settings.breed != blank -%}
                <span class="rcard__breed">{{ block.settings.breed }}</span>
              {%- endif -%}
              {%- if block.settings.box_type != blank -%}
                <span class="rcard__box rcard__box--{{ block.settings.box_color }}">
                  {{ block.settings.box_type }}
                </span>
              {%- endif -%}
              <div class="rcard__stars" aria-label="{{ block.settings.stars }} sterren">
                {%- for i in (1..block.settings.stars) -%}
                  {{- 'icon-star.svg' | inline_asset_content -}}
                {%- endfor -%}
                <span class="rcard__score">{{ block.settings.stars }}/5</span>
              </div>
            </div>

          </div>

          <!-- Quote + review body -->
          <div class="rcard__body">
            <span class="rcard__open-quote" aria-hidden="true">&ldquo;</span>
            {%- if block.settings.review_title != blank -%}
              <h3 class="rcard__review-title">{{ block.settings.review_title }}</h3>
            {%- endif -%}
            <p class="rcard__text">{{ block.settings.review_text }}</p>

            <!-- Geverifieerde aankoop -->
            {%- if block.settings.verified -%}
              <div class="rcard__verified">
                {{- 'icon-check-circle.svg' | inline_asset_content -}}
                Geverifieerde aankoop
              </div>
            {%- endif -%}

            <!-- Decoratief sluitend aanhalingsteken -->
            <span class="rcard__close-quote" aria-hidden="true">&rdquo;</span>
          </div>

        </article>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- ── TRUST STRIP ────────────────────────────────────── -->
  {%- assign trust_blocks = section.blocks | where: 'type', 'trust' -%}
  {%- if trust_blocks.size > 0 -%}
    <div class="rv__trust">
      <div class="rv__trust-inner">
        {%- for block in trust_blocks -%}
          <div class="rv__trust-item" {{ block.shopify_attributes }}>
            <span class="rv__trust-icon rv__trust-icon--{{ block.settings.color }}" aria-hidden="true">
              {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
            </span>
            <div class="rv__trust-text">
              <strong>{{ block.settings.title }}</strong>
              {%- if block.settings.subtitle != blank -%}
                <span>{{ block.settings.subtitle }}</span>
              {%- endif -%}
              {%- if block.settings.stars_line != blank -%}
                <span class="rv__trust-stars" aria-hidden="true">
                  {%- for i in (1..5) -%}{{- 'icon-star.svg' | inline_asset_content -}}{%- endfor -%}
                  {{ block.settings.stars_line }}
                </span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</section>

{% stylesheet %}
/* ════════════════════════════════════════════════════════
   REVIEWS SECTIE
   ════════════════════════════════════════════════════════ */
.rv {
  background: #FBF6EC;
  padding: 80px 0 0;
  overflow: hidden;
}

/* ── Header ─────────────────────────────────────────────── */
.rv__header {
  text-align: center;
  padding: 0 20px;
  margin-bottom: 52px;
  display: flex; flex-direction: column;
  align-items: center; gap: 12px;
}
.rv__eyebrow {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: 'Karla', sans-serif;
  font-size: .78rem; font-weight: 800;
  letter-spacing: .1em; text-transform: uppercase;
  color: #e75480;
}
.rv__eyebrow svg { width: 13px; height: 13px; }
.rv__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  color: #3d2209;
  line-height: 1.05;
}
.rv__sub {
  font-family: 'Karla', sans-serif;
  font-size: 1rem; color: #A88259;
  max-width: 560px; line-height: 1.55;
  text-align: center;
}
.rv__sub-accent {
  color: #F7A048; font-weight: 800;
}

/* ── Grid ────────────────────────────────────────────────── */
.rv__grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 0 20px;
  max-width: 1280px;
  margin: 0 auto;
}
@media(min-width: 768px) {
  .rv__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    padding: 0 60px;
    align-items: stretch;
  }
}

/* ── Kaart ────────────────────────────────────────────────── */
.rcard {
  background: #fff;
  border-radius: 24px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  box-shadow: 0 4px 20px rgba(96,58,21,.07);
  position: relative;
  overflow: hidden;
}

/* ── Kaart top: avatar + info ──────────────────────────── */
.rcard__top {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

/* Circulaire avatar */
.rcard__avatar-wrap { flex-shrink: 0; }
.rcard__avatar {
  width: 110px; height: 110px;
  border-radius: 50%;
  object-fit: cover;
  display: block;
  border: 3px solid #F8EFDD;
  box-shadow: 0 4px 12px rgba(96,58,21,.12);
}
.rcard__avatar-ph {
  width: 110px; height: 110px;
  border-radius: 50%;
  background: #F8EFDD;
  display: flex; align-items: center; justify-content: center;
  color: #DAC9A1;
}
.rcard__avatar-ph svg { width: 40px; height: 40px; }

/* Info rechts van avatar */
.rcard__info {
  display: flex; flex-direction: column;
  gap: 5px; min-width: 0;
  padding-top: 4px;
}
.rcard__dog-name {
  font-family: 'Lilita One', cursive;
  font-size: 1.35rem; color: #3d2209;
  line-height: 1;
}
.rcard__breed {
  font-family: 'Karla', sans-serif;
  font-size: .85rem; color: #A88259;
}
.rcard__box {
  display: inline-flex; align-items: center;
  font-family: 'Karla', sans-serif;
  font-size: .78rem; font-weight: 800;
  padding: 4px 12px;
  border-radius: 999px;
  width: fit-content;
}
.rcard__box--orange { background: #FFF0E4; color: #d9823a; }
.rcard__box--green  { background: #E8F5E2; color: #2d7a1a; }
.rcard__box--pink   { background: #FFF0F5; color: #c0394b; }

.rcard__stars {
  display: flex; align-items: center; gap: 3px;
  margin-top: 2px;
}
.rcard__stars svg {
  width: 16px; height: 16px;
  color: #F7A048; fill: #F7A048;
}
.rcard__score {
  font-family: 'Karla', sans-serif;
  font-size: .82rem; font-weight: 800;
  color: #A88259; margin-left: 4px;
}

/* ── Review body ──────────────────────────────────────── */
.rcard__body {
  display: flex; flex-direction: column;
  gap: 10px; flex: 1;
  position: relative;
}

/* Opening aanhalingsteken */
.rcard__open-quote {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 3.8rem; line-height: .8;
  color: #e75480; font-weight: 700;
  display: block;
  margin-bottom: -4px;
}

.rcard__review-title {
  font-family: 'Lilita One', cursive;
  font-size: 1.05rem;
  color: #e75480;
  line-height: 1.25;
  margin: 0;
}
.rcard__text {
  font-family: 'Karla', sans-serif;
  font-size: .9rem; color: #603A15;
  line-height: 1.6; margin: 0;
}

/* Geverifieerde aankoop */
.rcard__verified {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: 'Karla', sans-serif;
  font-size: .8rem; font-weight: 700;
  color: #66AA44; margin-top: 4px;
}
.rcard__verified svg { width: 15px; height: 15px; color: #66AA44; }

/* Decoratief sluitend aanhalingsteken (rechtsonder) */
.rcard__close-quote {
  position: absolute;
  bottom: -12px; right: 4px;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 7rem; line-height: 1;
  color: rgba(231,84,128,.08);
  font-weight: 700;
  pointer-events: none;
  user-select: none;
}

/* ── Trust strip ─────────────────────────────────────── */
.rv__trust {
  background: #F8EFDD;
  border-top: 1.5px solid #EDE2C9;
  margin-top: 60px;
}
.rv__trust-inner {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  max-width: 1280px; margin: 0 auto;
  padding: 0;
}
@media(min-width: 768px) {
  .rv__trust-inner { grid-template-columns: repeat(4, 1fr); }
}
.rv__trust-item {
  display: flex; align-items: center; gap: 14px;
  padding: 22px 20px;
  border-right: 1px solid #EDE2C9;
}
.rv__trust-item:last-child { border-right: none; }
@media(max-width:767px) {
  .rv__trust-item:nth-child(2n) { border-right: none; }
  .rv__trust-item:nth-child(n+3) { border-top: 1px solid #EDE2C9; }
}
.rv__trust-icon {
  width: 48px; height: 48px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.rv__trust-icon svg { width: 22px; height: 22px; }
.rv__trust-icon--green  { background: #e8f5e2; color: #66AA44; }
.rv__trust-icon--pink   { background: #fff0f5; color: #e75480; }
.rv__trust-icon--orange { background: #fff0e4; color: #F7A048; }
.rv__trust-icon--yellow { background: #fffae0; color: #c49000; }
.rv__trust-text {
  display: flex; flex-direction: column; gap: 2px;
}
.rv__trust-text strong {
  font-family: 'Lilita One', cursive;
  font-size: 1rem; color: #3d2209; line-height: 1.1;
}
.rv__trust-text span {
  font-family: 'Karla', sans-serif;
  font-size: .8rem; color: #A88259; line-height: 1.35;
}
.rv__trust-stars {
  display: flex; align-items: center; gap: 3px; margin-top: 3px;
}
.rv__trust-stars svg { width: 13px; height: 13px; color: #F7A048; fill: #F7A048; }
{% endstylesheet %}

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {"type":"image_picker","id":"avatar",        "label":"Hondenfoto (rond)"},
        {"type":"text",        "id":"dog_name",      "label":"Naam hond",          "default":"Luna"},
        {"type":"text",        "id":"breed",         "label":"Ras",                "default":"Golden Retriever"},
        {"type":"text",        "id":"box_type",      "label":"Box type",           "default":"Happy Box"},
        {
          "type":"select","id":"box_color","label":"Box kleur","default":"orange",
          "options":[
            {"value":"orange","label":"Oranje"},
            {"value":"green","label":"Groen"},
            {"value":"pink","label":"Roze"}
          ]
        },
        {
          "type":"range","id":"stars","label":"Sterren","min":1,"max":5,"step":1,"default":5
        },
        {"type":"text",    "id":"review_title","label":"Review titel",   "default":"Elke maand weer een feestje!"},
        {"type":"textarea","id":"review_text", "label":"Review tekst",   "default":"Luna wordt altijd zó enthousiast als de Kwispelbox binnenkomt. De speeltjes zijn stevig en superleuk!"},
        {"type":"checkbox","id":"verified",    "label":"Geverifieerde aankoop","default":true}
      ]
    },
    {
      "type": "trust",
      "name": "Trust item",
      "settings": [
        {
          "type":"select","id":"icon","label":"Icoon","default":"paw",
          "options":[
            {"value":"paw","label":"Poot"},{"value":"heart","label":"Hart"},
            {"value":"shield","label":"Schild"},{"value":"gift","label":"Cadeau"},
            {"value":"star","label":"Ster"},{"value":"truck","label":"Vrachtwagen"},
            {"value":"account","label":"Personen"}
          ]
        },
        {
          "type":"select","id":"color","label":"Kleur","default":"green",
          "options":[
            {"value":"green","label":"Groen"},{"value":"pink","label":"Roze"},
            {"value":"orange","label":"Oranje"},{"value":"yellow","label":"Geel"}
          ]
        },
        {"type":"text","id":"title",      "label":"Titel",      "default":"1.200+"},
        {"type":"text","id":"subtitle",   "label":"Subtitel",   "default":"Blije honden in onze community"},
        {"type":"text","id":"stars_line", "label":"Sterren label (bijv. op basis van 500+ reviews)"}
      ]
    }
  ],
  "settings": [
    {"type":"text",    "id":"eyebrow",          "label":"Eyebrow",           "default":"Geliefd door honden én hun baasjes"},
    {"type":"textarea","id":"title",            "label":"Titel",             "default":"Wat onze klanten zeggen"},
    {"type":"text",    "id":"subtitle_plain",   "label":"Subtitel begin",    "default":"Duizenden honden genieten al elke maand van hun "},
    {"type":"text",    "id":"subtitle_accent",  "label":"Subtitel accent",   "default":"Kwispelbox."},
    {"type":"text",    "id":"subtitle_tail",    "label":"Subtitel vervolg",  "default":" Lees wat hun baasjes hiervan vinden."}
  ],
  "presets": [{"name":"Reviews"}]
}
{% endschema %}
