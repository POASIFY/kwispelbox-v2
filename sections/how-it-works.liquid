<section class="hiw">

  <!-- Header ───────────────────────────────────────────── -->
  <div class="hiw__header">
    <h2 class="hiw__title">{{ section.settings.title }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="hiw__sub">
        {{- section.settings.subtitle_prefix -}}
        <span class="hiw__sub-accent">{{- section.settings.subtitle_accent -}}</span>
      </p>
    {%- endif -%}
  </div>

  <!-- Stappen ──────────────────────────────────────────── -->
  <div class="hiw__steps-wrap">
    <div class="hiw__steps">

      {%- assign step_blocks = section.blocks | where: 'type', 'step' -%}
      {%- for block in step_blocks -%}
        <div class="hiw__step hiw__step--{{ block.settings.color }}"
             {{ block.shopify_attributes }}>

          <!-- Nummer + verbindingslijn -->
          <div class="hiw__step-top">
            {%- unless forloop.first -%}
              <div class="hiw__connector" aria-hidden="true">
                <span class="hiw__connector-paw">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
              </div>
            {%- endunless -%}
            <div class="hiw__num hiw__num--{{ block.settings.color }}">
              {{ forloop.index }}
            </div>
          </div>

          <!-- Cirkelafbeelding -->
          <div class="hiw__img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                srcset="{{ block.settings.image | image_url: width: 300 }} 300w,
                        {{ block.settings.image | image_url: width: 400 }} 400w"
                sizes="(max-width: 767px) 70vw, 22vw"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                width="400" height="400"
                loading="lazy"
                class="hiw__img"
              >
            {%- else -%}
              <div class="hiw__img-ph">
                {{- 'icon-paw.svg' | inline_asset_content -}}
              </div>
            {%- endif -%}
          </div>

          <!-- Icoontje onder afbeelding -->
          <div class="hiw__icon hiw__icon--{{ block.settings.color }}" aria-hidden="true">
            {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
          </div>
          <!-- Tekst -->
          <div class="hiw__text">
            <h3 class="hiw__step-title hiw__step-title--{{ block.settings.color }}">
              {{ block.settings.title }}
            </h3>
            <p class="hiw__step-desc">{{ block.settings.description }}</p>
          </div>

        </div>
      {%- endfor -%}

    </div>
  </div>

  <!-- Trust strip ──────────────────────────────────────── -->
  {%- assign trust_blocks = section.blocks | where: 'type', 'trust' -%}
  {%- if trust_blocks.size > 0 -%}
    <div class="hiw__trust">
      <div class="hiw__trust-inner">

        {%- if section.settings.trust_img_left != blank -%}
          <div class="hiw__trust-avatar" aria-hidden="true">
            <img src="{{ section.settings.trust_img_left | image_url: width: 120 }}"
                 alt="" width="80" height="80" loading="lazy">
          </div>
        {%- endif -%}

        <div class="hiw__trust-items">
          {%- for block in trust_blocks -%}
            <div class="hiw__trust-item" {{ block.shopify_attributes }}>
              <span class="hiw__trust-icon hiw__trust-icon--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <div class="hiw__trust-text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}
                  <span>{{ block.settings.subtitle }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.trust_img_right != blank -%}
          <div class="hiw__trust-avatar" aria-hidden="true">
            <img src="{{ section.settings.trust_img_right | image_url: width: 120 }}"
                 alt="" width="80" height="80" loading="lazy">
          </div>
        {%- endif -%}

      </div>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
/* ── Sectie ─────────────────────────────────────────────── */
.hiw {
  background: #F8EFDD;
  padding: 80px 0 0;
  overflow: hidden;
}

/* ── Header ─────────────────────────────────────────────── */
.hiw__header {
  text-align: center;
  padding: 0 20px;
  margin-bottom: 56px;
}
.hiw__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  color: #3d2209;
  line-height: 1.05;
  margin-bottom: 12px;
}
.hiw__sub {
  font-family: 'Karla', sans-serif;
  font-size: 1.1rem;
  color: #A88259;
}
.hiw__sub-accent {
  color: #F7A048;
  font-weight: 800;
}

/* ── Stappen wrapper ────────────────────────────────────── */
.hiw__steps-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 0 20px 40px;
}
.hiw__steps-wrap::-webkit-scrollbar { display: none; }

.hiw__steps {
  display: flex;
  gap: 0;
  min-width: max-content;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
  align-items: flex-start;
  position: relative;
}

@media(min-width: 900px) {
  .hiw__steps-wrap { overflow-x: visible; padding: 0 0 40px; }
  .hiw__steps { min-width: unset; }
}


/* ── Verbindingslijn tussen stappen ────────────────────── */
.hiw__step-top {
  position: relative;
}
.hiw__connector {
  position: absolute;
  left: -50%;
  width: 100%;
  top: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
  pointer-events: none;
}
.hiw__connector::before {
  content: '';
  position: absolute;
  left: 0; right: 0; top: 50%;
  transform: translateY(-50%);
  border-top: 2px dashed #DAC9A1;
  z-index: 0;
}
.hiw__connector-paw {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px; height: 24px;
  background: #F8EFDD;
  border-radius: 50%;
  position: relative;
  z-index: 1;
  color: #DAC9A1;
}
.hiw__connector-paw svg { width: 14px; height: 14px; }

/* ── Stap ───────────────────────────────────────────────── */
.hiw__step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  flex: 1;
  min-width: 200px;
  position: relative;
}

/* ── Bovenste rij: connector + nummer ───────────────────── */
.hiw__step-top {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 20px;
  position: relative;
}

/* Verbindingslijn links van nummer */
/* connector verwijderd */
/* Cirkels zijn altijd rond (border-radius via hiw__img-wrap) */

/* Genummerde cirkel */
.hiw__num {
  width: 52px; height: 52px;
  border-radius: 50%;
  position: relative; z-index: 2;
  position: relative; z-index: 2;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Lilita One', cursive;
  font-size: 1.4rem;
  color: #fff;
  z-index: 1;
  flex-shrink: 0;
  box-shadow: 0 4px 14px rgba(0,0,0,.12);
}
.hiw__num--green  { background: #66AA44; }
.hiw__num--orange { background: #F7A048; }
.hiw__num--pink   { background: #FFB8CD; color: #603A15; }
.hiw__num--yellow { background: #FFE071; color: #603A15; }

/* ── Cirkelafbeelding ───────────────────────────────────── */
.hiw__img-wrap {
  width: 200px; height: 200px;
  border-radius: 50%;
  overflow: hidden;
  border: 4px solid #fff;
  box-shadow: 0 8px 32px rgba(96,58,21,.14);
  flex-shrink: 0;
  background: #EDE2C9;
  transition: border-radius 600ms cubic-bezier(.68,-0.55,.27,1.55), box-shadow 300ms ease;
}
@media(min-width: 900px) {
  .hiw__img-wrap { width: 220px; height: 220px; }
}
.hiw__img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 400ms ease;
}
.hiw__step:hover .hiw__img { transform: scale(1.06); }
.hiw__img-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  color: #DAC9A1;
}
.hiw__img-ph svg { width: 48px; height: 48px; }

/* ── Icoon onder afbeelding ─────────────────────────────── */
.hiw__icon {
  width: 44px; height: 44px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-top: -22px;
  border: 3px solid #F8EFDD;
  z-index: 2;
  position: relative;
  flex-shrink: 0;
}
.hiw__icon svg { width: 20px; height: 20px; }
.hiw__icon--green  { background: #66AA44; color: #fff; }
.hiw__icon--orange { background: #F7A048; color: #fff; }
.hiw__icon--pink   { background: #FFB8CD; color: #603A15; }
.hiw__icon--yellow { background: #FFE071; color: #603A15; }

/* ── Tekst ──────────────────────────────────────────────── */
.hiw__text {
  padding: 20px 16px 20px;
  max-width: 220px;
  border-radius: 20px;
  margin-top: 8px;
  width: 100%;
}
/* Gekleurde achtergrond per stap */
.hiw__step--green  .hiw__text { background: #e8f5e2; }
.hiw__step--orange .hiw__text { background: #fff0e4; }
.hiw__step--pink   .hiw__text { background: #fff0f5; }
.hiw__step--yellow .hiw__text { background: #fffae0; }
.hiw__step-title {
  font-family: 'Lilita One', cursive;
  font-size: 1.2rem;
  line-height: 1.2;
  margin-bottom: 8px;
}
.hiw__step-title--green  { color: #2d7a1a; font-size: 1.3rem; }
.hiw__step-title--orange { color: #b86a1e; font-size: 1.3rem; }
.hiw__step-title--pink   { color: #c0394b; font-size: 1.3rem; }
.hiw__step-title--yellow { color: #8a6200; font-size: 1.3rem; }

.hiw__step-desc {
  font-family: 'Karla', sans-serif;
  font-size: .875rem;
  color: #A88259;
  line-height: 1.6;
}

/* ── Trust strip ────────────────────────────────────────── */
.hiw__trust {
  background: #FBF6EC;
  border-top: 1.5px solid #EDE2C9;
  margin-top: 40px;
}
.hiw__trust-inner {
  max-width: 1280px; margin: 0 auto;
  padding: 20px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
}
@media(min-width: 768px) { .hiw__trust-inner { padding: 20px 40px; } }

.hiw__trust-avatar {
  flex-shrink: 0;
}
.hiw__trust-avatar img {
  width: 80px; height: 80px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid #fff;
  box-shadow: 0 4px 12px rgba(96,58,21,.12);
  display: block;
}
@media(max-width: 767px) { .hiw__trust-avatar { display: none; } }

.hiw__trust-items {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8px 0;
  justify-content: space-around;
}
.hiw__trust-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
}
.hiw__trust-icon {
  width: 40px; height: 40px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.hiw__trust-icon svg { width: 18px; height: 18px; }
.hiw__trust-icon--green  { background: #e8f5e2; color: #66AA44; }
.hiw__trust-icon--pink   { background: #fff0f5; color: #e75480; }
.hiw__trust-icon--orange { background: #fff0e4; color: #F7A048; }

.hiw__trust-text {
  display: flex; flex-direction: column; gap: 2px;
}
.hiw__trust-text strong {
  font-family: 'Karla', sans-serif;
  font-size: .85rem; font-weight: 800; color: #603A15;
  line-height: 1.2;
}
.hiw__trust-text span {
  font-size: .75rem; color: #A88259;
}

{% endstylesheet %}

