<section class="inside">

  <!-- Header ───────────────────────────────────────────── -->
  <div class="inside__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="inside__eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}
    <h2 class="inside__title">{{ section.settings.title }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="inside__sub">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  <!-- Hoofd grid ───────────────────────────────────────── -->
  <div class="inside__wrap">

    <!-- Links ────────────────────────────────────────────── -->
    <div class="inside__col inside__col--left">
      {%- assign left_blocks = section.blocks | where: 'type', 'item' -%}
      {%- for block in left_blocks -%}
        {%- if block.settings.side == 'left' -%}
          <div class="inside__item inside__item--{{ block.settings.color }}" {{ block.shopify_attributes }}>
            <div class="inside__item-header">
              <span class="inside__item-icon inside__item-icon--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <div>
                <h3 class="inside__item-title">{{ block.settings.title }}</h3>
                <p class="inside__item-desc">{{ block.settings.description }}</p>
              </div>
            </div>
            {%- if block.settings.image != blank -%}
              <div class="inside__item-img-wrap">
                <img
                  src="{{ block.settings.image | image_url: width: 320 }}"
                  srcset="{{ block.settings.image | image_url: width: 240 }} 240w,
                          {{ block.settings.image | image_url: width: 320 }} 320w"
                  sizes="(max-width: 767px) 80vw, 22vw"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  width="320" height="200"
                  loading="lazy"
                  class="inside__item-img"
                >
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Midden: grote doos afbeelding ────────────────────── -->
    <div class="inside__center">
      <div class="inside__center-img-wrap">
        {%- if section.settings.hero_image != blank -%}
          <img
            src="{{ section.settings.hero_image | image_url: width: 800 }}"
            srcset="{{ section.settings.hero_image | image_url: width: 500 }} 500w,
                    {{ section.settings.hero_image | image_url: width: 800 }} 800w"
            sizes="(max-width: 767px) 90vw, 35vw"
            alt="{{ section.settings.hero_image.alt | default: shop.name | escape }}"
            width="800"
            height="{{ 800 | divided_by: section.settings.hero_image.aspect_ratio | round }}"
            loading="lazy"
            class="inside__center-img"
          >
        {%- else -%}
          <div class="inside__center-ph">
            {{- 'icon-box.svg' | inline_asset_content -}}
            <span>Voeg doos afbeelding toe</span>
          </div>
        {%- endif -%}

        {%- if section.settings.badge != blank -%}
          <div class="inside__center-badge" aria-label="{{ section.settings.badge }}">
            <span>{{ section.settings.badge }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Rechts ───────────────────────────────────────────── -->
    <div class="inside__col inside__col--right">
      {%- for block in left_blocks -%}
        {%- if block.settings.side == 'right' -%}
          <div class="inside__item inside__item--{{ block.settings.color }}" {{ block.shopify_attributes }}>
            <div class="inside__item-header">
              <span class="inside__item-icon inside__item-icon--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <div>
                <h3 class="inside__item-title">{{ block.settings.title }}</h3>
                <p class="inside__item-desc">{{ block.settings.description }}</p>
              </div>
            </div>
            {%- if block.settings.image != blank -%}
              <div class="inside__item-img-wrap">
                <img
                  src="{{ block.settings.image | image_url: width: 320 }}"
                  srcset="{{ block.settings.image | image_url: width: 240 }} 240w,
                          {{ block.settings.image | image_url: width: 320 }} 320w"
                  sizes="(max-width: 767px) 80vw, 22vw"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  width="320" height="200"
                  loading="lazy"
                  class="inside__item-img"
                >
              </div>
            {%- endif -%}
            {%- if block.settings.footnote != blank -%}
              <p class="inside__item-footnote">{{ block.settings.footnote }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  <!-- Trust strip ──────────────────────────────────────── -->
  {%- assign trust_blocks = section.blocks | where: 'type', 'trust' -%}
  {%- if trust_blocks.size > 0 -%}
    <div class="inside__trust">
      <div class="inside__trust-inner">
        {%- if section.settings.trust_dog_left != blank -%}
          <div class="inside__trust-dog">
            <img src="{{ section.settings.trust_dog_left | image_url: width: 160 }}"
                 alt="" width="80" height="80" loading="lazy">
          </div>
        {%- endif -%}
        <div class="inside__trust-items">
        {%- for block in trust_blocks -%}
          <div class="inside__trust-item" {{ block.shopify_attributes }}>
            <span class="inside__trust-icon inside__trust-icon--{{ block.settings.color }}" aria-hidden="true">
              {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
            </span>
            <div class="inside__trust-text">
              <strong>{{ block.settings.title }}</strong>
              {%- if block.settings.subtitle != blank -%}
                <span>{{ block.settings.subtitle }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
        </div>
        {%- if section.settings.trust_dog_right != blank -%}
          <div class="inside__trust-dog">
            <img src="{{ section.settings.trust_dog_right | image_url: width: 160 }}"
                 alt="" width="80" height="80" loading="lazy">
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</section>

{% stylesheet %}
/* ── Sectie ─────────────────────────────────────────────── */
.inside {
  background: #F8EFDD;
  padding: 80px 0 0;
  overflow: hidden;
}

/* ── Header ─────────────────────────────────────────────── */
.inside__header {
  text-align: center;
  padding: 0 20px;
  margin-bottom: 48px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
.inside__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: 'Karla', sans-serif;
  font-size: .8rem;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #e75480;
}
.inside__eyebrow svg { flex-shrink: 0; }
.inside__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(2rem, 5vw, 3.4rem);
  color: #3d2209;
  line-height: 1.05;
}
.inside__sub {
  font-family: 'Karla', sans-serif;
  font-size: 1.05rem;
  color: #A88259;
  line-height: 1.65;
  max-width: 48ch;
}

/* ── Hoofd grid ─────────────────────────────────────────── */
.inside__wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px 60px;
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  align-items: center;
}
@media(min-width: 900px) {
  .inside__wrap {
    grid-template-columns: 1fr 1.2fr 1fr;
    padding: 0 40px 60px;
    gap: 24px;
    align-items: start;
  }
}

/* ── Kolommen ───────────────────────────────────────────── */
.inside__col {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* ── Content item ───────────────────────────────────────── */
.inside__item {
  background: #fff;
  border-radius: 20px;
  overflow: hidden;
  border: 1.5px solid #EDE2C9;
  transition: transform 200ms cubic-bezier(.34,1.56,.64,1),
              box-shadow 200ms ease;
}
.inside__item:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 28px rgba(96,58,21,.1);
}
/* Kleur per icon type */
.inside__item--pink   { background: #fff8fa; border-color: #FFD6E3; }
.inside__item--green  { background: #f6fdf2; border-color: #c8e6c0; }
.inside__item--yellow { background: #fffdf0; border-color: #ffe9a0; }
.inside__item--orange { background: #fff8f2; border-color: #ffd4b0; }

.inside__item-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 18px 18px 14px;
}
.inside__item-icon {
  width: 44px; height: 44px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.inside__item-icon svg { width: 20px; height: 20px; }
.inside__item-icon--pink   { background: #fff0f5; color: #e75480; }
.inside__item-icon--green  { background: #e8f5e2; color: #66AA44; }
.inside__item-icon--yellow { background: #fffae0; color: #c49000; }
.inside__item-icon--orange { background: #fff0e4; color: #F7A048; }

.inside__item-title {
  font-family: 'Lilita One', cursive;
  font-size: 1.05rem;
  color: #3d2209;
  line-height: 1.2;
  margin-bottom: 4px;
}
.inside__item-desc {
  font-family: 'Karla', sans-serif;
  font-size: .8rem;
  color: #A88259;
  line-height: 1.6;
}
.inside__item-img-wrap {
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
}
.inside__item-img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 400ms ease;
}
.inside__item:hover .inside__item-img { transform: scale(1.04); }
.inside__item-footnote {
  font-family: 'Karla', sans-serif;
  font-size: .7rem;
  color: #C4A882;
  padding: 8px 18px 14px;
  font-style: italic;
}

/* ── Midden: doos afbeelding ────────────────────────────── */
.inside__center {
  display: flex;
  justify-content: center;
}
.inside__center-img-wrap {
  position: relative;
  width: 100%;
  max-width: 480px;
}
.inside__center-img {
  width: 100%;
  border-radius: 24px;
  box-shadow: 0 16px 56px rgba(96,58,21,.16);
  display: block;
}
.inside__center-ph {
  width: 100%;
  aspect-ratio: 1;
  background: #EDE2C9;
  border-radius: 24px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 12px; color: #A88259;
}
.inside__center-ph svg { width: 56px; height: 56px; }

/* Cirkel badge */
.inside__center-badge {
  position: absolute;
  top: 20px; right: -16px;
  width: 110px; height: 110px;
  background: #FFE071;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  padding: 16px;
  box-shadow: 0 6px 24px rgba(96,58,21,.15);
  border: 3px solid #fff;
  z-index: 2;
}
.inside__center-badge span {
  font-family: 'Lilita One', cursive;
  font-size: .8rem;
  color: #603A15;
  line-height: 1.3;
}
@media(max-width: 899px) {
  .inside__center-badge {
    top: 12px; right: 12px;
    width: 80px; height: 80px;
  }
  .inside__center-badge span { font-size: .7rem; }
}

/* ── Trust strip ────────────────────────────────────────── */
.inside__trust {
  background: #EDE2C9;
  border-top: 1.5px solid #DAC9A1;
}
.inside__trust-inner {
  max-width: 1280px; margin: 0 auto;
  padding: 0 20px;
  display: flex;
  align-items: center;
  gap: 16px;
}
@media(min-width: 768px) {
  .inside__trust-inner { padding: 0 40px; }
}
.inside__trust-item {
  display: flex; align-items: center; gap: 12px;
  padding: 16px 16px;
  border-right: 1px solid #DAC9A1;
}
.inside__trust-item:last-child { border-right: none; }
.inside__trust-dog {
  width: 80px; height: 80px; border-radius: 50%;
  overflow: hidden; flex-shrink: 0;
  border: 3px solid #fff;
  box-shadow: 0 4px 16px rgba(96,58,21,.15);
}
.inside__trust-dog img {
  width: 100%; height: 100%; object-fit: cover; display: block;
}
@media(max-width: 767px) { .inside__trust-dog { display: none; } }
.inside__trust-items {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  flex: 1; gap: 0;
}
@media(min-width: 768px) {
  .inside__trust-items { grid-template-columns: repeat(4, 1fr); }
}
.inside__trust-icon {
  width: 44px; height: 44px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.inside__trust-icon svg { width: 20px; height: 20px; }
.inside__trust-icon--green  { background: #e8f5e2; color: #66AA44; }
.inside__trust-icon--pink   { background: #fff0f5; color: #e75480; }
.inside__trust-icon--orange { background: #fff0e4; color: #F7A048; }
.inside__trust-icon--yellow { background: #fffae0; color: #c49000; }

.inside__trust-text {
  display: flex; flex-direction: column; gap: 2px;
}
.inside__trust-text strong {
  font-family: 'Karla', sans-serif;
  font-size: .85rem; font-weight: 800; color: #603A15; line-height: 1.2;
}
.inside__trust-text span {
  font-size: .75rem; color: #A88259;
}

{% endstylesheet %}

