{% comment %}
  Kwispelbox — Betaalmogelijkheden
  Full-bleed hero (foto + overlay) + betaalmethode-grid + veiligheid-strip
  + FAQ/contact + CTA-strip. Alles instelbaar via Theme Editor. Mobiel-geoptimaliseerd.
{% endcomment %}

{%- comment -%} ── HERO (volle breedte, foto als achtergrond) ── {%- endcomment -%}
{%- if section.settings.hero_title_1 != blank or section.settings.hero_image != blank -%}
  <div class="pp__hero full-width">
    {%- if section.settings.hero_image != blank -%}
      {{ section.settings.hero_image | image_url: width: 2400 | image_tag:
         widths: '800, 1200, 1600, 2000, 2400', sizes: '100vw',
         loading: 'eager', fetchpriority: 'high',
         class: 'pp__hero-img', alt: section.settings.hero_title_1 | escape }}
    {%- else -%}
      <div class="pp__hero-img pp__hero-img--placeholder">{{ 'image' | placeholder_svg_tag: 'pp__placeholder' }}</div>
    {%- endif -%}
    <div class="pp__hero-overlay" aria-hidden="true"></div>
    <div class="pp__hero-content">
      <h1 class="pp__hero-heading">
        {{ section.settings.hero_title_1 }}
        {%- if section.settings.hero_title_2 != blank -%}
          <span class="pp__hero-heading-accent">{{ section.settings.hero_title_2 }}</span>
          <span class="pp__hero-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
        {%- endif -%}
      </h1>
      {%- if section.settings.hero_body != blank -%}
        <p class="pp__hero-body">{{ section.settings.hero_body }}</p>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% render 'breadcrumbs', overlay: true %}

<div class="pp full-width">

  {%- comment -%} ── BETAALMETHODE-GRID ───────────────────────── {%- endcomment -%}
  {%- assign method_blocks = section.blocks | where: 'type', 'method' -%}
  {%- if method_blocks.size > 0 -%}
    <div class="pp__methods">
      {%- if section.settings.methods_title != blank -%}
        <h2 class="pp__section-title">
          <span class="pp__title-dash" aria-hidden="true"></span>
          {{ section.settings.methods_title }}
          <span class="pp__title-dash" aria-hidden="true"></span>
        </h2>
      {%- endif -%}
      <ul class="pp__grid" role="list">
        {%- for block in method_blocks -%}
          <li class="pp__card" {{ block.shopify_attributes }}>
            <div class="pp__card-logo">
              {%- if block.settings.logo != blank -%}
                {{ block.settings.logo | image_url: width: 200 | image_tag:
                   widths: '100, 200', sizes: '100px', loading: 'lazy',
                   class: 'pp__card-logo-img', alt: block.settings.name | escape }}
              {%- else -%}
                <span class="pp__card-logo-ph" aria-hidden="true">{{- 'icon-shield.svg' | inline_asset_content -}}</span>
              {%- endif -%}
            </div>
            <h3 class="pp__card-name">{{ block.settings.name }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="pp__card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}

  {%- comment -%} ── VEILIGHEID-STRIP ─────────────────────────── {%- endcomment -%}
  {%- if section.settings.safety_title != blank -%}
    <div class="pp__safety">
      <span class="pp__safety-icon" aria-hidden="true">{{- 'icon-shield.svg' | inline_asset_content -}}</span>
      <div class="pp__safety-text">
        <h2 class="pp__safety-title">{{ section.settings.safety_title }}</h2>
        {%- if section.settings.safety_body != blank -%}
          <p class="pp__safety-body">{{ section.settings.safety_body }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.safety_badge != blank -%}
        <span class="pp__safety-badge" aria-hidden="true">
          <span class="pp__safety-badge-lock">{{- 'icon-lock.svg' | inline_asset_content -}}</span>
          {{ section.settings.safety_badge }}
        </span>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── FAQ + CONTACT ────────────────────────────── {%- endcomment -%}
  {%- assign faq_blocks = section.blocks | where: 'type', 'faq' -%}
  {%- if faq_blocks.size > 0 or section.settings.contact_title != blank -%}
    <div class="pp__support">

      {%- if faq_blocks.size > 0 -%}
        <div class="pp__faq">
          {%- if section.settings.faq_title != blank -%}
            <h2 class="pp__faq-title">{{ section.settings.faq_title }}</h2>
          {%- endif -%}
          <div class="pp__faq-list">
            {%- for block in faq_blocks -%}
              <details class="pp__faq-item" {{ block.shopify_attributes }}>
                <summary class="pp__faq-q">
                  <span>{{ block.settings.question }}</span>
                  <span class="pp__faq-chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                </summary>
                <div class="pp__faq-a">{{ block.settings.answer }}</div>
              </details>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.contact_title != blank -%}
        <aside class="pp__contact">
          <span class="pp__contact-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
          <h2 class="pp__contact-title">{{ section.settings.contact_title }}</h2>
          {%- if section.settings.contact_body != blank -%}
            <p class="pp__contact-body">{{ section.settings.contact_body }}</p>
          {%- endif -%}
          {%- if section.settings.contact_btn != blank -%}
            <a href="{{ section.settings.contact_url }}" class="pp__contact-btn">
              {{ section.settings.contact_btn }}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.contact_email != blank -%}
            <div class="pp__contact-detail">
              <span aria-hidden="true">{{- 'icon-mail.svg' | inline_asset_content -}}</span>
              {{ section.settings.contact_email }}
            </div>
          {%- endif -%}
          {%- if section.settings.contact_hours != blank -%}
            <div class="pp__contact-detail">
              <span aria-hidden="true">{{- 'icon-refresh.svg' | inline_asset_content -}}</span>
              {{ section.settings.contact_hours }}
            </div>
          {%- endif -%}
        </aside>
      {%- endif -%}

    </div>
  {%- endif -%}

  {%- comment -%} ── CTA-STRIP ────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.cta_title != blank -%}
    <div class="pp__ctastrip">
      <div class="pp__ctastrip-body">
        <span class="pp__ctastrip-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
        <h2 class="pp__ctastrip-title">{{ section.settings.cta_title }}</h2>
        {%- if section.settings.cta_body != blank -%}
          <p class="pp__ctastrip-text">{{ section.settings.cta_body }}</p>
        {%- endif -%}
        {%- if section.settings.cta_btn != blank -%}
          <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="pp__ctastrip-btn">
            {{ section.settings.cta_btn }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_image != blank -%}
        <span class="pp__ctastrip-img" aria-hidden="true">
          {{ section.settings.cta_image | image_url: width: 700 | image_tag:
             widths: '350, 700', sizes: '(min-width: 768px) 340px, 100vw',
             loading: 'lazy', class: 'pp__ctastrip-img-el', alt: '' }}
        </span>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

{% stylesheet %}
.pp{max-width:1100px;margin:0 auto;padding:0 20px 64px;font-family:'Karla',sans-serif}

/* Hero — volle breedte, foto als achtergrond */
.pp__hero{position:relative;width:100%;min-height:360px;overflow:hidden;display:flex;align-items:center;background:#F4E7D0}
.pp__hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:right center;display:block}
.pp__hero-img--placeholder{background:#EDE2C9;display:flex;align-items:center;justify-content:center}
.pp__hero-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(244,231,208,.45) 0%,rgba(244,231,208,.8) 50%,rgba(244,231,208,.97) 78%)}
.pp__hero-content{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:36px 24px 40px;display:flex;flex-direction:column;gap:18px}
.pp__hero-heading{font-family:'Lilita One',cursive;font-size:clamp(2.4rem,6vw,4.5rem);line-height:1.05;color:#3d2209;margin:0;max-width:16ch}
.pp__hero-heading-accent{color:#66AA44;display:inline}
.pp__hero-heart{display:inline-flex;color:#FFB8CD;vertical-align:middle;margin-left:6px}
.pp__hero-heart svg{width:30px;height:30px}
.pp__hero-body{font-size:1.05rem;color:#603A15;margin:0;line-height:1.5;max-width:42ch}

/* Sectie-titel */
.pp__section-title{font-family:'Lilita One',cursive;font-size:clamp(1.6rem,3.5vw,2.4rem);color:#3d2209;text-align:center;margin:40px 0 28px;display:flex;align-items:center;justify-content:center;gap:14px}
.pp__title-dash{width:26px;height:3px;background:#66AA44;border-radius:3px;display:inline-block}

/* Betaalmethode-grid */
.pp__methods{margin-bottom:48px}
.pp__grid{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:16px}
.pp__card{background:#FBF3E4;border:1.5px solid #EDE2C9;border-radius:20px;padding:24px 18px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:8px;transition:transform 200ms cubic-bezier(.34,1.56,.64,1),box-shadow 200ms}
.pp__card:hover{transform:translateY(-4px);box-shadow:0 10px 26px rgba(96,58,21,.1)}
.pp__card-logo{width:96px;height:60px;flex-shrink:0;background:#fff;border-radius:12px;display:flex;align-items:center;justify-content:center;overflow:hidden;padding:8px;margin-bottom:4px}
.pp__card-logo-img{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain}
.pp__card-logo-ph{display:flex;color:#DAC9A1}
.pp__card-logo-ph svg{width:26px;height:26px}
.pp__card-name{font-family:'Lilita One',cursive;font-size:1.1rem;color:#3d2209;margin:0;line-height:1.15}
.pp__card-desc{font-size:.88rem;color:#A88259;margin:0;line-height:1.4}

/* Veiligheid-strip */
.pp__safety{display:flex;align-items:center;gap:18px;background:#e8f5e2;border-radius:22px;padding:24px 26px;flex-wrap:wrap}
.pp__safety-icon{width:52px;height:52px;border-radius:50%;background:#66AA44;color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pp__safety-icon svg{width:26px;height:26px}
.pp__safety-text{flex:1;min-width:200px}
.pp__safety-title{font-family:'Lilita One',cursive;font-size:1.25rem;color:#3d2209;margin:0 0 3px}
.pp__safety-body{font-size:.92rem;color:#3d6b1f;margin:0;line-height:1.45}
.pp__safety-badge{display:inline-flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;width:104px;height:104px;background:#66AA44;color:#fff;border-radius:50%;font-family:'Lilita One',cursive;font-size:.82rem;text-align:center;line-height:1.1;padding:12px;flex-shrink:0}
.pp__safety-badge-lock{display:flex}
.pp__safety-badge-lock svg{width:24px;height:24px}

/* FAQ + contact */
.pp__support{display:grid;grid-template-columns:1fr;gap:20px;margin-top:44px}
.pp__faq{background:#FBF3E4;border-radius:24px;padding:26px 22px}
.pp__faq-title{font-family:'Lilita One',cursive;font-size:1.4rem;color:#3d2209;margin:0 0 16px}
.pp__faq-list{display:flex;flex-direction:column}
.pp__faq-item{border-bottom:1px solid #EDE2C9}
.pp__faq-item:last-child{border-bottom:none}
.pp__faq-q{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 4px;cursor:pointer;font-family:'Karla',sans-serif;font-weight:700;font-size:1rem;color:#3d2209;list-style:none}
.pp__faq-q::-webkit-details-marker{display:none}
.pp__faq-chevron{display:flex;color:#A88259;flex-shrink:0;transition:transform 250ms}
.pp__faq-chevron svg{width:18px;height:18px}
.pp__faq-item[open] .pp__faq-chevron{transform:rotate(180deg)}
.pp__faq-a{padding:0 4px 16px;font-size:.94rem;color:#603A15;line-height:1.55}
.pp__contact{background:#e8f5e2;border-radius:24px;padding:26px 22px;display:flex;flex-direction:column;gap:8px}
.pp__contact-heart{display:flex;color:#FFB8CD}
.pp__contact-heart svg{width:30px;height:30px}
.pp__contact-title{font-family:'Lilita One',cursive;font-size:1.3rem;color:#3d2209;margin:4px 0 0}
.pp__contact-body{font-size:.94rem;color:#3d6b1f;margin:0 0 6px;line-height:1.5}
.pp__contact-btn{display:inline-flex;align-items:center;gap:8px;align-self:flex-start;background:#66AA44;color:#fff;font-family:'Lilita One',cursive;font-size:.95rem;padding:12px 22px;border-radius:999px;text-decoration:none;margin-bottom:6px;transition:background 160ms,transform 200ms cubic-bezier(.34,1.56,.64,1)}
.pp__contact-btn:hover{background:#4d8833;transform:translateY(-2px)}
.pp__contact-detail{display:flex;align-items:center;gap:9px;font-size:.92rem;font-weight:600;color:#3d2209}
.pp__contact-detail span{display:flex;color:#66AA44;flex-shrink:0}
.pp__contact-detail svg{width:18px;height:18px}

/* CTA-strip */
.pp__ctastrip{position:relative;margin-top:40px;background:#4d7a30;border-radius:26px;overflow:hidden;display:flex;align-items:center;min-height:170px}
.pp__ctastrip-body{position:relative;z-index:1;padding:28px 24px;display:flex;flex-direction:column;align-items:flex-start;gap:10px;max-width:60%}
.pp__ctastrip-heart{display:flex;color:#FFB8CD}
.pp__ctastrip-heart svg{width:28px;height:28px}
.pp__ctastrip-title{font-family:'Lilita One',cursive;font-size:clamp(1.4rem,3vw,1.9rem);color:#fff;margin:0;line-height:1.1}
.pp__ctastrip-text{font-size:.95rem;color:#eaf3e2;margin:0;line-height:1.45}
.pp__ctastrip-btn{display:inline-flex;align-items:center;gap:8px;background:#fff;color:#3d2209;font-family:'Lilita One',cursive;font-size:.95rem;padding:13px 24px;border-radius:999px;text-decoration:none;margin-top:4px;transition:transform 200ms cubic-bezier(.34,1.56,.64,1)}
.pp__ctastrip-btn:hover{transform:translateY(-2px)}
.pp__ctastrip-img{position:absolute;right:0;bottom:0;top:0;width:42%;z-index:0;display:flex;align-items:flex-end;justify-content:flex-end}
.pp__ctastrip-img-el{width:100%;height:100%;object-fit:cover;object-position:center}

/* Desktop */
@media(min-width:768px){
  .pp__hero{min-height:480px}
  .pp__hero-overlay{background:linear-gradient(90deg,rgba(244,231,208,.95) 0%,rgba(244,231,208,.88) 32%,rgba(244,231,208,.5) 56%,rgba(244,231,208,0) 80%)}
  .pp__hero-content{padding:60px 60px}
  .pp__grid{grid-template-columns:repeat(4,1fr);gap:18px}
  .pp__support{grid-template-columns:1.5fr 1fr;gap:24px;align-items:start}
  .pp__faq{padding:32px 28px}
  .pp__contact{padding:32px 28px}
}

/* Mobiel: hero tekst onder foto */
@media(max-width:767px){
  .pp__hero{flex-direction:column;align-items:stretch;min-height:unset;background:#F4E7D0}
  .pp__hero-img{position:relative;inset:auto;width:100%;height:auto;aspect-ratio:4/3;display:block}
  .pp__hero-img--placeholder{aspect-ratio:4/3}
  .pp__hero-overlay{display:none}
  .pp__hero-content{position:static;background:#F4E7D0;padding:24px 20px 30px}
  .pp__ctastrip-img{position:relative;width:100%;aspect-ratio:16/10}
  .pp__ctastrip{flex-direction:column-reverse}
  .pp__ctastrip-body{max-width:100%;padding:24px 20px}
}

@media(prefers-reduced-motion:reduce){
  .pp__card,.pp__contact-btn,.pp__ctastrip-btn,.pp__faq-chevron{transition:none}
  .pp__card:hover,.pp__contact-btn:hover,.pp__ctastrip-btn:hover{transform:none}
}
{% endstylesheet %}

{% schema %}
{
  "name": "Betaalmogelijkheden",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_title_1", "label": "Titel regel 1", "default": "Betaal zoals" },
    { "type": "text", "id": "hero_title_2", "label": "Titel regel 2 (groen)", "default": "het voor jou werkt" },
    { "type": "textarea", "id": "hero_body", "label": "Tekst", "default": "Bij Kwispelbox maken we betalen makkelijk, veilig en betrouwbaar. Kies zelf de betaalmethode die het beste bij jou past." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero afbeelding" },

    { "type": "header", "content": "Betaalmethodes" },
    { "type": "text", "id": "methods_title", "label": "Titel", "default": "Alle betaalmethoden op een rij" },

    { "type": "header", "content": "Veiligheid-strip" },
    { "type": "text", "id": "safety_title", "label": "Titel", "default": "Veilig betalen, dat vinden wij belangrijk" },
    { "type": "textarea", "id": "safety_body", "label": "Tekst", "default": "Al je betalingen worden beveiligd met SSL-encryptie. Zo zijn jouw gegevens altijd goed beschermd." },
    { "type": "text", "id": "safety_badge", "label": "Badge tekst", "default": "100% veilig & beveiligd" },

    { "type": "header", "content": "FAQ" },
    { "type": "text", "id": "faq_title", "label": "Titel", "default": "Veelgestelde vragen" },

    { "type": "header", "content": "Contact-blok" },
    { "type": "text", "id": "contact_title", "label": "Titel", "default": "Toch nog vragen?" },
    { "type": "text", "id": "contact_body", "label": "Tekst", "default": "Ons team helpt je graag verder." },
    { "type": "text", "id": "contact_btn", "label": "Knoptekst", "default": "Neem contact op" },
    { "type": "url", "id": "contact_url", "label": "Knop link" },
    { "type": "text", "id": "contact_email", "label": "E-mail" },
    { "type": "text", "id": "contact_hours", "label": "Reactietijd / openingstijden" },

    { "type": "header", "content": "CTA-strip" },
    { "type": "text", "id": "cta_title", "label": "Titel", "default": "Klaar om jouw hond blij te maken?" },
    { "type": "text", "id": "cta_body", "label": "Tekst", "default": "Kies je favoriete Kwispelbox en betaal op jouw manier." },
    { "type": "text", "id": "cta_btn", "label": "Knoptekst", "default": "Ontdek onze boxen" },
    { "type": "url", "id": "cta_url", "label": "Knop link" },
    { "type": "image_picker", "id": "cta_image", "label": "CTA afbeelding (puppy)" }
  ],
  "blocks": [
    {
      "type": "method",
      "name": "Betaalmethode",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "text", "id": "name", "label": "Naam", "default": "iDEAL" },
        { "type": "text", "id": "description", "label": "Beschrijving", "default": "Veilig en vertrouwd betalen via je eigen bank." }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ vraag",
      "settings": [
        { "type": "text", "id": "question", "label": "Vraag", "default": "Is betalen bij Kwispelbox veilig?" },
        { "type": "textarea", "id": "answer", "label": "Antwoord", "default": "Ja, al je betalingen verlopen via een beveiligde SSL-verbinding." }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Betaalmogelijkheden",
      "blocks": [
        { "type": "method", "settings": { "name": "iDEAL", "description": "Veilig en vertrouwd betalen via je eigen bank." } },
        { "type": "method", "settings": { "name": "Klarna", "description": "Achteraf betalen of in 3 termijnen. Flexibel en zonder gedoe." } },
        { "type": "method", "settings": { "name": "Mastercard", "description": "Betaal eenvoudig en veilig met je Mastercard." } },
        { "type": "method", "settings": { "name": "Visa", "description": "Wereldwijd geaccepteerd en altijd betrouwbaar." } },
        { "type": "method", "settings": { "name": "PayPal", "description": "Snel en veilig betalen met je PayPal account." } },
        { "type": "method", "settings": { "name": "Apple Pay", "description": "Supersnel betalen met Apple Pay." } },
        { "type": "method", "settings": { "name": "Google Pay", "description": "Betaal makkelijk en veilig met Google Pay." } },
        { "type": "method", "settings": { "name": "Bancontact", "description": "Voor onze Belgische klanten: veilig en vertrouwd." } },
        { "type": "faq", "settings": { "question": "Is betalen bij Kwispelbox veilig?", "answer": "Ja, al je betalingen verlopen via een beveiligde SSL-verbinding en we slaan geen betaalgegevens op." } },
        { "type": "faq", "settings": { "question": "Wanneer wordt het bedrag afgeschreven?", "answer": "Het bedrag wordt direct na het plaatsen van je bestelling afgeschreven, behalve bij achteraf betalen via Klarna." } },
        { "type": "faq", "settings": { "question": "Kan ik achteraf betalen?", "answer": "Ja, via Klarna kun je achteraf of in termijnen betalen." } },
        { "type": "faq", "settings": { "question": "Welke betaalmethoden zijn er in België?", "answer": "In België kun je betalen met Bancontact, creditcard, PayPal en meer." } }
      ]
    }
  ]
}
{% endschema %}
