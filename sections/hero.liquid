{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
  assign has_mobile_image = false
  if section.settings.mobile_image != blank
    assign has_mobile_image = true
  endif
-%}

<div class="hero full-width{% if section.settings.full_height %} hero--full-height{% endif %}">

  {%- comment -%} Achtergrondafbeelding desktop {%- endcomment -%}
  {%- if has_image -%}
    <img
      class="hero__img{% if has_mobile_image %} hero__img--desktop{% endif %}"
      src="{{ section.settings.image | image_url: width: 1200 }}"
      srcset="
        {{ section.settings.image | image_url: width: 600  }} 600w,
        {{ section.settings.image | image_url: width: 900  }} 900w,
        {{ section.settings.image | image_url: width: 1200 }} 1200w,
        {{ section.settings.image | image_url: width: 1600 }} 1600w,
        {{ section.settings.image | image_url: width: 1920 }} 1920w
      "
      sizes="100vw"
      alt="{{ section.settings.image.alt | escape }}"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- endif -%}

  {%- comment -%} Aparte afbeelding voor mobiel (optioneel) {%- endcomment -%}
  {%- if has_mobile_image -%}
    <img
      class="hero__img hero__img--mobile"
      src="{{ section.settings.mobile_image | image_url: width: 800 }}"
      srcset="
        {{ section.settings.mobile_image | image_url: width: 400 }} 400w,
        {{ section.settings.mobile_image | image_url: width: 600 }} 600w,
        {{ section.settings.mobile_image | image_url: width: 800 }} 800w
      "
      sizes="100vw"
      alt="{{ section.settings.mobile_image.alt | escape }}"
      width="{{ section.settings.mobile_image.width }}"
      height="{{ section.settings.mobile_image.height }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- endif -%}

  {%- comment -%} Gradient overlay {%- endcomment -%}
  <div class="hero__overlay"></div>

  {%- comment -%} Content {%- endcomment -%}
  <div class="hero__content hero__content--{{ section.settings.content_alignment }}">

    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.btn_primary_label != blank or section.settings.btn_secondary_label != blank -%}
      <div class="hero__btns">
        {%- if section.settings.btn_primary_label != blank -%}
          <a href="{{ section.settings.btn_primary_url }}"
             class="hero__btn hero__btn--primary">
            {{ section.settings.btn_primary_label }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                 aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.btn_secondary_label != blank -%}
          <a href="{{ section.settings.btn_secondary_url }}"
             class="hero__btn hero__btn--secondary">
            {{ section.settings.btn_secondary_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Trust pills {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <ul class="hero__pills" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_pill' -%}
            <li class="hero__pill" {{ block.shopify_attributes }}>
              {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              {{ block.settings.text }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>

  <!-- Wave divider onderaan hero -->
  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none"
         xmlns="http://www.w3.org/2000/svg">
      <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z"
            fill="#F8EFDD"/>
    </svg>
  </div>

</div>

{% stylesheet %}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 480px;
  display: flex;
  align-items: center;
  background-color: #F8EFDD;
}

.hero--full-height {
  min-height: calc(100svh - var(--kw-header-h, 140px));
}

/* ── Afbeelding ───────────────────────────────────────────────── */
.hero__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: right center;
}

.hero__img--desktop { display: none; }
.hero__img--mobile  { display: block; }

@media (min-width: 768px) {
  .hero__img--desktop { display: block; }
  .hero__img--mobile  { display: none; }
}

/* ── Gradient overlay ─────────────────────────────────────────── */
.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    rgba(248,239,221,.95) 0%,
    rgba(248,239,221,.85) 30%,
    rgba(248,239,221,.5)  55%,
    rgba(248,239,221,.0)  80%
  );
}

@media (max-width: 767px) {
  .hero__overlay {
    background: linear-gradient(
      180deg,
      rgba(248,239,221,.2)  0%,
      rgba(248,239,221,.75) 45%,
      rgba(248,239,221,.97) 70%
    );
  }
}

/* ── Content ──────────────────────────────────────────────────── */
.hero__content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 60px 20px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

@media (min-width: 768px) {
  .hero__content {
    padding: 80px 60px;
    max-width: 580px;
    margin: 0;
  }
}

/* Centreren optie */
.hero__content--center {
  align-items: center;
  text-align: center;
  max-width: 1280px;
  margin: 0 auto;
}

.hero__content--left {
  align-items: flex-start;
  text-align: left;
}

/* Mobiel altijd centreren */
@media (max-width: 767px) {
  .hero__content {
    align-items: center;
    text-align: center;
    padding-top: 40vw;
  }
}

/* ── Tekst elementen ──────────────────────────────────────────── */
.hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'Karla', sans-serif;
  font-size: 0.8rem;
  font-weight: 800;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #d9823a;
  background: rgba(247,160,72,.15);
  border: 1.5px solid rgba(247,160,72,.3);
  border-radius: 999px;
  padding: 5px 14px;
}

.hero__heading {
  font-family: 'Lilita One', cursive;
  font-size: clamp(2.4rem, 6vw, 4.5rem);
  line-height: 1.05;
  color: #603A15;
  max-width: 14ch;
}

.hero__sub {
  font-family: 'Karla', sans-serif;
  font-size: clamp(1rem, 1.8vw, 1.2rem);
  color: #A88259;
  line-height: 1.7;
  max-width: 42ch;
}

/* ── Knoppen ──────────────────────────────────────────────────── */
.hero__btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.hero__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Lilita One', cursive;
  font-size: 1rem;
  border-radius: 999px;
  text-decoration: none;
  padding: 14px 28px;
  transition: transform 200ms cubic-bezier(.34,1.56,.64,1),
              box-shadow 160ms ease,
              background 160ms ease;
}
.hero__btn:active { transform: scale(.97); }

.hero__btn--primary {
  background: #F7A048;
  color: #fff;
  box-shadow: 0 4px 16px rgba(247,160,72,.4);
}
.hero__btn--primary:hover {
  background: #d9823a;
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(247,160,72,.45);
}

.hero__btn--secondary {
  background: transparent;
  color: #603A15;
  border: 2.5px solid #603A15;
}
.hero__btn--secondary:hover {
  background: #603A15;
  color: #F8EFDD;
  transform: translateY(-3px);
}

/* ── Trust pills ──────────────────────────────────────────────── */
.hero__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  list-style: none;
  margin-top: 4px;
}

.hero__pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'Karla', sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  color: #603A15;
  background: rgba(255,255,255,.7);
  border: 1.5px solid rgba(96,58,21,.15);
  border-radius: 999px;
  padding: 6px 14px;
  backdrop-filter: blur(4px);
}

.hero__pill svg {
  width: 13px;
  height: 13px;
  color: #F7A048;
  flex-shrink: 0;
}

.hero__wave {
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  line-height: 0;
  pointer-events: none;
}
.hero__wave svg {
  width: 100%;
  height: 60px;
  display: block;
}

/* ── Reduced motion ───────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .hero__btn { transition: none; }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "limit": 1,
  "enabled_on": {
    "templates": ["index"]
  },
  "blocks": [
    {
      "type": "trust_pill",
      "name": "Trust pill",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icoon",
          "default": "truck",
          "options": [
            { "value": "truck",        "label": "Verzending" },
            { "value": "cart",         "label": "Winkelwagen" },
            { "value": "search",       "label": "Zoek" },
            { "value": "account",      "label": "Account" }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Gratis v.a. €75"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Afbeelding"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding desktop"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Afbeelding mobiel (optioneel)",
      "info": "Laat leeg om dezelfde afbeelding te gebruiken"
    },
    {
      "type": "header",
      "content": "Tekst"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Koptekst",
      "default": "Een feestje voor jouw hond."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtekst",
      "default": "Verrassingsboxen vol zorgvuldig geselecteerd speelgoed. Elke bestelling voelt als een cadeautje."
    },
    {
      "type": "header",
      "content": "Knoppen"
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Primaire knop tekst",
      "default": "Ontdek de boxen"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Primaire knop link"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Secundaire knop tekst",
      "default": "Hoe werkt het?"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Secundaire knop link"
    },
    {
      "type": "header",
      "content": "Opmaak"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Uitlijning content",
      "default": "left",
      "options": [
        { "value": "left",   "label": "Links" },
        { "value": "center", "label": "Gecentreerd" }
      ]
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Volledige schermhoogte",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "trust_pill", "settings": { "icon": "truck", "text": "Gratis v.a. €75" } },
        { "type": "trust_pill", "settings": { "icon": "cart",  "text": "1-3 werkdagen" } },
        { "type": "trust_pill", "settings": { "icon": "account", "text": "Garantie" } }
      ]
    }
  ]
}
{% endschema %}
