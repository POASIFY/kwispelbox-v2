{% comment %} KWISPELBOX — Cart pagina {% endcomment %}

{%- assign free_threshold = section.settings.free_shipping_threshold | times: 100 -%}
{%- assign cart_total = cart.total_price -%}
{%- assign remaining_cents = free_threshold | minus: cart_total -%}
{%- assign shipping_free = false -%}
{%- if cart_total >= free_threshold -%}{%- assign shipping_free = true -%}{%- endif -%}
{%- assign progress_pct = cart_total | times: 100 | divided_by: free_threshold -%}
{%- if progress_pct > 100 -%}{%- assign progress_pct = 100 -%}{%- endif -%}

<div class="cart-page" data-cart-section>

  <!-- ══ KOPTEKST ════════════════════════════════════════ -->
  <div class="cart-page__header">
    <h1 class="cart-page__title">
      {{ section.settings.title }}
      <span class="cart-page__title-heart" aria-hidden="true">
        {{- 'icon-heart.svg' | inline_asset_content -}}
      </span>
    </h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="cart-page__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  {%- if cart.item_count > 0 -%}
  <div class="cart-page__layout">

    <!-- ══ LINKS: items + extras ═══════════════════════════ -->
    <div class="cart-page__left">

      <!-- Gratis verzending balk -->
      <div class="cart-shipping-bar" data-shipping-bar>
        <div class="cart-shipping-bar__text">
          {%- if shipping_free -%}
            {{- 'icon-truck.svg' | inline_asset_content -}}
            <span>{{ section.settings.shipping_free_msg }}</span>
            <span class="cart-shipping-bar__confetti" aria-hidden="true">🎉</span>
          {%- else -%}
            {{- 'icon-truck.svg' | inline_asset_content -}}
            <span>{{ section.settings.shipping_bar_msg }}
              <strong>{{ remaining_cents | money }}</strong>
              {{ section.settings.shipping_bar_suffix }}
            </span>
          {%- endif -%}
        </div>
        <div class="cart-shipping-bar__track" aria-hidden="true">
          <div class="cart-shipping-bar__fill" style="width:{{ progress_pct }}%"></div>
        </div>
      </div>

      <!-- Cart items -->
      <div class="cart-items" data-cart-items>
        {%- for item in cart.items -%}
          <div class="cart-item" data-item-key="{{ item.key }}">

            <!-- Afbeelding -->
            <a href="{{ item.url }}" class="cart-item__img-link" tabindex="-1" aria-hidden="true">
              {%- if item.image -%}
                <img
                  src="{{ item.image | image_url: width: 200 }}"
                  alt="{{ item.title | escape }}"
                  width="100" height="100"
                  loading="lazy"
                  class="cart-item__img"
                >
              {%- else -%}
                <div class="cart-item__img-ph">{{- 'icon-box.svg' | inline_asset_content -}}</div>
              {%- endif -%}
            </a>

            <!-- Info -->
            <div class="cart-item__info">
              <div class="cart-item__top">
                <div>
                  <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  {%- if item.product.description != blank -%}
                    <p class="cart-item__desc">
                      {{ item.product.description | strip_html | truncate: 80 }}
                    </p>
                  {%- endif -%}

                  <!-- Selectvak voor abonnement (als aanwezig) -->
                  {%- if item.selling_plan_allocation != blank -%}
                    <span class="cart-item__plan-badge">
                      {{ item.selling_plan_allocation.selling_plan.name }}
                    </span>
                  {%- endif -%}
                </div>
                <span class="cart-item__price">{{ item.final_line_price | money }}</span>
              </div>

              <div class="cart-item__bottom">
                <!-- Acties -->
                <div class="cart-item__actions">
                  {%- if item.properties != blank -%}
                    <button class="cart-item__action-btn"
                            data-action="edit-item"
                            data-item-url="{{ item.url }}">
                      {{- 'icon-edit.svg' | inline_asset_content -}}
                      {{ 'Bewerken' }}
                    </button>
                  {%- endif -%}
                  <button class="cart-item__action-btn cart-item__action-btn--remove"
                          data-action="remove-item"
                          data-item-key="{{ item.key }}"
                          aria-label="Verwijder {{ item.title | escape }}">
                    {{- 'icon-trash.svg' | inline_asset_content -}}
                    {{ 'Verwijderen' }}
                  </button>
                </div>

                <!-- Aantal stepper -->
                <div class="cart-item__qty" role="group" aria-label="Aantal">
                  <button class="cart-item__qty-btn"
                          data-action="decrease"
                          data-item-key="{{ item.key }}"
                          aria-label="Minder">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                      <path d="M5 12h14"/>
                    </svg>
                  </button>
                  <span class="cart-item__qty-num" data-qty="{{ item.key }}">
                    {{ item.quantity }}
                  </span>
                  <button class="cart-item__qty-btn"
                          data-action="increase"
                          data-item-key="{{ item.key }}"
                          aria-label="Meer">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                      <path d="M5 12h14"/><path d="M12 5v14"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>

          </div>
        {%- endfor -%}
      </div>

      <!-- Upsell banner -->
      {%- if section.settings.upsell_title != blank and section.settings.upsell_product != blank -%}
        {%- assign up_product = section.settings.upsell_product -%}
        {%- unless cart.items contains up_product.variants.first -%}
          <div class="cart-upsell-banner">
            <span class="cart-upsell-banner__icon" aria-hidden="true">
              {{- 'icon-gift.svg' | inline_asset_content -}}
            </span>
            <div class="cart-upsell-banner__copy">
              <strong>{{ section.settings.upsell_title }}</strong>
              <span>{{ section.settings.upsell_desc }}</span>
            </div>
            <button class="cart-upsell-banner__btn kc-btn kc-btn--outline-pink"
                    data-action="add-upsell"
                    data-variant-id="{{ up_product.variants.first.id }}">
              Toevoegen voor {{ up_product.price | money }}
            </button>
          </div>
        {%- endunless -%}
      {%- endif -%}

      <!-- Trust bar -->
      <div class="cart-trust-bar">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_item' -%}
            <div class="cart-trust-bar__item" {{ block.shopify_attributes }}>
              <span class="cart-trust-bar__icon cart-trust-bar__icon--{{ block.settings.color }}">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <div class="cart-trust-bar__text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}
                  <span>{{ block.settings.subtitle }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Productaanbevelingen -->
      {%- if section.settings.rec_collection != blank -%}
        {%- assign rec_col = collections[section.settings.rec_collection] -%}
        {%- if rec_col.products_count > 0 -%}
          <div class="cart-recs">
            <h2 class="cart-recs__title">
              <span class="cart-recs__title-heart" aria-hidden="true">
                {{- 'icon-heart.svg' | inline_asset_content -}}
              </span>
              {{ section.settings.rec_title }}
            </h2>
            <div class="cart-recs__slider" data-recs-slider>
              <button class="cart-recs__nav cart-recs__nav--prev" aria-label="Vorige">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <path d="M19 12H5"/><path d="m12 5-7 7 7 7"/>
                </svg>
              </button>
              <div class="cart-recs__track">
                {%- for product in rec_col.products limit: 8 -%}
                  {%- unless cart.items.first.product == product -%}
                    <div class="cart-rec-card">
                      <a href="{{ product.url }}" class="cart-rec-card__img-link">
                        {%- if product.featured_image -%}
                          <img
                            src="{{ product.featured_image | image_url: width: 300 }}"
                            alt="{{ product.title | escape }}"
                            width="150" height="150"
                            loading="lazy"
                            class="cart-rec-card__img"
                          >
                        {%- endif -%}
                      </a>
                      <p class="cart-rec-card__name">{{ product.title }}</p>
                      <p class="cart-rec-card__price">{{ product.price | money }}</p>
                      <button class="cart-rec-card__btn"
                              data-action="add-product"
                              data-variant-id="{{ product.variants.first.id }}">
                        Toevoegen
                        {{- 'icon-cart.svg' | inline_asset_content -}}
                      </button>
                    </div>
                  {%- endunless -%}
                {%- endfor -%}
              </div>
              <button class="cart-recs__nav cart-recs__nav--next" aria-label="Volgende">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </button>
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}

      <!-- Hulp-sectie -->
      <div class="cart-help">
        {%- if section.settings.help_image != blank -%}
          <div class="cart-help__img-wrap" aria-hidden="true">
            <img
              src="{{ section.settings.help_image | image_url: width: 400 }}"
              alt=""
              width="200" height="200"
              loading="lazy"
              class="cart-help__img"
            >
          </div>
        {%- endif -%}
        <div class="cart-help__content">
          <strong class="cart-help__title">{{ section.settings.help_title }}</strong>
          <span class="cart-help__sub">{{ section.settings.help_subtitle }}</span>
          <div class="cart-help__links">
            {%- if section.settings.help_whatsapp != blank -%}
              <a href="https://wa.me/{{ section.settings.help_whatsapp | remove: '+' | remove: ' ' }}"
                 class="cart-help__link" target="_blank" rel="noopener">
                {{- 'icon-volume.svg' | inline_asset_content -}}
                WhatsApp ons
              </a>
            {%- endif -%}
            {%- if section.settings.help_email != blank -%}
              <a href="mailto:{{ section.settings.help_email }}" class="cart-help__link">
                {{- 'icon-mail.svg' | inline_asset_content -}}
                Stuur een e-mail
              </a>
            {%- endif -%}
            {%- if section.settings.help_faq_url != blank -%}
              <a href="{{ section.settings.help_faq_url }}" class="cart-help__link">
                {{- 'icon-search.svg' | inline_asset_content -}}
                Veelgestelde vragen
              </a>
            {%- endif -%}
          </div>
        </div>
        {%- if section.settings.help_score != blank -%}
          <div class="cart-help__score">
            <div class="cart-help__stars" aria-hidden="true">
              {%- for i in (1..5) -%}{{- 'icon-star.svg' | inline_asset_content -}}{%- endfor -%}
            </div>
            <strong>{{ section.settings.help_score }}</strong>
            <span>{{ section.settings.help_score_label }}</span>
          </div>
        {%- endif -%}
      </div>

    </div>

    <!-- ══ RECHTS: overzicht (sticky) ════════════════════════ -->
    <div class="cart-page__right">
      <div class="cart-sidebar" data-cart-sidebar>

        <!-- Overzicht -->
        <div class="cart-summary">
          <h2 class="cart-summary__title">
            {{ section.settings.summary_title }}
            <span class="cart-summary__heart" aria-hidden="true">
              {{- 'icon-heart.svg' | inline_asset_content -}}
            </span>
          </h2>
          <div class="cart-summary__row">
            <span>Subtotaal</span>
            <span data-subtotal>{{ cart.total_price | money }}</span>
          </div>
          <div class="cart-summary__row">
            <span>Verzending
              <span class="cart-summary__info" aria-label="Verzendinfo">ⓘ</span>
            </span>
            <span class="cart-summary__shipping" data-shipping>
              {%- if shipping_free -%}
                <span style="color:#66AA44;font-weight:800">Gratis</span>
              {%- else -%}
                Berekend bij afrekenen
              {%- endif -%}
            </span>
          </div>
          <div class="cart-summary__divider"></div>
          <div class="cart-summary__row cart-summary__row--total">
            <span>Totaal <small>(incl. btw)</small></span>
            <strong data-total>{{ cart.total_price | money }}</strong>
          </div>

          <a href="{{ routes.checkout_url }}" class="cart-checkout-btn" id="cart-checkout">
            {{- 'icon-lock.svg' | inline_asset_content -}}
            {{ section.settings.checkout_label }}
          </a>

          <a href="{{ section.settings.continue_url | default: '/' }}"
             class="cart-continue-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M19 12H5"/><path d="m12 5-7 7 7 7"/>
            </svg>
            {{ section.settings.continue_label }}
          </a>
        </div>

        <!-- Kwispels loyalty widget -->
        {%- if section.settings.show_kwispels -%}
          <div class="cart-kwispels">
            <div class="cart-kwispels__header">
              {{- 'icon-paw.svg' | inline_asset_content -}}
              <strong>{{ section.settings.kwispels_title }}</strong>
            </div>
            <p class="cart-kwispels__sub">{{ section.settings.kwispels_sub }}</p>
            <div class="cart-kwispels__earn" data-kwispels-earn>
              <span class="cart-kwispels__plus">+</span>
              <strong class="cart-kwispels__amount">
                {%- assign kwispels = cart.total_price | divided_by: 100 | floor -%}
                {{ kwispels }} kwispels
              </strong>
            </div>
            <p class="cart-kwispels__cta-text">{{ section.settings.kwispels_cta_text }}</p>
            {%- if customer -%}
              <span class="cart-kwispels__logged-in">
                {{- 'icon-check-circle.svg' | inline_asset_content -}}
                Je spaart automatisch mee!
              </span>
            {%- else -%}
              <a href="{{ routes.account_login_url }}" class="cart-kwispels__login-btn">
                {{- 'icon-account.svg' | inline_asset_content -}}
                Inloggen
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        <!-- Betaalmethoden -->
        {%- if section.settings.show_payment_icons -%}
          <div class="cart-payment-icons">
            <p class="cart-payment-icons__label">{{ section.settings.payment_label }}</p>
            <div class="cart-payment-icons__list">
              {%- assign methods = shop.enabled_payment_types -%}
              {%- for method in methods -%}
                {{ method | payment_type_img_url | image_tag: method, class: 'cart-payment-icons__icon' }}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>

  </div>

  {%- else -%}

  <!-- Lege cart -->
  <div class="cart-empty">
    <span class="cart-empty__icon" aria-hidden="true">{{- 'icon-paw.svg' | inline_asset_content -}}</span>
    <h2 class="cart-empty__title">{{ section.settings.empty_title }}</h2>
    <p class="cart-empty__sub">{{ section.settings.empty_subtitle }}</p>
    <a href="{{ section.settings.empty_cta_url | default: '/collections/all' }}"
       class="kc-btn kc-btn--primary">
      {{ section.settings.empty_cta_label }}
      {{- 'icon-paw.svg' | inline_asset_content -}}
    </a>
  </div>

  {%- endif -%}

</div>

{% stylesheet %}
/* ════════════════════════════════════════════════════════
   CART PAGINA — Kwispelbox
   ════════════════════════════════════════════════════════ */

/* Gedeelde knoppen (ook gebruikt door kwispelclub) */
.kc-btn {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: 'Lilita One', cursive; font-size: .95rem;
  padding: 13px 24px; border-radius: 999px;
  text-decoration: none; border: none; cursor: pointer;
  transition: transform 200ms cubic-bezier(.34,1.56,.64,1), box-shadow 160ms;
}
.kc-btn:hover { transform: translateY(-2px); }
.kc-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
.kc-btn--primary { background: #e75480; color: #fff; box-shadow: 0 4px 16px rgba(231,84,128,.28); }
.kc-btn--primary:hover { background: #c4396a; }
.kc-btn--outline-pink { background: transparent; color: #e75480; border: 1.5px solid #FFB8CD; }
.kc-btn--outline-pink:hover { background: #FFF0F5; }

/* ── Pagina layout ─────────────────────────────────────── */
.cart-page {
  max-width: 1280px;
  margin: 0 auto;
  padding: 40px 20px 80px;
}
@media(min-width: 1024px) { .cart-page { padding: 48px 60px 80px; } }

/* Koptekst */
.cart-page__header { margin-bottom: 28px; }
.cart-page__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  color: #3d2209; display: flex; align-items: center; gap: 10px; margin: 0 0 6px;
}
.cart-page__title-heart { display: flex; align-items: center; color: #e75480; }
.cart-page__title-heart svg { width: 22px; height: 22px; }
.cart-page__subtitle { font-family: 'Karla', sans-serif; font-size: .95rem; color: #A88259; margin: 0; }

/* Twee-koloms lay-out */
.cart-page__layout { display: flex; flex-direction: column; gap: 24px; }
@media(min-width: 900px) {
  .cart-page__layout { flex-direction: row; align-items: flex-start; gap: 32px; }
  .cart-page__left  { flex: 1; min-width: 0; }
  .cart-page__right { width: 340px; flex-shrink: 0; position: sticky; top: 100px; }
}

/* ── Gratis verzending balk ──────────────────────────────── */
.cart-shipping-bar {
  background: #fff;
  border-radius: 16px;
  padding: 16px 20px;
  margin-bottom: 16px;
  border: 1.5px solid #EDE2C9;
}
.cart-shipping-bar__text {
  display: flex; align-items: center; gap: 8px;
  font-family: 'Karla', sans-serif; font-size: .88rem; color: #603A15;
  margin-bottom: 10px;
}
.cart-shipping-bar__text svg { width: 18px; height: 18px; color: #66AA44; flex-shrink: 0; }
.cart-shipping-bar__text strong { color: #66AA44; }
.cart-shipping-bar__confetti { font-size: 1rem; }
.cart-shipping-bar__track {
  height: 8px; border-radius: 999px;
  background: #F8EFDD; overflow: hidden;
}
.cart-shipping-bar__fill {
  height: 100%; border-radius: 999px;
  background: linear-gradient(90deg, #66AA44, #8BC34A);
  transition: width 500ms ease;
}

/* ── Cart items ─────────────────────────────────────────── */
.cart-items {
  display: flex; flex-direction: column; gap: 0;
  background: #fff; border-radius: 20px;
  border: 1.5px solid #EDE2C9;
  overflow: hidden;
}
.cart-item {
  display: flex; gap: 16px; padding: 20px;
  border-bottom: 1.5px solid #EDE2C9;
  transition: background 200ms;
}
.cart-item:last-child { border-bottom: none; }
.cart-item:hover { background: #FEFCF8; }
.cart-item.is-loading { opacity: .5; pointer-events: none; }

.cart-item__img-link { flex-shrink: 0; }
.cart-item__img {
  width: 100px; height: 100px;
  border-radius: 14px;
  object-fit: cover; display: block;
}
.cart-item__img-ph {
  width: 100px; height: 100px;
  border-radius: 14px; background: #F8EFDD;
  display: flex; align-items: center; justify-content: center; color: #EDE2C9;
}
.cart-item__img-ph svg { width: 36px; height: 36px; }

.cart-item__info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 10px; }
.cart-item__top {
  display: flex; justify-content: space-between;
  align-items: flex-start; gap: 12px;
}
.cart-item__name {
  font-family: 'Lilita One', cursive; font-size: 1rem;
  color: #3d2209; text-decoration: none;
  display: block; margin-bottom: 2px;
}
.cart-item__name:hover { color: #e75480; }
.cart-item__variant { font-family: 'Karla', sans-serif; font-size: .78rem; color: #A88259; }
.cart-item__desc { font-family: 'Karla', sans-serif; font-size: .82rem; color: #A88259; line-height: 1.5; margin: 2px 0 0; }
.cart-item__plan-badge {
  display: inline-block; margin-top: 6px;
  background: #e8f5e2; color: #2d7a1a;
  font-family: 'Karla', sans-serif; font-size: .72rem; font-weight: 800;
  padding: 3px 10px; border-radius: 999px;
}
.cart-item__price {
  font-family: 'Lilita One', cursive; font-size: 1.05rem;
  color: #3d2209; white-space: nowrap; flex-shrink: 0;
}

.cart-item__bottom {
  display: flex; align-items: center;
  justify-content: space-between; gap: 12px;
  flex-wrap: wrap;
}
.cart-item__actions { display: flex; gap: 8px; }
.cart-item__action-btn {
  display: inline-flex; align-items: center; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 4px 0;
  font-family: 'Karla', sans-serif; font-size: .78rem; font-weight: 700;
  color: #A88259; transition: color 160ms;
}
.cart-item__action-btn svg { width: 13px; height: 13px; }
.cart-item__action-btn:hover { color: #603A15; }
.cart-item__action-btn--remove:hover { color: #c4396a; }

.cart-item__qty {
  display: flex; align-items: center; gap: 0;
  border: 1.5px solid #EDE2C9; border-radius: 999px;
  overflow: hidden; background: #fff;
}
.cart-item__qty-btn {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  background: none; border: none; cursor: pointer; color: #603A15;
  transition: background 160ms;
}
.cart-item__qty-btn:hover { background: #F8EFDD; }
.cart-item__qty-num {
  min-width: 28px; text-align: center;
  font-family: 'Lilita One', cursive; font-size: .9rem; color: #3d2209;
}

/* ── Upsell banner ──────────────────────────────────────── */
.cart-upsell-banner {
  display: flex; align-items: center; gap: 14px;
  background: #FFF0F5; border: 1.5px solid #FFB8CD;
  border-radius: 16px; padding: 16px 20px;
  margin-top: 16px; flex-wrap: wrap;
}
.cart-upsell-banner__icon {
  width: 44px; height: 44px; border-radius: 50%;
  background: #ffe0ee; color: #e75480;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.cart-upsell-banner__icon svg { width: 20px; height: 20px; }
.cart-upsell-banner__copy { flex: 1; }
.cart-upsell-banner__copy strong {
  display: block; font-family: 'Lilita One', cursive;
  font-size: .95rem; color: #3d2209;
}
.cart-upsell-banner__copy span {
