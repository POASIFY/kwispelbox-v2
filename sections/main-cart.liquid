{% javascript %}
(function () {
  'use strict';

  const section   = document.querySelector('[data-cart-section]');
  if (!section) return;

  // ── Helpers ────────────────────────────────────────────
  function money(cents) {
    return '€' + (cents / 100).toFixed(2).replace('.', ',');
  }

  async function cartRequest(url, body) {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify(body)
    });
    return res.json();
  }

  async function getCart() {
    const res = await fetch('/cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    return res.json();
  }

  function setLoading(key, state) {
    const el = section.querySelector(`[data-item-key="${key}"]`);
    if (el) el.classList.toggle('is-loading', state);
  }

  // ── Totalen bijwerken ────────────────────────────────────
  function updateTotals(cart) {
    const total     = section.querySelector('[data-total]');
    const subtotal  = section.querySelector('[data-subtotal]');
    const shippingEl = section.querySelector('[data-shipping]');
    const threshold  = parseInt(section.dataset.freeThreshold || '7500', 10);

    if (total)    total.textContent    = money(cart.total_price);
    if (subtotal) subtotal.textContent = money(cart.total_price);

    if (shippingEl) {
      shippingEl.innerHTML = cart.total_price >= threshold
        ? '<span style="color:#66AA44;font-weight:800">Gratis</span>'
        : 'Berekend bij afrekenen';
    }

    // Kwispels
    const kwispelsEl = section.querySelector('[data-kwispels-earn] .cart-kwispels__amount');
    if (kwispelsEl) {
      kwispelsEl.textContent = Math.floor(cart.total_price / 100) + ' kwispels';
    }

    updateShippingBar(cart.total_price, threshold);
  }

  function updateShippingBar(totalCents, thresholdCents) {
    const bar  = section.querySelector('.cart-shipping-bar__fill');
    const text = section.querySelector('.cart-shipping-bar__text');
    if (!bar || !text) return;

    const pct       = Math.min(100, Math.round(totalCents / thresholdCents * 100));
    bar.style.width = pct + '%';

    if (totalCents >= thresholdCents) {
      text.innerHTML = `
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect width="16" height="13" x="1" y="3" rx="2"/><path d="M1 9h22"/><path d="M14 9v8"/></svg>
        <span>Gefeliciteerd! Je verzending is gratis 🎉</span>`;
    } else {
      const rem = money(thresholdCents - totalCents);
      text.innerHTML = `
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect width="16" height="13" x="1" y="3" rx="2"/><path d="M1 9h22"/><path d="M14 9v8"/></svg>
        <span>Nog maar <strong>${rem}</strong> voor gratis verzending</span>`;
    }
  }

  // ── Item aantallen aanpassen ─────────────────────────────
  async function changeQty(key, delta) {
    setLoading(key, true);
    const qtyEl   = section.querySelector(`[data-qty="${key}"]`);
    const current = parseInt(qtyEl?.textContent || '1', 10);
    const newQty  = Math.max(0, current + delta);

    const cart = await cartRequest('/cart/change.js', { id: key, quantity: newQty });

    if (newQty === 0) {
      const itemEl = section.querySelector(`[data-item-key="${key}"]`);
      if (itemEl) itemEl.remove();
      if (!cart.items.length) location.reload();
    } else {
      if (qtyEl) qtyEl.textContent = newQty;
    }

    updateTotals(cart);
    setLoading(key, false);
  }

  // ── Item verwijderen ─────────────────────────────────────
  async function removeItem(key) {
    setLoading(key, true);
    const cart = await cartRequest('/cart/change.js', { id: key, quantity: 0 });
    const itemEl = section.querySelector(`[data-item-key="${key}"]`);
    if (itemEl) itemEl.remove();
    if (!cart.items.length) location.reload();
    updateTotals(cart);
  }

  // ── Product toevoegen (upsell / aanbeveling) ─────────────
  async function addProduct(variantId, btn) {
    btn.disabled = true;
    btn.textContent = '✓ Toegevoegd';
    const cart = await cartRequest('/cart/add.js', { id: parseInt(variantId, 10), quantity: 1 });
    updateTotals(await getCart());
    setTimeout(() => { btn.disabled = false; btn.textContent = '+ Toevoegen'; }, 2000);
  }

  // ── Event delegation ─────────────────────────────────────
  section.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-action]');
    if (!btn) return;

    const action = btn.dataset.action;
    const key    = btn.dataset.itemKey;

    if (action === 'increase')    changeQty(key, 1);
    if (action === 'decrease')    changeQty(key, -1);
    if (action === 'remove-item') removeItem(key);
    if (action === 'add-upsell' || action === 'add-product') {
      addProduct(btn.dataset.variantId, btn);
    }
  });

  // ── Slider navigatie ─────────────────────────────────────
  const track    = section.querySelector('.cart-recs__track');
  const prevBtn  = section.querySelector('.cart-recs__nav--prev');
  const nextBtn  = section.querySelector('.cart-recs__nav--next');
  const CARD_W   = 174;
  if (track && prevBtn && nextBtn) {
    prevBtn.addEventListener('click', () => track.scrollBy({ left: -CARD_W * 2, behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => track.scrollBy({ left: CARD_W * 2, behavior: 'smooth' }));
  }

})();
{% endjavascript %}

