<section class="ugc">

  <!-- Header ───────────────────────────────────────────── -->
  <div class="ugc__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ugc__eyebrow">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}
    <h2 class="ugc__title">{{ section.settings.title }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="ugc__sub">
        {{ section.settings.subtitle_plain }}
        <span class="ugc__sub-accent">{{ section.settings.subtitle_accent }}</span>
      </p>
    {%- endif -%}
  </div>

  <!-- Foto grid ────────────────────────────────────────── -->
  {%- assign photo_blocks = section.blocks | where: 'type', 'photo' -%}
  {%- if photo_blocks.size > 0 -%}
    <div class="ugc__grid-wrap">
      <div class="ugc__grid">
        {%- for block in photo_blocks -%}
          <div class="ugc__photo ugc__photo--{{ block.settings.size }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                        {{ block.settings.image | image_url: width: 600 }} 600w,
                        {{ block.settings.image | image_url: width: 800 }} 800w"
                sizes="(max-width: 767px) 45vw, 20vw"
                alt="{{ block.settings.dog_name | default: 'Blije hond' | escape }}"
                width="600" height="600"
                loading="lazy"
                class="ugc__img"
              >
            {%- else -%}
              <div class="ugc__img-ph">
                {{- 'icon-paw.svg' | inline_asset_content -}}
              </div>
            {%- endif -%}
            {%- if block.settings.dog_name != blank -%}
              <div class="ugc__name">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                {{ block.settings.dog_name }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <!-- Onderste CTA strip ───────────────────────────────── -->
  <div class="ugc__strip">
    <div class="ugc__strip-inner">

      <!-- Links: uitnodiging -->
      <div class="ugc__strip-invite">
        <span class="ugc__strip-cam" aria-hidden="true">
          {{- 'icon-camera.svg' | inline_asset_content -}}
        </span>
        <div class="ugc__strip-copy">
          <strong>{{ section.settings.invite_title }}</strong>
          <span>
            Tag <span class="ugc__strip-handle">{{ section.settings.handle }}</span>
            en gebruik <span class="ugc__strip-hash">{{ section.settings.hashtag }}</span>
            {{ section.settings.invite_suffix }}
          </span>
        </div>
      </div>

      <!-- Midden: avatars + teller -->
      <div class="ugc__strip-count">
        {%- assign avatar_blocks = section.blocks | where: 'type', 'avatar' -%}
        {%- if avatar_blocks.size > 0 -%}
          <div class="ugc__avatars">
            {%- for block in avatar_blocks limit: 5 -%}
              <div class="ugc__avatar" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 80 }}"
                       alt="" width="40" height="40" loading="lazy">
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <span class="ugc__count-num">{{ section.settings.count_label }}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" style="color:#e75480"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      </div>

      <!-- Rechts: CTA knop -->
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url }}" class="ugc__cta">
          {{ section.settings.cta_label }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      {%- endif -%}

    </div>
  </div>

</section>

{% stylesheet %}
/* ── Sectie ─────────────────────────────────────────────── */
.ugc {
  background: #F8EFDD;
  padding: 80px 0 0;
  overflow: hidden;
}

/* ── Header ─────────────────────────────────────────────── */
.ugc__header {
  text-align: center;
  padding: 0 20px;
  margin-bottom: 48px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.ugc__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: 'Karla', sans-serif;
  font-size: .8rem;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #e75480;
}
.ugc__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  color: #3d2209;
  line-height: 1;
}
.ugc__sub {
  font-family: 'Karla', sans-serif;
  font-size: 1.05rem;
  color: #A88259;
  line-height: 1.65;
  max-width: 60ch;
}
.ugc__sub-accent {
  color: #F7A048;
  font-weight: 800;
}

/* ── Foto grid ──────────────────────────────────────────── */
.ugc__grid-wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}
@media(min-width: 1200px) {
  .ugc__grid-wrap { padding: 0 40px; }
}

.ugc__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: auto auto;
  gap: 12px;
}

/* Mobiel: 2 kolommen */
@media(max-width: 767px) {
  .ugc__grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
}

/* Grootte varianten */
.ugc__photo--wide { grid-column: span 2; }
.ugc__photo--tall { grid-row: span 2; }
.ugc__photo--normal { grid-column: span 1; }

/* Foto */
.ugc__photo {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  background: #EDE2C9;
  cursor: pointer;
  min-height: 200px;
}
@media(max-width: 767px) {
  .ugc__photo--wide { grid-column: span 1; }
  .ugc__photo--tall { grid-row: span 1; }
  .ugc__photo { border-radius: 14px; min-height: 160px; }
}

.ugc__img {
  width: 100%;
  height: 100%;
  min-height: 200px;
  object-fit: cover;
  display: block;
  transition: transform 400ms ease;
}
.ugc__photo:hover .ugc__img { transform: scale(1.05); }
.ugc__img-ph {
  width: 100%; height: 100%; min-height: 220px;
  display: flex; align-items: center; justify-content: center;
  color: #DAC9A1;
}
.ugc__img-ph svg { width: 40px; height: 40px; }

/* Naam label */
.ugc__name {
  position: absolute;
  bottom: 10px; left: 10px;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: 'Karla', sans-serif;
  font-size: .75rem;
  font-weight: 700;
  color: #fff;
  background: rgba(61,34,9,.55);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  border-radius: 999px;
  padding: 4px 12px;
  border: 1px solid rgba(255,255,255,.2);
}
.ugc__name svg { color: #e75480; flex-shrink: 0; }

/* ── Strip ──────────────────────────────────────────────── */
.ugc__strip {
  background: #EDE2C9;
  margin-top: 48px;
  border-top: 1.5px solid #DAC9A1;
}
.ugc__strip-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 24px 20px;
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}
@media(min-width: 1024px) { .ugc__strip-inner { padding: 24px 60px; flex-wrap: nowrap; } }

/* Invite */
.ugc__strip-invite {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  flex: 1;
  min-width: 240px;
}
.ugc__strip-cam {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: #e8f5e2;
  color: #66AA44;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.ugc__strip-cam svg { width: 22px; height: 22px; }
.ugc__strip-copy { display: flex; flex-direction: column; gap: 4px; }
.ugc__strip-copy strong {
  font-family: 'Lilita One', cursive;
  font-size: 1rem;
  color: #3d2209;
}
.ugc__strip-copy span {
  font-family: 'Karla', sans-serif;
  font-size: .85rem;
  color: #A88259;
  line-height: 1.5;
}
.ugc__strip-handle { color: #F7A048; font-weight: 700; }
.ugc__strip-hash   { color: #F7A048; font-weight: 700; }

/* Teller */
.ugc__strip-count {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}
.ugc__avatars { display: flex; }
.ugc__avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  border: 2.5px solid #EDE2C9;
  overflow: hidden;
  background: #DAC9A1;
  margin-left: -10px;
}
.ugc__avatar:first-child { margin-left: 0; }
.ugc__avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
.ugc__count-num {
  font-family: 'Lilita One', cursive;
  font-size: 1.1rem;
  color: #3d2209;
  white-space: nowrap;
}

/* CTA knop */
.ugc__cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Lilita One', cursive;
  font-size: 1rem;
  background: #66AA44;
  color: #fff;
  padding: 14px 28px;
  border-radius: 999px;
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(102,170,68,.35);
  transition: background 160ms, transform 200ms cubic-bezier(.34,1.56,.64,1);
}
.ugc__cta:hover { background: #4d8833; transform: translateY(-2px); }

/* Mobiel strip */
@media(max-width: 767px) {
  .ugc__strip-count { display: none; }
  .ugc__cta { width: 100%; justify-content: center; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Social proof",
  "tag": "section",
  "blocks": [
    {
      "type": "photo",
      "name": "Hondenfoto",
      "settings": [
        {"type":"image_picker","id":"image","label":"Foto"},
        {"type":"text","id":"dog_name","label":"Naam hond","default":"Luna"},
        {
          "type": "select","id": "size","label": "Formaat","default": "normal",
          "options": [
            {"value":"normal","label":"Normaal"},
            {"value":"wide","label":"Breed (2 kolommen)"},
            {"value":"tall","label":"Hoog (2 rijen)"}
          ]
        }
      ]
    },
    {
      "type": "avatar",
      "name": "Avatar",
      "settings": [
        {"type":"image_picker","id":"image","label":"Profielfoto"}
      ]
    }
  ],
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Een community vol kwispelende staarten"},
    {"type":"text","id":"title","label":"Titel","default":"Meer dan 1.200 blije honden."},
    {"type":"text","id":"subtitle_plain","label":"Subtitel (normaal deel)","default":"Elke dag maken we honden (en hun baasjes) blij met een verrassingsbox vol speelplezier. Dit is onze "},
    {"type":"text","id":"subtitle_accent","label":"Subtitel (oranje deel)","default":"Kwispelbox community!"},
    {"type":"text","id":"invite_title","label":"Uitnodiging titel","default":"Deel ook jouw moment!"},
    {"type":"text","id":"handle","label":"Instagram handle","default":"@kwispelbox.nl"},
    {"type":"text","id":"hashtag","label":"Hashtag","default":"#kwispelbox"},
    {"type":"text","id":"invite_suffix","label":"Uitnodiging staart","default":"voor een kans om uitgelicht te worden!"},
    {"type":"text","id":"count_label","label":"Teller label","default":"+1.200"},
    {"type":"text","id":"cta_label","label":"CTA tekst","default":"Bekijk alle blije honden"},
    {"type":"url","id":"cta_url","label":"CTA link"}
  ],
  "presets": [{
    "name": "Social proof",
    "blocks": [
      {"type":"photo","settings":{"dog_name":"Luna","size":"wide"}},
      {"type":"photo","settings":{"dog_name":"Bobby","size":"normal"}},
      {"type":"photo","settings":{"dog_name":"Milo","size":"normal"}},
      {"type":"photo","settings":{"dog_name":"Nala","size":"normal"}},
      {"type":"photo","settings":{"dog_name":"Boris","size":"normal"}},
      {"type":"photo","settings":{"dog_name":"Pip","size":"normal"}},
      {"type":"photo","settings":{"dog_name":"Max","size":"tall"}},
      {"type":"photo","settings":{"dog_name":"Teddy","size":"normal"}},
      {"type":"photo","settings":{"dog_name":"Charlie","size":"normal"}},
      {"type":"avatar"},{"type":"avatar"},{"type":"avatar"},
      {"type":"avatar"},{"type":"avatar"}
    ]
  }]
}
{% endschema %}
