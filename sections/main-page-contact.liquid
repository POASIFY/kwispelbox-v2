{% comment %}
  Kwispelbox — Contact / Klantenservice pagina
  Hero is full-width (directe child van .shopify-section); de rest staat in
  een begrensde container. Alles instelbaar via Theme Editor.
{% endcomment %}

{%- comment -%} ── HERO (volle breedte, foto als achtergrond) ── {%- endcomment -%}
{%- if section.settings.hero_title_1 != blank or section.settings.hero_image != blank -%}
  <div class="pc__hero full-width">

    {%- if section.settings.hero_image != blank -%}
      {{ section.settings.hero_image | image_url: width: 2400 | image_tag:
         widths: '800, 1200, 1600, 2000, 2400', sizes: '100vw',
         loading: 'eager', fetchpriority: 'high',
         class: 'pc__hero-img', alt: section.settings.hero_title_1 | escape }}
    {%- else -%}
      <div class="pc__hero-img pc__hero-img--placeholder">{{ 'image' | placeholder_svg_tag: 'pc__placeholder' }}</div>
    {%- endif -%}

    <div class="pc__hero-overlay" aria-hidden="true"></div>

    <div class="pc__hero-content">
      <h1 class="pc__hero-heading">
        {{ section.settings.hero_title_1 }}
        {%- if section.settings.hero_title_2 != blank -%}
          <span class="pc__hero-heading-accent">{{ section.settings.hero_title_2 }}</span>
          <span class="pc__hero-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
        {%- endif -%}
      </h1>
      {%- if section.settings.hero_body != blank -%}
        <p class="pc__hero-body">{{ section.settings.hero_body }}</p>
      {%- endif -%}

      <ul class="pc__hero-usps" role="list">
        {%- if section.settings.usp_1_title != blank -%}
          <li class="pc__hero-usp">
            <span class="pc__hero-usp-icon pc__hero-usp-icon--green" aria-hidden="true">{{- 'icon-mail.svg' | inline_asset_content -}}</span>
            <span class="pc__hero-usp-text">
              <strong>{{ section.settings.usp_1_title }}</strong>
              {%- if section.settings.usp_1_body != blank -%}<span>{{ section.settings.usp_1_body }}</span>{%- endif -%}
            </span>
          </li>
        {%- endif -%}
        {%- if section.settings.usp_2_title != blank -%}
          <li class="pc__hero-usp">
            <span class="pc__hero-usp-icon pc__hero-usp-icon--yellow" aria-hidden="true">{{- 'icon-refresh.svg' | inline_asset_content -}}</span>
            <span class="pc__hero-usp-text">
              <strong>{{ section.settings.usp_2_title }}</strong>
              {%- if section.settings.usp_2_body != blank -%}<span>{{ section.settings.usp_2_body }}</span>{%- endif -%}
            </span>
          </li>
        {%- endif -%}
      </ul>
    </div>
  </div>
{%- endif -%}

{% render 'breadcrumbs', overlay: true %}

<div class="pc full-width">

  {%- comment -%} ── HULP-KAARTEN ─────────────────────────────── {%- endcomment -%}
  {%- assign help_blocks = section.blocks | where: 'type', 'help_card' -%}
  {%- if section.settings.help_title != blank or help_blocks.size > 0 -%}
    <div class="pc__help">
      {%- if section.settings.help_title != blank -%}
        <h2 class="pc__section-title">
          <span class="pc__title-dash" aria-hidden="true"></span>
          {{ section.settings.help_title }}
          <span class="pc__title-dash" aria-hidden="true"></span>
        </h2>
      {%- endif -%}
      {%- if section.settings.help_subtitle != blank -%}
        <p class="pc__section-sub">{{ section.settings.help_subtitle }}</p>
      {%- endif -%}

      {%- if help_blocks.size > 0 -%}
        <div class="pc__help-grid">
          {%- for block in help_blocks -%}
            <div class="pc__card" {{ block.shopify_attributes }}>
              <span class="pc__card-icon pc__card-icon--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <h3 class="pc__card-title">{{ block.settings.title }}</h3>
              {%- if block.settings.body != blank -%}
                <p class="pc__card-body">{{ block.settings.body }}</p>
              {%- endif -%}
              {%- if block.settings.link_text != blank -%}
                <a href="{{ block.settings.link_url | default: '#' }}" class="pc__card-link pc__card-link--{{ block.settings.color }}">
                  {{ block.settings.link_text }}
                  <span class="pc__card-arrow" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
                </a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── FORMULIER + CONTACTGEGEVENS ──────────────── {%- endcomment -%}
  <div class="pc__contact">

    <div class="pc__form-wrap">
      <h2 class="pc__form-title">
        {{ section.settings.form_title | default: 'Stuur ons een bericht' }}
        <span class="pc__form-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
      </h2>
      {%- if section.settings.form_subtitle != blank -%}
        <p class="pc__form-sub">{{ section.settings.form_subtitle }}</p>
      {%- endif -%}

      {%- form 'contact', id: 'PcContactForm', class: 'pc__form' -%}
        {%- if form.posted_successfully? -%}
          <div class="pc__form-success" role="status">
            <span class="pc__form-success-icon" aria-hidden="true">{{- 'icon-check-circle.svg' | inline_asset_content -}}</span>
            {{ section.settings.form_success | default: 'Bedankt! We hebben je bericht ontvangen en reageren zo snel mogelijk.' }}
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="pc__form-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="pc__form-row">
          <div class="pc__field">
            <label class="pc__sr-only" for="PcName">Naam</label>
            <input type="text" id="PcName" name="contact[name]" class="pc__input"
                   placeholder="Naam" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" required>
          </div>
          <div class="pc__field">
            <label class="pc__sr-only" for="PcEmail">E-mailadres</label>
            <input type="email" id="PcEmail" name="contact[email]" class="pc__input"
                   placeholder="E-mailadres" autocomplete="email" autocorrect="off" autocapitalize="off"
                   value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required>
          </div>
        </div>

        {%- if section.settings.form_show_subject -%}
          <div class="pc__field">
            <label class="pc__sr-only" for="PcSubject">Onderwerp</label>
            <div class="pc__select-wrap">
              <select id="PcSubject" name="contact[Onderwerp]" class="pc__input pc__select">
                <option value="" disabled selected>Kies een onderwerp</option>
                <option value="Vraag over mijn bestelling">Ik heb een vraag over mijn bestelling</option>
                <option value="Vraag over een product">Ik heb een vraag over een product</option>
                <option value="Advies voor mijn hond">Ik wil advies voor mijn hond</option>
                <option value="Vraag over een Kwispelbox">Ik heb een vraag over een Kwispelbox</option>
                <option value="Retourneren">Ik wil retourneren</option>
                <option value="Accountvraag">Ik heb een accountvraag</option>
                <option value="Samenwerken">Ik wil samenwerken</option>
                <option value="Iets anders">Iets anders</option>
              </select>
              <span class="pc__select-chevron" aria-hidden="true">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</span>
            </div>
          </div>
        {%- endif -%}

        <div class="pc__field">
          <label class="pc__sr-only" for="PcBody">Je bericht</label>
          <textarea id="PcBody" name="contact[body]" class="pc__input pc__textarea"
                    placeholder="Je bericht" rows="5" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>

        <button type="submit" class="pc__submit">
          {{ section.settings.form_button | default: 'Bericht versturen' }}
          <span class="pc__submit-arrow" aria-hidden="true">{{- 'icon-play.svg' | inline_asset_content -}}</span>
        </button>

        {%- if section.settings.form_footnote != blank -%}
          <p class="pc__form-footnote">{{ section.settings.form_footnote }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>

    {%- comment -%} Contactgegevens (blocks van type info_item) {%- endcomment -%}
    {%- assign info_blocks = section.blocks | where: 'type', 'info_item' -%}
    {%- if section.settings.info_title != blank or info_blocks.size > 0 -%}
      <aside class="pc__info">
        {%- if section.settings.info_title != blank -%}
          <h2 class="pc__info-title">{{ section.settings.info_title }}</h2>
        {%- endif -%}

        {%- for block in info_blocks -%}
          <div class="pc__info-item" {{ block.shopify_attributes }}>
            <span class="pc__info-icon pc__info-icon--{{ block.settings.color }}" aria-hidden="true">
              {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
            </span>
            <div class="pc__info-text">
              <strong>{{ block.settings.title }}</strong>
              {%- if block.settings.body != blank -%}
                <span>{{ block.settings.body }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}

        {%- if section.settings.show_socials -%}
          <div class="pc__socials">
            {%- if section.settings.instagram_url != blank -%}
              <a href="{{ section.settings.instagram_url }}" class="pc__social" aria-label="Instagram" target="_blank" rel="noopener">{{- 'icon-instagram.svg' | inline_asset_content -}}</a>
            {%- endif -%}
            {%- if section.settings.facebook_url != blank -%}
              <a href="{{ section.settings.facebook_url }}" class="pc__social" aria-label="Facebook" target="_blank" rel="noopener">{{- 'icon-heart.svg' | inline_asset_content -}}</a>
            {%- endif -%}
            {%- if section.settings.tiktok_url != blank -%}
              <a href="{{ section.settings.tiktok_url }}" class="pc__social" aria-label="TikTok" target="_blank" rel="noopener">{{- 'icon-play.svg' | inline_asset_content -}}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </aside>
    {%- endif -%}
  </div>

  {%- comment -%} ── OVER-STRIP ───────────────────────────────── {%- endcomment -%}
  {%- if section.settings.about_title != blank -%}
    <div class="pc__about">
      {%- if section.settings.about_image != blank -%}
        <span class="pc__about-media">
          {{ section.settings.about_image | image_url: width: 600 | image_tag:
             widths: '300, 600', sizes: '300px', loading: 'lazy',
             class: 'pc__about-img', alt: section.settings.about_title | escape }}
        </span>
      {%- endif -%}
      <div class="pc__about-text">
        <h2 class="pc__about-title">{{ section.settings.about_title }}</h2>
        {%- if section.settings.about_body != blank -%}
          <p class="pc__about-body">{{ section.settings.about_body }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.about_badge != blank -%}
        <span class="pc__about-badge" aria-hidden="true">
          <span class="pc__about-badge-heart">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
          {{ section.settings.about_badge }}
        </span>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── TRUST-BAR ────────────────────────────────── {%- endcomment -%}
  {%- assign trust_blocks = section.blocks | where: 'type', 'trust_item' -%}
  {%- if trust_blocks.size > 0 -%}
    <ul class="pc__trust" role="list">
      {%- for block in trust_blocks -%}
        <li class="pc__trust-item" {{ block.shopify_attributes }}>
          <span class="pc__trust-icon pc__trust-icon--{{ block.settings.color }}" aria-hidden="true">
            {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
          </span>
          <span class="pc__trust-text">
            <strong>{{ block.settings.title }}</strong>
            {%- if block.settings.body != blank -%}<span>{{ block.settings.body }}</span>{%- endif -%}
          </span>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

</div>

{% stylesheet %}
.pc{max-width:1200px;margin:0 auto;padding:0 20px 60px;font-family:'Karla',sans-serif}
.pc__sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

/* Hero — volle breedte, foto als achtergrond */
.pc__hero{position:relative;width:100%;min-height:360px;overflow:hidden;display:flex;align-items:center;background:#F4E7D0}
.pc__hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:right center;display:block}
.pc__hero-img--placeholder{background:#EDE2C9;display:flex;align-items:center;justify-content:center}
.pc__hero-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(244,231,208,.45) 0%,rgba(244,231,208,.8) 50%,rgba(244,231,208,.97) 78%)}
.pc__hero-content{position:relative;z-index:2;width:100%;max-width:1280px;margin:0 auto;padding:36px 24px 40px;display:flex;flex-direction:column;gap:18px}
.pc__hero-heading{font-family:'Lilita One',cursive;font-size:clamp(2.4rem,6vw,4.5rem);line-height:1.05;color:#3d2209;margin:0;max-width:16ch}
.pc__hero-heading-accent{color:#66AA44;display:inline}
.pc__hero-heart{display:inline-flex;color:#FFB8CD;vertical-align:middle;margin-left:6px}
.pc__hero-heart svg{width:30px;height:30px}
.pc__hero-body{font-size:1.05rem;color:#603A15;margin:0;line-height:1.5;max-width:42ch}
.pc__hero-usps{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:16px}
.pc__hero-usp{display:flex;align-items:center;gap:14px}
.pc__hero-usp-icon{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#fff}
.pc__hero-usp-icon svg{width:22px;height:22px}
.pc__hero-usp-icon--green{background:#66AA44}
.pc__hero-usp-icon--yellow{background:#FFC83D}
.pc__hero-usp-text{display:flex;flex-direction:column;gap:1px}
.pc__hero-usp-text strong{font-size:1rem;font-weight:800;color:#3d2209}
.pc__hero-usp-text span{font-size:.9rem;color:#603A15}

/* Sectie-titels */
.pc__section-title{font-family:'Lilita One',cursive;font-size:clamp(2rem,5vw,3.4rem);color:#3d2209;text-align:center;margin:0;display:flex;align-items:center;justify-content:center;gap:14px}
.pc__title-dash{width:26px;height:3px;background:#66AA44;border-radius:3px;display:inline-block}
.pc__section-sub{text-align:center;color:#A88259;font-size:1rem;margin:8px 0 0}

/* Hulp-kaarten */
.pc__help{margin-top:48px}
.pc__help-grid{margin-top:28px;display:grid;grid-template-columns:1fr;gap:16px}
.pc__card{background:#FBF3E4;border-radius:22px;padding:26px 22px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:10px;transition:transform 200ms cubic-bezier(.34,1.56,.64,1),box-shadow 200ms}
.pc__card:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(96,58,21,.1)}
.pc__card-icon{width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0}
.pc__card-icon svg{width:30px;height:30px}
.pc__card-icon--green{background:#66AA44}
.pc__card-icon--orange{background:#F7A048}
.pc__card-icon--pink{background:#FF8FB3}
.pc__card-icon--brown{background:#A88259}
.pc__card-icon--yellow{background:#FFC83D}
.pc__card-title{font-family:'Lilita One',cursive;font-size:1.2rem;color:#3d2209;margin:6px 0 0}
.pc__card-body{font-size:.92rem;color:#603A15;margin:0;line-height:1.45}
.pc__card-link{display:inline-flex;align-items:center;gap:5px;margin-top:6px;font-weight:800;font-size:.92rem;text-decoration:none}
.pc__card-link--green{color:#4d8833}
.pc__card-link--orange{color:#d9823a}
.pc__card-link--pink{color:#e75480}
.pc__card-link--brown{color:#A88259}
.pc__card-link--yellow{color:#c49000}
.pc__card-arrow{display:flex;transform:rotate(-90deg)}
.pc__card-arrow svg{width:14px;height:14px}

/* Contact: formulier + info */
.pc__contact{margin-top:48px;display:grid;grid-template-columns:1fr;gap:24px}
.pc__form-wrap{background:#FBF3E4;border-radius:24px;padding:28px 24px}
.pc__form-title{font-family:'Lilita One',cursive;font-size:clamp(1.6rem,3vw,2rem);color:#3d2209;margin:0;display:flex;align-items:center;gap:8px}
.pc__form-heart{display:inline-flex;color:#FFB8CD}
.pc__form-heart svg{width:22px;height:22px}
.pc__form-sub{color:#A88259;font-size:.95rem;margin:6px 0 20px}
.pc__form{display:flex;flex-direction:column;gap:14px}
.pc__form-row{display:grid;grid-template-columns:1fr;gap:14px}
.pc__field{display:flex;flex-direction:column}
.pc__input{width:100%;box-sizing:border-box;font-family:'Karla',sans-serif;font-size:.95rem;color:#3d2209;background:#fff;border:2px solid #EDE2C9;border-radius:14px;padding:14px 16px;transition:border-color 180ms,box-shadow 180ms}
.pc__input::placeholder{color:#A88259}
.pc__input:focus{outline:none;border-color:#66AA44;box-shadow:0 0 0 3px rgba(102,170,68,.15)}
.pc__textarea{resize:vertical;min-height:120px;line-height:1.5}
.pc__select-wrap{position:relative}
.pc__select{appearance:none;-webkit-appearance:none;cursor:pointer;padding-right:44px}
.pc__select-chevron{position:absolute;right:16px;top:50%;transform:translateY(-50%);display:flex;color:#A88259;pointer-events:none}
.pc__select-chevron svg{width:16px;height:16px}
.pc__submit{display:inline-flex;align-items:center;justify-content:center;gap:10px;width:100%;background:#66AA44;color:#fff;font-family:'Lilita One',cursive;font-size:1.05rem;border:none;border-radius:999px;padding:16px 24px;cursor:pointer;transition:background 160ms,transform 200ms cubic-bezier(.34,1.56,.64,1)}
.pc__submit:hover{background:#4d8833;transform:translateY(-2px)}
.pc__submit-arrow{display:flex}
.pc__submit-arrow svg{width:16px;height:16px}
.pc__form-footnote{text-align:center;color:#A88259;font-size:.85rem;margin:4px 0 0}
.pc__form-success{display:flex;align-items:center;gap:10px;background:#e8f5e2;color:#3d6b1f;border-radius:14px;padding:14px 16px;font-weight:700;font-size:.95rem}
.pc__form-success-icon{display:flex;color:#66AA44;flex-shrink:0}
.pc__form-success-icon svg{width:22px;height:22px}
.pc__form-errors{background:#fff0f0;color:#a83232;border-radius:14px;padding:14px 16px;font-size:.9rem}

/* Contactgegevens */
.pc__info{background:#FBF3E4;border-radius:24px;padding:28px 24px;display:flex;flex-direction:column;gap:20px}
.pc__info-title{font-family:'Lilita One',cursive;font-size:1.3rem;color:#3d2209;margin:0}
.pc__info-item{display:flex;align-items:flex-start;gap:14px}
.pc__info-icon{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0}
.pc__info-icon svg{width:20px;height:20px}
.pc__info-icon--green{background:#66AA44}
.pc__info-icon--orange{background:#F7A048}
.pc__info-icon--pink{background:#FF8FB3}
.pc__info-icon--yellow{background:#FFC83D}
.pc__info-icon--brown{background:#A88259}
.pc__info-text{display:flex;flex-direction:column;gap:2px}
.pc__info-text strong{font-size:1rem;font-weight:800;color:#3d2209}
.pc__info-text span{font-size:.9rem;color:#A88259;line-height:1.4}
.pc__socials{display:flex;gap:10px;margin-top:2px}
.pc__social{width:40px;height:40px;border-radius:50%;background:#3d2209;color:#fff;display:flex;align-items:center;justify-content:center;text-decoration:none;transition:transform 200ms cubic-bezier(.34,1.56,.64,1)}
.pc__social:hover{transform:translateY(-3px)}
.pc__social svg{width:18px;height:18px}

/* Over-strip */
.pc__about{position:relative;margin-top:40px;background:#F4E7D0;border-radius:26px;padding:24px;display:flex;flex-direction:column;gap:16px;align-items:flex-start}
.pc__about-media{width:100%;border-radius:18px;overflow:hidden;display:block}
.pc__about-img{width:100%;height:auto;display:block;object-fit:cover}
.pc__about-title{font-family:'Lilita One',cursive;font-size:1.4rem;color:#3d2209;margin:0}
.pc__about-body{font-size:.95rem;color:#603A15;margin:6px 0 0;line-height:1.5}
.pc__about-badge{display:inline-flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;width:104px;height:104px;background:#66AA44;color:#fff;border-radius:50%;font-family:'Lilita One',cursive;font-size:.85rem;text-align:center;line-height:1.1;padding:10px;align-self:center}
.pc__about-badge-heart{display:flex}
.pc__about-badge-heart svg{width:22px;height:22px}

/* Trust-bar */
.pc__trust{list-style:none;margin:32px 0 0;padding:24px;display:grid;grid-template-columns:1fr 1fr;gap:20px;border-top:1px solid #EDE2C9}
.pc__trust-item{display:flex;align-items:center;gap:12px}
.pc__trust-icon{display:flex;flex-shrink:0}
.pc__trust-icon svg{width:30px;height:30px}
.pc__trust-icon--green{color:#66AA44}
.pc__trust-icon--orange{color:#F7A048}
.pc__trust-icon--pink{color:#FF8FB3}
.pc__trust-icon--yellow{color:#FFC83D}
.pc__trust-icon--brown{color:#A88259}
.pc__trust-text{display:flex;flex-direction:column;gap:1px}
.pc__trust-text strong{font-size:.95rem;font-weight:800;color:#3d2209}
.pc__trust-text span{font-size:.82rem;color:#A88259}

/* Desktop */
@media(min-width:768px){
  .pc__hero{min-height:520px}
  .pc__hero-overlay{background:linear-gradient(90deg,rgba(244,231,208,.95) 0%,rgba(244,231,208,.88) 32%,rgba(244,231,208,.5) 56%,rgba(244,231,208,0) 80%)}
  .pc__hero-content{padding:64px 60px;max-width:1280px}
  .pc__help-grid{grid-template-columns:repeat(4,1fr)}
  .pc__contact{grid-template-columns:1.6fr 1fr;align-items:start}
  .pc__form-wrap{padding:36px 32px}
  .pc__form-row{grid-template-columns:1fr 1fr}
  .pc__about{flex-direction:row;align-items:center;padding:24px 32px;gap:28px}
  .pc__about-media{width:240px;flex-shrink:0}
  .pc__about-text{flex:1}
  .pc__about-badge{flex-shrink:0;width:120px;height:120px}
  .pc__trust{grid-template-columns:repeat(4,1fr);gap:24px}
}

@media(max-width:767px){
  .pc__hero{flex-direction:column;align-items:stretch;min-height:unset;background:#F4E7D0}
  .pc__hero-img{position:relative;inset:auto;width:100%;height:auto;aspect-ratio:4/3;display:block}
  .pc__hero-img--placeholder{aspect-ratio:4/3}
  .pc__hero-overlay{display:none}
  .pc__hero-content{position:static;background:#F4E7D0;padding:24px 20px 30px}
}

@media(prefers-reduced-motion:reduce){
  .pc__card,.pc__submit,.pc__social{transition:none}
  .pc__card:hover,.pc__submit:hover,.pc__social:hover{transform:none}
}
{% endstylesheet %}

