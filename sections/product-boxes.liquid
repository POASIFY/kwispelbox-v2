<section class="pboxes">
  <div class="pboxes__wrap">

    <!-- Sectie header -->
    <div class="pboxes__header">
      <h2 class="pboxes__title">{{ section.settings.title }}</h2>
      <p class="pboxes__sub">{{ section.settings.subtitle }}</p>
    </div>

    <!-- Drie kaarten -->
    <div class="pboxes__grid" data-pboxes-grid>
      {%- for block in section.blocks -%}
        {%- if block.type == 'box' -%}
          <div class="pbox pbox--{{ block.settings.color }}{% if block.settings.featured %} pbox--featured{% endif %}"
               {{ block.shopify_attributes }}>

            <!-- Badge -->
            {%- if block.settings.badge != blank -%}
              <div class="pbox__badge">
                {{ block.settings.badge }}
                {%- if block.settings.featured -%}
                  <span aria-hidden="true">✦</span>
                {%- endif -%}
              </div>
            {%- endif -%}

            <!-- Afbeelding -->
            <div class="pbox__img-wrap">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                          {{ block.settings.image | image_url: width: 600 }} 600w,
                          {{ block.settings.image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 767px) 90vw, (max-width: 1024px) 45vw, 360px"
                  alt="{{ block.settings.image.alt | default: block.settings.name | escape }}"
                  width="600"
                  height="{{ 600 | divided_by: block.settings.image.aspect_ratio | round }}"
                  loading="lazy"
                  class="pbox__img"
                >
              {%- else -%}
                <div class="pbox__img-placeholder">
                  {{- 'icon-box.svg' | inline_asset_content -}}
                  <span>Voeg afbeelding toe</span>
                </div>
              {%- endif -%}
            </div>

            <!-- Body -->
            <div class="pbox__body">
              <h3 class="pbox__name">{{ block.settings.name }}</h3>
              <p class="pbox__count">{{ block.settings.count }}</p>

              <!-- Features -->
              {%- if block.settings.feat1 != blank or block.settings.feat2 != blank or block.settings.feat3 != blank or block.settings.feat4 != blank -%}
                <ul class="pbox__feats" role="list">
                  {%- if block.settings.feat1 != blank -%}
                    <li class="pbox__feat"><span class="pbox__feat-icon">{{- 'icon-' | append: block.settings.feat1_icon | default: 'paw' | append: '.svg' | inline_asset_content -}}</span>{{ block.settings.feat1 }}</li>
                  {%- endif -%}
                  {%- if block.settings.feat2 != blank -%}
                    <li class="pbox__feat"><span class="pbox__feat-icon">{{- 'icon-' | append: block.settings.feat2_icon | default: 'paw' | append: '.svg' | inline_asset_content -}}</span>{{ block.settings.feat2 }}</li>
                  {%- endif -%}
                  {%- if block.settings.feat3 != blank -%}
                    <li class="pbox__feat"><span class="pbox__feat-icon">{{- 'icon-' | append: block.settings.feat3_icon | default: 'paw' | append: '.svg' | inline_asset_content -}}</span>{{ block.settings.feat3 }}</li>
                  {%- endif -%}
                  {%- if block.settings.feat4 != blank -%}
                    <li class="pbox__feat"><span class="pbox__feat-icon">{{- 'icon-' | append: block.settings.feat4_icon | default: 'paw' | append: '.svg' | inline_asset_content -}}</span>{{ block.settings.feat4 }}</li>
                  {%- endif -%}

                </ul>
              {%- endif -%}

              <!-- Prijs + CTA -->
              <div class="pbox__footer">
                <span class="pbox__price">{{ block.settings.price }}</span>
                <a href="{{ block.settings.url }}" class="pbox__btn">
                  {{ block.settings.btn_label }}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                       aria-hidden="true">
                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                  </svg>
                </a>
              </div>



            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Onderste trust strip -->
    {%- if section.settings.show_trust != false -%}
    <div class="pboxes__trust">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust_item' -%}
          <div class="pboxes__trust-item" {{ block.shopify_attributes }}>
            {%- if block.settings.type == 'avatars' -%}
              <div class="pboxes__avatars">
                {%- for i in (1..3) -%}
                  <div class="pboxes__avatar"></div>
                {%- endfor -%}
              </div>
              <div class="pboxes__trust-text">
                <strong>{{ block.settings.title }}</strong>
                <span>{{ block.settings.subtitle }}</span>
              </div>
            {%- elsif block.settings.type == 'stars' -%}
              <div class="pboxes__stars" aria-label="{{ block.settings.title }}">
                {%- for i in (1..5) -%}
                  {{- 'icon-star.svg' | inline_asset_content -}}
                {%- endfor -%}
              </div>
              <div class="pboxes__trust-text">
                <strong>{{ block.settings.title }}</strong>
                <span>{{ block.settings.subtitle }}</span>
              </div>
            {%- else -%}
              <span class="pboxes__trust-icon pboxes__trust-icon--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <div class="pboxes__trust-text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}
                  <span>{{ block.settings.subtitle }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- endfor -%}
    </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
/* ── Sectie wrapper ─────────────────────────────────────────── */
.pboxes {
  background: #F8EFDD;
  padding: 80px 0 80px;
}
.pboxes__wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}
@media(min-width:1200px){ .pboxes__wrap { padding: 0 60px; } }

/* ── Header ─────────────────────────────────────────────────── */
.pboxes__header {
  text-align: center;
  margin-bottom: 48px;
}
.pboxes__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  color: #3d2209;
  line-height: 1.1;
  margin-bottom: 12px;
}
.pboxes__sub {
  font-family: 'Karla', sans-serif;
  font-size: 1.1rem;
  color: #A88259;
}

/* ── Grid ───────────────────────────────────────────────────── */
.pboxes__grid {
  display: flex;
  gap: 20px;
  padding: 0 20px 12px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  align-items: stretch;
}
.pboxes__grid::-webkit-scrollbar { display: none; }
.pboxes__grid > * {
  flex: 0 0 82%;
  scroll-snap-align: center;
  min-width: 280px;
  max-width: 360px;
}
@media(min-width: 768px) {
  .pboxes__grid {
    overflow-x: visible;
    scroll-snap-type: none;
    padding: 0 0 0;
    justify-content: center;
    align-items: end;
    flex-wrap: nowrap;
  }
  .pboxes__grid > * {
    flex: 1;
    min-width: 0;
    max-width: none;
  }
}

/* ── Kaart basis ────────────────────────────────────────────── */
.pbox {
  background: #fff;
  border-radius: 24px;
  overflow: hidden;
  border: 2px solid #EDE2C9;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: transform 250ms cubic-bezier(.34,1.56,.64,1),
              box-shadow 250ms ease;
}
.pbox:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 48px rgba(96,58,21,.13);
}

/* ── Featured kaart (Happy) ─────────────────────────────────── */
.pbox--featured {
  border-width: 2.5px;
}
.pbox--orange.pbox--featured { border-color: #F7A048; box-shadow: 0 8px 32px rgba(247,160,72,.18); }
@media(min-width:768px) {
  .pbox--featured {
    transform: scale(1.03);
    transform-origin: center center;
  }
  .pbox--featured:hover {
    transform: scale(1.03) translateY(-6px);
  }
}

/* ── Badge ──────────────────────────────────────────────────── */
.pbox__badge {
  position: absolute;
  top: 14px;
  left: 14px;
  z-index: 3;
  font-family: 'Karla', sans-serif;
  font-size: 0.78rem;
  font-weight: 800;
  padding: 6px 14px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
  box-shadow: 0 2px 8px rgba(96,58,21,.14);
}
.pbox--green  .pbox__badge { background: #e8f5e2; color: #2d7a1a; }
.pbox--orange .pbox__badge { background: #F7A048; color: #fff; }
.pbox--pink   .pbox__badge { background: #fff0f5; color: #c0394b; }

/* ── Afbeelding ─────────────────────────────────────────────── */
.pbox__img-wrap {
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: #F8EFDD;
  flex-shrink: 0;
}
.pbox__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 400ms ease;
}
.pbox:hover .pbox__img { transform: scale(1.04); }
.pbox__img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: #DAC9A1;
  font-size: 0.875rem;
}
.pbox__img-placeholder svg { width: 48px; height: 48px; }

/* ── Body ───────────────────────────────────────────────────── */
.pbox__body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
}
.pbox__name {
  font-family: 'Lilita One', cursive;
  font-size: 1.5rem;
  line-height: 1.1;
}
.pbox--green  .pbox__name { color: #2d7a1a; }
.pbox--orange .pbox__name { color: #d9823a; }
.pbox--pink   .pbox__name { color: #c0394b; }

.pbox__count {
  font-family: 'Karla', sans-serif;
  font-size: 0.95rem;
  color: #A88259;
  margin-top: -8px;
}

/* ── Features ───────────────────────────────────────────────── */
.pbox__feats {
  display: flex;
  flex-direction: column;
  gap: 6px;
  list-style: none;
  margin: 0;
  padding: 0;
}
.pbox__feat {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Karla', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: #603A15;
  background: #fff;
  border-radius: 999px;
  padding: 6px 14px 6px 6px;
  width: fit-content;
}
.pbox__feat-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  flex-shrink: 0;
}
.pbox__feat-icon svg { width: 14px; height: 14px; }
.pbox--green  .pbox__feat-icon { background: #e8f5e2; color: #66AA44; }
.pbox--orange .pbox__feat-icon { background: #fff0e4; color: #F7A048; }
.pbox--pink   .pbox__feat-icon { background: #fff0f5; color: #e75480; }

/* ── Footer: prijs + knop ───────────────────────────────────── */
.pbox__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-top: auto;
  padding-top: 8px;
}
.pbox__price {
  font-family: 'Lilita One', cursive;
  font-size: 1.75rem;
  color: #3d2209;
  line-height: 1;
}
.pbox__btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Lilita One', cursive;
  font-size: 0.95rem;
  padding: 12px 20px;
  border-radius: 999px;
  text-decoration: none;
  color: #fff;
  white-space: nowrap;
  transition: transform 200ms cubic-bezier(.34,1.56,.64,1), box-shadow 180ms;
}
.pbox__btn:hover { transform: translateY(-2px); }
.pbox--green  .pbox__btn { background: #66AA44; box-shadow: 0 4px 14px rgba(102,170,68,.35); }
.pbox--green  .pbox__btn:hover { background: #4d8833; }
.pbox--orange .pbox__btn { background: #F7A048; box-shadow: 0 4px 14px rgba(247,160,72,.35); }
.pbox--orange .pbox__btn:hover { background: #d9823a; }
.pbox--pink   .pbox__btn { background: #FFB8CD; color: #603A15; box-shadow: 0 4px 14px rgba(255,184,205,.4); }
.pbox--pink   .pbox__btn:hover { background: #f09ab2; }


/* ── Onderste trust strip ───────────────────────────────────── */
.pboxes__trust {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
  margin-top: 48px;
  padding: 24px 32px;
  background: #fff;
  border-radius: 20px;
  border: 1.5px solid #EDE2C9;
}
.pboxes__trust-item {
  display: flex;
  align-items: center;
  gap: 10px;
}
.pboxes__avatars {
  display: flex;
}
.pboxes__avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: #EDE2C9;
  border: 2px solid #fff;
  margin-left: -8px;
}
.pboxes__avatar:first-child { margin-left: 0; background: #DAC9A1; }
.pboxes__avatar:nth-child(2) { background: #c4a882; }
.pboxes__avatar:nth-child(3) { background: #A88259; }

.pboxes__trust-icon {
  width: 36px; height: 36px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.pboxes__trust-icon svg { width: 18px; height: 18px; }
.pboxes__trust-icon--green  { background: #e8f5e2; color: #66AA44; }
.pboxes__trust-icon--orange { background: #fff0e4; color: #F7A048; }
.pboxes__trust-icon--pink   { background: #fff0f5; color: #e75480; }
.pboxes__trust-icon--yellow { background: #fffae0; color: #c49000; }

.pboxes__trust-text {
  display: flex; flex-direction: column; gap: 1px;
}
.pboxes__trust-text strong {
  font-family: 'Karla', sans-serif;
  font-size: 0.85rem; font-weight: 800; color: #603A15;
}
.pboxes__trust-text span {
  font-size: 0.75rem; color: #A88259;
}

.pboxes__stars { display: flex; gap: 2px; }
.pboxes__stars svg { width: 16px; height: 16px; color: #F7A048; }

/* ── Mobiel ─────────────────────────────────────────────────── */
@media(max-width:767px) {
  .pboxes { padding: 48px 0 60px; }
  .pboxes__trust { padding: 20px; justify-content: center; }
  .pbox--featured { transform: none; }
}

/* ── Slider dots (mobiel) ──────────────────────────────── */
.pboxes__dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  margin-top: 20px;
}
@media(min-width: 768px) { .pboxes__dots { display: none; } }

.pboxes__dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #EDE2C9;
  border: none; padding: 0; cursor: pointer;
  transition: background 250ms ease, width 250ms ease;
  flex-shrink: 0;
}
.pboxes__dot--active {
  background: #F7A048;
  width: 24px;
  border-radius: 999px;
}
{% endstylesheet %}


{% javascript %}
(function () {
  const grid = document.querySelector('[data-pboxes-grid]');
  if (!grid) return;

  const dots = document.querySelectorAll('.pboxes__dot');
  if (!dots.length) return;

  function getActiveIndex() {
    const cards = grid.querySelectorAll(':scope > *');
    if (!cards.length) return 0;
    const gridLeft = grid.getBoundingClientRect().left;
    const gridWidth = grid.offsetWidth;
    let closest = 0, minDist = Infinity;
    cards.forEach((card, i) => {
      const cardCenter = card.getBoundingClientRect().left - gridLeft + card.offsetWidth / 2;
      const dist = Math.abs(cardCenter - gridWidth / 2);
      if (dist < minDist) { minDist = dist; closest = i; }
    });
    return closest;
  }

  function updateDots(index) {
    dots.forEach((dot, i) => {
      const active = i === index;
      dot.classList.toggle('pboxes__dot--active', active);
      dot.setAttribute('aria-selected', active ? 'true' : 'false');
    });
  }

  // Scroll → dots bijwerken
  let scrollTimer;
  grid.addEventListener('scroll', () => {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => updateDots(getActiveIndex()), 60);
  }, { passive: true });

  // Dot klik → scroll naar kaart
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      const cards = grid.querySelectorAll(':scope > *');
      if (cards[i]) {
        cards[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
    });
  });
})();
{% endjavascript %}

{% schema %}
