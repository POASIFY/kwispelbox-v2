{% comment %} KWISPELCLUB – Landingspagina v2 – Productie-klaar {% endcomment %}
{%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}
{%- assign step_blocks    = section.blocks | where: 'type', 'step' -%}
{%- assign trust_blocks   = section.blocks | where: 'type', 'trust' -%}

<!-- ══ HERO ══════════════════════════════════════════════ -->
<section class="kc-hero">
  <div class="kc-hero__inner">
    <div class="kc-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="kc-hero__eyebrow">
          {{- 'icon-heart.svg' | inline_asset_content -}}
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      <h1 class="kc-hero__title">{{ section.settings.title }}</h1>

      {%- if section.settings.tagline != blank -%}
        <p class="kc-hero__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}

      {%- if section.settings.intro != blank -%}
        <p class="kc-hero__intro">{{ section.settings.intro }}</p>
      {%- endif -%}

      <div class="kc-hero__ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="kc-btn kc-btn--primary">
            {{ section.settings.cta_primary_label }}
            {{- 'icon-paw.svg' | inline_asset_content -}}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="kc-btn kc-btn--ghost">
            {{- 'icon-account.svg' | inline_asset_content -}}
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>

      <div class="kc-hero__trust-row">
        {%- if section.settings.trust_count != blank -%}
          <div class="kc-hero__trust-pill">
            {{- 'icon-users.svg' | inline_asset_content -}}
            {{ section.settings.trust_count }}
          </div>
        {%- endif -%}
        {%- if section.settings.trust_score != blank -%}
          <div class="kc-hero__trust-pill">
            {{- 'icon-star.svg' | inline_asset_content -}}
            {{ section.settings.trust_score }}
          </div>
        {%- endif -%}
        {%- if section.settings.trust_free != blank -%}
          <div class="kc-hero__trust-pill">
            {{- 'icon-heart.svg' | inline_asset_content -}}
            {{ section.settings.trust_free }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="kc-hero__media">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 900 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w,
                  {{ section.settings.hero_image | image_url: width: 900 }} 900w"
          sizes="(max-width: 899px) 90vw, 48vw"
          alt="{{ section.settings.hero_image.alt | default: 'Kwispelclub' | escape }}"
          width="900" height="900"
          loading="eager"
          fetchpriority="high"
          class="kc-hero__img"
        >
      {%- else -%}
        <div class="kc-hero__img-ph">
          {{- 'icon-paw.svg' | inline_asset_content -}}
          <span>Upload hero afbeelding</span>
        </div>
      {%- endif -%}
      {%- if section.settings.bubble_text != blank -%}
        <div class="kc-hero__bubble" aria-hidden="true">
          {{- section.settings.bubble_text | newline_to_br -}}
          {{- 'icon-paw.svg' | inline_asset_content -}}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- ══ VOORDELEN / PIJLERS ════════════════════════════════ -->
{%- if benefit_blocks.size > 0 -%}
<section class="kc-benefits">
  <div class="kc-wrap">
    {%- if section.settings.benefits_title != blank -%}
      <h2 class="kc-section-title">{{ section.settings.benefits_title }}</h2>
    {%- endif -%}
    <div class="kc-benefits__grid">
      {%- for block in benefit_blocks -%}
        <div class="kc-benefit-card" {{ block.shopify_attributes }}>
          <span class="kc-benefit-card__icon kc-icon-wrap kc-icon-wrap--{{ block.settings.color }}">
            {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
          </span>
          <strong class="kc-benefit-card__title">{{ block.settings.title }}</strong>
          <p class="kc-benefit-card__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- ══ HOND VAN DE MAAND ═════════════════════════════════ -->
{%- if section.settings.motm_title != blank -%}
<section class="kc-motm">
  <div class="kc-wrap kc-motm__layout">

    <div class="kc-motm__photo" aria-hidden="true">
      <div class="kc-polaroid">
        {%- if section.settings.motm_image != blank -%}
          <img
            src="{{ section.settings.motm_image | image_url: width: 480 }}"
            alt="{{ section.settings.motm_name | default: 'Kwispelaar van de maand' | escape }}"
            width="480" height="480"
            loading="lazy"
            class="kc-polaroid__img"
          >
        {%- else -%}
          <div class="kc-polaroid__ph">{{- 'icon-camera.svg' | inline_asset_content -}}</div>
        {%- endif -%}
        {%- if section.settings.motm_name != blank -%}
          <div class="kc-polaroid__label">
            <span class="kc-polaroid__name">{{ section.settings.motm_name }}</span>
            <span class="kc-polaroid__sub">Kwispelaar van de maand 🏆</span>
          </div>
        {%- endif -%}
        <span class="kc-polaroid__deco-heart">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
      </div>
    </div>

    <div class="kc-motm__content">
      <h2 class="kc-motm__title">
        {{ section.settings.motm_title }}
        <span class="kc-inline-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
      </h2>
      {%- if section.settings.motm_desc != blank -%}
        <p class="kc-motm__desc">{{ section.settings.motm_desc }}</p>
      {%- endif -%}
      {%- if section.settings.motm_cta_label != blank -%}
        <a href="{{ section.settings.motm_cta_url }}" class="kc-btn kc-btn--outline-pink">
          {{- 'icon-camera.svg' | inline_asset_content -}}
          {{ section.settings.motm_cta_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>
{%- endif -%}

<!-- ══ ZO WERKT HET ═══════════════════════════════════════ -->
{%- if step_blocks.size > 0 -%}
<section class="kc-how">
  <div class="kc-wrap">
    {%- if section.settings.how_title != blank -%}
      <h2 class="kc-section-title">
        {{ section.settings.how_title }}
        <span class="kc-inline-heart" aria-hidden="true">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
      </h2>
    {%- endif -%}
    <div class="kc-how__flow">
      {%- for block in step_blocks -%}
        <div class="kc-step" {{ block.shopify_attributes }}>
          <div class="kc-step__icon-wrap">
            <span class="kc-step__icon kc-icon-wrap kc-icon-wrap--{{ block.settings.color }}">
              {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
            </span>
            {%- unless forloop.last -%}
              <span class="kc-step__connector" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </span>
            {%- endunless -%}
          </div>
          <strong class="kc-step__label">{{ block.settings.number }}. {{ block.settings.title }}</strong>
          <p class="kc-step__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- ══ INSCHRIJVEN ════════════════════════════════════════ -->
{%- if section.settings.nl_title != blank -%}
<section class="kc-signup">
  <div class="kc-signup__inner kc-wrap">
    <div class="kc-signup__left">
      <span class="kc-signup__icon" aria-hidden="true">
        {{- 'icon-mail.svg' | inline_asset_content -}}
      </span>
      <div class="kc-signup__copy">
        <strong class="kc-signup__title">{{ section.settings.nl_title }}</strong>
        {%- if section.settings.nl_desc != blank -%}
          <p class="kc-signup__desc">{{ section.settings.nl_desc }}</p>
        {%- endif -%}
      </div>
    </div>
    <form class="kc-signup__form"
          action="{{ routes.root_url }}contact#contact_form"
          method="post"
          accept-charset="UTF-8">
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[tags]" value="kwispelclub">
      <label for="kc-nl-email" class="kc-sr-only">{{ section.settings.nl_placeholder }}</label>
      <input
        type="email"
        id="kc-nl-email"
        name="contact[email]"
        required
        autocomplete="email"
        class="kc-signup__input"
        placeholder="{{ section.settings.nl_placeholder }}"
      >
      <button type="submit" class="kc-btn kc-btn--orange">
        {{ section.settings.nl_button }}
        {{- 'icon-paw.svg' | inline_asset_content -}}
      </button>
    </form>
  </div>
</section>
{%- endif -%}

<!-- ══ TRUST BAR ══════════════════════════════════════════ -->
{%- if trust_blocks.size > 0 -%}
<section class="kc-trust">
  <div class="kc-trust__inner">
    {%- for block in trust_blocks -%}
      <div class="kc-trust__item" {{ block.shopify_attributes }}>
        <span class="kc-trust__icon kc-icon-wrap kc-icon-wrap--{{ block.settings.color }}">
          {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
        </span>
        <div class="kc-trust__text">
          <strong>{{ block.settings.title }}</strong>
          {%- if block.settings.subtitle != blank -%}
            <span>{{ block.settings.subtitle }}</span>
          {%- endif -%}
          {%- if block.settings.show_stars -%}
            <span class="kc-trust__stars" aria-hidden="true">
              {%- for i in (1..5) -%}{{- 'icon-star.svg' | inline_asset_content -}}{%- endfor -%}
            </span>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{% stylesheet %}
/* ════════════════════════════════════════════════════════
   KWISPELCLUB — Production-ready, v2
   Design tokens: zelfde als theme-brede secties
   ════════════════════════════════════════════════════════ */

.kc-sr-only {
  position: absolute; width: 1px; height: 1px;
  overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap;
}
.kc-wrap {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}
@media(min-width: 1024px) {
  .kc-wrap { padding: 0 60px; }
}

/* ── Gedeelde componenten ────────────────────────────────── */

/* Sectietitel */
.kc-section-title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  color: #3d2209;
  text-align: center;
  margin-bottom: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

/* Inline hart naast titel */
.kc-inline-heart {
  display: inline-flex;
  align-items: center;
  color: #e75480;
}
.kc-inline-heart svg { width: 22px; height: 22px; }

/* Icoon-cirkel (zoals andere secties) */
.kc-icon-wrap {
  width: 64px; height: 64px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.kc-icon-wrap svg { width: 28px; height: 28px; }
.kc-icon-wrap--pink   { background: #ffe0ee; color: #e75480; }
.kc-icon-wrap--green  { background: #e8f5e2; color: #66AA44; }
.kc-icon-wrap--orange { background: #fff0e4; color: #F7A048; }
.kc-icon-wrap--purple { background: #f0ecff; color: #7c3aed; }
.kc-icon-wrap--yellow { background: #fffae0; color: #c49000; }
.kc-icon-wrap--brown  { background: #F8EFDD; color: #603A15; }

/* Knoppen */
.kc-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Lilita One', cursive;
  font-size: .95rem;
  padding: 13px 24px;
  border-radius: 999px;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition:
    transform 200ms cubic-bezier(.34, 1.56, .64, 1),
    box-shadow 160ms ease;
}
.kc-btn:hover { transform: translateY(-2px); }
.kc-btn svg { width: 16px; height: 16px; flex-shrink: 0; }
.kc-btn--primary {
  background: #e75480;
  color: #fff;
  box-shadow: 0 4px 16px rgba(231, 84, 128, .28);
}
.kc-btn--primary:hover { background: #c4396a; box-shadow: 0 6px 20px rgba(231,84,128,.36); }
.kc-btn--ghost {
  background: #fff;
  color: #3d2209;
  border: 2px solid #EDE2C9;
}
.kc-btn--ghost:hover { border-color: #A88259; background: #F8EFDD; }
.kc-btn--outline-pink {
  background: transparent;
  color: #e75480;
  border: 1.5px solid #FFB8CD;
}
.kc-btn--outline-pink:hover { background: #FFF0F5; }
.kc-btn--orange {
  background: #F7A048;
  color: #fff;
  box-shadow: 0 4px 14px rgba(247, 160, 72, .28);
}
.kc-btn--orange:hover { background: #d9823a; }

/* ══ HERO ══════════════════════════════════════════════════ */

.kc-hero {
  background: #FFF0F5;
  padding: 56px 0 0;
  overflow: hidden;
}

.kc-hero__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
  display: flex;
  flex-direction: column;
  gap: 36px;
  align-items: center;
}
@media(min-width: 900px) {
  .kc-hero__inner {
    flex-direction: row;
    align-items: flex-end;
    padding: 0 60px;
    gap: 0;
  }
}

/* Links: content */
.kc-hero__content {
  display: flex;
  flex-direction: column;
  gap: 18px;
  flex: 1;
  max-width: 540px;
}

.kc-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'Karla', sans-serif;
  font-size: .75rem;
  font-weight: 800;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #e75480;
}
.kc-hero__eyebrow svg { width: 13px; height: 13px; flex-shrink: 0; }

.kc-hero__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(3rem, 8vw, 6rem);
  color: #3d2209;
  line-height: .92;
  margin: 0;
}

.kc-hero__tagline {
  font-family: 'Lilita One', cursive;
  font-size: clamp(1.05rem, 2.5vw, 1.3rem);
  color: #603A15;
  margin: 0;
  line-height: 1.3;
}

.kc-hero__intro {
  font-family: 'Karla', sans-serif;
  font-size: .95rem;
  color: #A88259;
  line-height: 1.7;
  margin: 0;
}

.kc-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 4px;
}

/* Trust row onder CTA's */
.kc-hero__trust-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 4px;
}
.kc-hero__trust-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'Karla', sans-serif;
  font-size: .78rem;
  font-weight: 700;
  color: #603A15;
  background: rgba(255,255,255,.7);
  border: 1.5px solid #FFB8CD;
  border-radius: 999px;
  padding: 5px 12px;
}
.kc-hero__trust-pill svg { width: 13px; height: 13px; color: #e75480; flex-shrink: 0; }

/* Rechts: media */
.kc-hero__media {
  flex-shrink: 0;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
@media(min-width: 900px) {
  .kc-hero__media { width: 48%; align-self: flex-end; }
}

.kc-hero__img {
  width: 100%;
  max-width: 520px;
  display: block;
  border-radius: 28px 28px 0 0;
  object-fit: cover;
  object-position: center top;
}
@media(min-width: 900px) {
  .kc-hero__img { max-width: none; border-radius: 32px 32px 0 0; }
}

.kc-hero__img-ph {
  width: 100%;
  min-height: 320px;
  background: #FFD6E3;
  border-radius: 28px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: #e75480;
  font-family: 'Karla', sans-serif;
  font-size: .85rem;
}
.kc-hero__img-ph svg { width: 40px; height: 40px; }

/* Welcome-bubble */
.kc-hero__bubble {
  position: absolute;
  top: 20px; right: 0;
  background: #fff;
  border-radius: 20px;
  padding: 14px 18px;
  box-shadow: 0 4px 20px rgba(231, 84, 128, .18);
  font-family: 'Lilita One', cursive;
  font-size: .95rem;
  color: #3d2209;
  max-width: 165px;
  text-align: center;
  line-height: 1.35;
  z-index: 2;
}
.kc-hero__bubble svg { width: 18px; height: 18px; color: #e75480; display: block; margin: 4px auto 0; }
@media(min-width: 900px) {
  .kc-hero__bubble { top: 36px; right: 0; }
}

/* ══ VOORDELEN ══════════════════════════════════════════════ */

.kc-benefits {
  background: #fff;
  padding: 72px 0;
  border-top: 1.5px solid #EDE2C9;
}

.kc-benefits__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px 20px;
}
@media(min-width: 768px) {
  .kc-benefits__grid { grid-template-columns: repeat(4, 1fr); gap: 32px 24px; }
}

.kc-benefit-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 14px;
}
.kc-benefit-card__title {
  font-family: 'Lilita One', cursive;
  font-size: 1rem;
  color: #3d2209;
  line-height: 1.25;
}
.kc-benefit-card__desc {
  font-family: 'Karla', sans-serif;
  font-size: .82rem;
  color: #A88259;
  line-height: 1.6;
  max-width: 180px;
  margin: 0;
}

/* ══ HOND VAN DE MAAND ══════════════════════════════════════ */

.kc-motm {
  background: #FFF0F5;
  padding: 64px 0;
}
.kc-motm__layout {
  display: flex;
  flex-direction: column;
  gap: 40px;
  align-items: center;
}
@media(min-width: 768px) {
  .kc-motm__layout { flex-direction: row; align-items: center; gap: 64px; }
}

/* Polaroid */
.kc-motm__photo { flex-shrink: 0; display: flex; justify-content: center; }
.kc-polaroid {
  position: relative;
  background: #fff;
  padding: 12px 12px 52px;
  border-radius: 4px;
  box-shadow: 0 8px 32px rgba(231, 84, 128, .16);
  transform: rotate(-3deg);
  max-width: 220px;
  transition: transform 300ms ease;
}
.kc-polaroid:hover { transform: rotate(-1deg) scale(1.02); }
.kc-polaroid__img {
  width: 100%;
  display: block;
  aspect-ratio: 1;
  object-fit: cover;
  border-radius: 2px;
}
.kc-polaroid__ph {
  width: 196px; height: 196px;
  background: #FFD6E3;
  display: flex; align-items: center; justify-content: center;
  color: #e75480; border-radius: 2px;
}
.kc-polaroid__ph svg { width: 40px; height: 40px; }
.kc-polaroid__label {
  position: absolute;
  bottom: 10px; left: 0; right: 0;
  text-align: center; padding: 0 10px;
}
.kc-polaroid__name {
  display: block;
  font-family: 'Lilita One', cursive;
  font-size: 1rem; color: #3d2209;
}
.kc-polaroid__sub {
  display: block;
  font-family: 'Karla', sans-serif;
  font-size: .68rem; color: #A88259; margin-top: 2px;
}
.kc-polaroid__deco-heart {
  position: absolute;
  bottom: -14px; left: 14px;
  display: flex; color: #e75480;
}
.kc-polaroid__deco-heart svg { width: 26px; height: 26px; }

/* Motm rechts */
.kc-motm__content {
  display: flex; flex-direction: column;
  gap: 18px; max-width: 480px;
}
.kc-motm__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(1.7rem, 4vw, 2.4rem);
  color: #3d2209;
  display: flex; align-items: center; gap: 10px;
  margin: 0;
}
.kc-motm__desc {
  font-family: 'Karla', sans-serif;
  font-size: .95rem; color: #A88259;
  line-height: 1.7; margin: 0;
}

/* ══ ZO WERKT HET ════════════════════════════════════════════ */

.kc-how {
  background: #F8EFDD;
  padding: 72px 0;
}

.kc-how__flow {
  display: flex;
  flex-direction: column;
  gap: 32px;
  align-items: flex-start;
}
@media(min-width: 768px) {
  .kc-how__flow {
    flex-direction: row;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
  }
}

.kc-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
  flex: 1;
  min-width: 110px;
  position: relative;
  padding: 0 8px;
}

/* Desktop: mobiel anders (links uitgelijnd, icoon links) */
@media(max-width: 767px) {
  .kc-step {
    flex-direction: row;
    text-align: left;
    align-items: flex-start;
    gap: 16px;
    padding: 0;
  }
  .kc-step__icon-wrap { flex-shrink: 0; }
  .kc-step__label,
  .kc-step__desc { margin: 0; }
}

.kc-step__icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.kc-step__icon {
  width: 60px; height: 60px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.kc-step__icon svg { width: 26px; height: 26px; }

/* Verbindingspijl tussen stappen (desktop) */
.kc-step__connector {
  display: none;
  position: absolute;
  top: 50%; right: -20px;
  transform: translateY(-50%);
  color: #EDE2C9;
  z-index: 1;
}
@media(min-width: 768px) { .kc-step__connector { display: flex; } }
.kc-step__connector svg { width: 22px; height: 22px; }

.kc-step__label {
  font-family: 'Lilita One', cursive;
  font-size: .9rem; color: #3d2209;
  line-height: 1.25;
}
.kc-step__desc {
  font-family: 'Karla', sans-serif;
  font-size: .78rem; color: #A88259;
  line-height: 1.55; max-width: 130px; margin: 0;
}
@media(max-width: 767px) { .kc-step__desc { max-width: none; } }

/* ══ INSCHRIJVEN ════════════════════════════════════════════ */

.kc-signup {
  background: #4d7a30;
}
.kc-signup__inner {
  display: flex;
  flex-direction: column;
  gap: 24px;
  padding-top: 40px;
  padding-bottom: 40px;
}
@media(min-width: 768px) {
  .kc-signup__inner { flex-direction: row; align-items: center; gap: 40px; }
}

.kc-signup__left {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  flex: 1;
}
.kc-signup__icon {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: rgba(255,255,255,.15);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  color: #fff;
}
.kc-signup__icon svg { width: 24px; height: 24px; }
.kc-signup__copy { display: flex; flex-direction: column; gap: 4px; }
.kc-signup__title {
  font-family: 'Lilita One', cursive;
  font-size: 1.3rem; color: #fff; display: block;
}
.kc-signup__desc {
  font-family: 'Karla', sans-serif;
  font-size: .82rem; color: rgba(255,255,255,.72);
  line-height: 1.55; margin: 0;
}

.kc-signup__form {
  display: flex;
  gap: 8px;
  flex: 1;
  max-width: 480px;
  flex-wrap: wrap;
}
@media(min-width: 480px) { .kc-signup__form { flex-wrap: nowrap; } }
.kc-signup__input {
  flex: 1;
  min-width: 0;
  height: 52px;
  padding: 0 20px;
  border: none;
  border-radius: 999px;
  font-family: 'Karla', sans-serif;
  font-size: .95rem;
  color: #3d2209;
  outline: none;
  min-width: 200px;
}
.kc-signup__input::placeholder { color: #A88259; }
.kc-signup__input:focus {
  box-shadow: 0 0 0 2px rgba(247,160,72,.4);
}

/* ══ TRUST BAR ════════════════════════════════════════════ */

.kc-trust {
  background: #F8EFDD;
  border-top: 1.5px solid #EDE2C9;
}
.kc-trust__inner {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  max-width: 1280px;
  margin: 0 auto;
  padding: 0;
}
@media(min-width: 768px) {
  .kc-trust__inner { grid-template-columns: repeat(4, 1fr); }
}

.kc-trust__item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 22px 20px;
  border-right: 1px solid #EDE2C9;
}
.kc-trust__item:last-child { border-right: none; }
@media(max-width: 767px) {
  .kc-trust__item:nth-child(2n) { border-right: none; }
  .kc-trust__item:nth-child(n+3) { border-top: 1px solid #EDE2C9; }
}

.kc-trust__icon {
  width: 46px; height: 46px;
}
.kc-trust__icon svg { width: 20px; height: 20px; }
.kc-trust__icon.kc-icon-wrap--green  { background: #e8f5e2; color: #66AA44; }
.kc-trust__icon.kc-icon-wrap--pink   { background: #fff0f5; color: #e75480; }
.kc-trust__icon.kc-icon-wrap--orange { background: #fff0e4; color: #F7A048; }
.kc-trust__icon.kc-icon-wrap--yellow { background: #fffae0; color: #c49000; }

.kc-trust__text {
  display: flex; flex-direction: column; gap: 2px;
}
.kc-trust__text strong {
  font-family: 'Lilita One', cursive;
  font-size: .95rem; color: #3d2209; line-height: 1.15;
}
.kc-trust__text span {
  font-family: 'Karla', sans-serif;
  font-size: .78rem; color: #A88259; line-height: 1.35;
}
.kc-trust__stars {
  display: flex; gap: 2px; margin-top: 3px;
}
.kc-trust__stars svg { width: 12px; height: 12px; color: #F7A048; fill: #F7A048; }
{% endstylesheet %}

