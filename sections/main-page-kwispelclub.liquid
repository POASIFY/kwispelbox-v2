{% comment %} KWISPELCLUB – Landingspagina {% endcomment %}
{%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}
{%- assign step_blocks    = section.blocks | where: 'type', 'step' -%}
{%- assign trust_blocks   = section.blocks | where: 'type', 'trust' -%}

<!-- ══ HERO ══════════════════════════════════════════════ -->
<section class="kc-hero">
  <div class="kc-hero__inner">
    <div class="kc-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="kc-eyebrow">
          {{- 'icon-heart.svg' | inline_asset_content -}}
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}
      <h1 class="kc-hero__title">{{ section.settings.title }}</h1>
      {%- if section.settings.tagline != blank -%}
        <p class="kc-hero__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="kc-hero__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
      <div class="kc-hero__ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="kc-btn kc-btn--primary">
            {{ section.settings.cta_primary_label }}
            {{- 'icon-paw.svg' | inline_asset_content -}}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="kc-btn kc-btn--outline">
            {{- 'icon-account.svg' | inline_asset_content -}}
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>
      <div class="kc-hero__proof">
        <div class="kc-hero__avatars" aria-hidden="true">
          {%- for i in (1..4) -%}<span class="kc-hero__av kc-hero__av--{{ i }}"></span>{%- endfor -%}
        </div>
        <div class="kc-hero__proof-text">
          <div class="kc-stars">
            {%- for i in (1..5) -%}{{- 'icon-star.svg' | inline_asset_content -}}{%- endfor -%}
            <strong>{{ section.settings.proof_score }}</strong>
          </div>
          <span>{{ section.settings.proof_label }}</span>
        </div>
      </div>
    </div>
    <div class="kc-hero__media">
      {%- if section.settings.hero_image != blank -%}
        <img src="{{ section.settings.hero_image | image_url: width: 900 }}"
             srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w,
                     {{ section.settings.hero_image | image_url: width: 900 }} 900w"
             sizes="(max-width:767px) 90vw, 48vw"
             alt="{{ section.settings.hero_image.alt | default: 'Kwispelclub' | escape }}"
             width="900" height="900" loading="eager" fetchpriority="high"
             class="kc-hero__img">
      {%- else -%}
        <div class="kc-hero__img-ph">{{- 'icon-paw.svg' | inline_asset_content -}}</div>
      {%- endif -%}
      {%- if section.settings.welcome_bubble != blank -%}
        <div class="kc-hero__bubble">
          {{ section.settings.welcome_bubble }}
          {{- 'icon-paw.svg' | inline_asset_content -}}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- ══ PIJLERS ════════════════════════════════════════════ -->
{%- if benefit_blocks.size > 0 -%}
<section class="kc-pijlers">
  <div class="kc-wrap">
    {%- if section.settings.pijlers_title != blank -%}
      <h2 class="kc-title-center">{{ section.settings.pijlers_title }}</h2>
    {%- endif -%}
    <div class="kc-pijlers__grid">
      {%- for block in benefit_blocks -%}
        <div class="kc-pijler" {{ block.shopify_attributes }}>
          <span class="kc-pijler__icon kc-icon--{{ block.settings.color }}">
            {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
          </span>
          <strong class="kc-pijler__title">{{ block.settings.title }}</strong>
          <p class="kc-pijler__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- ══ KWISPELAAR VAN DE MAAND ════════════════════════════ -->
{%- if section.settings.motm_title != blank -%}
<section class="kc-motm">
  <div class="kc-wrap kc-motm__inner">
    <div class="kc-motm__photo">
      {%- if section.settings.motm_image != blank -%}
        <div class="kc-polaroid">
          <img src="{{ section.settings.motm_image | image_url: width: 500 }}"
               alt="{{ section.settings.motm_dog_name | default: 'Kwispelaar' | escape }}"
               width="500" height="500" loading="lazy" class="kc-polaroid__img">
          {%- if section.settings.motm_dog_name != blank -%}
            <div class="kc-polaroid__label">
              <span class="kc-polaroid__name">{{ section.settings.motm_dog_name }}</span>
              <span class="kc-polaroid__caption">Kwispelaar van de maand 🏆</span>
            </div>
          {%- endif -%}
          <span class="kc-polaroid__heart">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
        </div>
      {%- else -%}
        <div class="kc-polaroid kc-polaroid--ph">{{- 'icon-paw.svg' | inline_asset_content -}}</div>
      {%- endif -%}
    </div>
    <div class="kc-motm__content">
      <h2 class="kc-motm__title">
        {{ section.settings.motm_title }}
        <span class="kc-inline-heart">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
      </h2>
      {%- if section.settings.motm_desc != blank -%}
        <p class="kc-motm__desc">{{ section.settings.motm_desc }}</p>
      {%- endif -%}
      {%- if section.settings.motm_cta_label != blank -%}
        <a href="{{ section.settings.motm_cta_url }}" class="kc-btn kc-btn--outline-pink">
          {{- 'icon-camera.svg' | inline_asset_content -}}
          {{ section.settings.motm_cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- ══ ZO WERKT HET ═══════════════════════════════════════ -->
{%- if step_blocks.size > 0 -%}
<section class="kc-how">
  <div class="kc-wrap">
    {%- if section.settings.how_title != blank -%}
      <h2 class="kc-title-center">
        {{ section.settings.how_title }}
        <span class="kc-inline-heart">{{- 'icon-heart.svg' | inline_asset_content -}}</span>
      </h2>
    {%- endif -%}
    <div class="kc-how__steps">
      {%- for block in step_blocks -%}
        <div class="kc-step" {{ block.shopify_attributes }}>
          <div class="kc-step__icon kc-icon--{{ block.settings.color }}">
            {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
          </div>
          {%- unless forloop.last -%}
            <span class="kc-step__arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </span>
          {%- endunless -%}
          <strong class="kc-step__num">{{ block.settings.number }}. {{ block.settings.title }}</strong>
          <p class="kc-step__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

<!-- ══ NEWSLETTER ════════════════════════════════════════ -->
{%- if section.settings.nl_title != blank -%}
<section class="kc-nl">
  <div class="kc-nl__inner kc-wrap">
    <div class="kc-nl__left">
      <span class="kc-nl__icon">{{- 'icon-gift.svg' | inline_asset_content -}}</span>
      <div>
        <strong class="kc-nl__title">{{ section.settings.nl_title }}</strong>
        {%- if section.settings.nl_desc != blank -%}
          <p class="kc-nl__desc">{{ section.settings.nl_desc }}</p>
        {%- endif -%}
      </div>
    </div>
    <form class="kc-nl__form" action="{{ routes.root_url }}contact#contact_form"
          method="post" accept-charset="UTF-8">
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[tags]" value="kwispelclub">
      <label for="kc-email" class="kc-sr-only">E-mailadres</label>
      <input type="email" id="kc-email" name="contact[email]" required
             class="kc-nl__input" placeholder="{{ section.settings.nl_placeholder }}">
      <button type="submit" class="kc-btn kc-btn--orange">
        {{ section.settings.nl_button }}
        {{- 'icon-paw.svg' | inline_asset_content -}}
      </button>
    </form>
  </div>
</section>
{%- endif -%}

<!-- ══ TRUST ══════════════════════════════════════════════ -->
{%- if trust_blocks.size > 0 -%}
<section class="kc-trust">
  <div class="kc-trust__inner">
    {%- for block in trust_blocks -%}
      <div class="kc-trust__item" {{ block.shopify_attributes }}>
        <span class="kc-trust__icon kc-icon--{{ block.settings.color }}">
          {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
        </span>
        <div class="kc-trust__text">
          <strong>{{ block.settings.title }}</strong>
          {%- if block.settings.subtitle != blank -%}<span>{{ block.settings.subtitle }}</span>{%- endif -%}
          {%- if block.settings.stars -%}
            <span class="kc-trust__stars">
              {%- for i in (1..5) -%}{{- 'icon-star.svg' | inline_asset_content -}}{%- endfor -%}
            </span>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{% stylesheet %}
/* ── Tokens ──────────────────────────────────────────────── */
:root {
  --kc-pink: #e75480; --kc-pink-soft: #FFF0F5; --kc-pink-light: #FFD6E3;
  --kc-green: #66AA44; --kc-green-dark: #4d7a30; --kc-green-soft: #e8f5e2;
  --kc-orange: #F7A048; --kc-yellow: #c49000;
  --kc-ink: #3d2209; --kc-body: #603A15; --kc-soft: #A88259;
  --kc-cream: #F8EFDD; --kc-line: #EDE2C9;
  --kc-head: 'Lilita One', cursive; --kc-text: 'Karla', sans-serif;
  --kc-gap: 20px; --kc-r: 24px;
}
@media(min-width:1024px){ :root { --kc-gap: 60px; } }
.kc-sr-only { position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0); }
.kc-wrap { max-width:1280px; margin:0 auto; padding:0 var(--kc-gap); }

/* ── Gedeeld ─────────────────────────────────────────────── */
.kc-title-center {
  font-family:var(--kc-head); font-size:clamp(1.7rem,4vw,2.4rem);
  color:var(--kc-ink); text-align:center; margin-bottom:40px;
  display:flex; align-items:center; justify-content:center; gap:10px;
}
.kc-inline-heart { display:inline-flex; align-items:center; color:var(--kc-pink); }
.kc-inline-heart svg { width:20px; height:20px; }
.kc-eyebrow {
  display:inline-flex; align-items:center; gap:6px;
  font-family:var(--kc-text); font-size:.75rem; font-weight:800;
  letter-spacing:.1em; text-transform:uppercase; color:var(--kc-pink);
}
.kc-eyebrow svg { width:12px; height:12px; }
.kc-btn {
  display:inline-flex; align-items:center; gap:8px;
  font-family:var(--kc-head); font-size:.95rem;
  padding:13px 24px; border-radius:999px; text-decoration:none;
  transition:transform 200ms cubic-bezier(.34,1.56,.64,1), box-shadow 160ms;
  cursor:pointer; border:none;
}
.kc-btn:hover { transform:translateY(-2px); }
.kc-btn svg { width:16px; height:16px; flex-shrink:0; }
.kc-btn--primary { background:var(--kc-pink); color:#fff; box-shadow:0 4px 16px rgba(231,84,128,.28); }
.kc-btn--primary:hover { background:#c4396a; }
.kc-btn--outline { background:#fff; color:var(--kc-ink); border:2px solid var(--kc-line); }
.kc-btn--outline:hover { border-color:var(--kc-soft); }
.kc-btn--outline-pink { background:transparent; color:var(--kc-pink); border:1.5px solid var(--kc-pink-light); }
.kc-btn--outline-pink:hover { background:var(--kc-pink-soft); }
.kc-btn--orange { background:var(--kc-orange); color:#fff; box-shadow:0 4px 14px rgba(247,160,72,.3); }
.kc-btn--orange:hover { background:#d9823a; }
.kc-stars { display:flex; align-items:center; gap:3px; }
.kc-stars svg { width:14px; height:14px; color:var(--kc-orange); fill:var(--kc-orange); }
.kc-stars strong { font-family:var(--kc-text); font-size:.85rem; font-weight:800; color:var(--kc-ink); margin-left:4px; }

/* Icoon cirkels */
.kc-icon--pink   { background:#ffe5ef; color:var(--kc-pink); }
.kc-icon--green  { background:var(--kc-green-soft); color:var(--kc-green); }
.kc-icon--orange { background:#fff0e4; color:var(--kc-orange); }
.kc-icon--purple { background:#f0ecff; color:#7c3aed; }
.kc-icon--yellow { background:#fffae0; color:var(--kc-yellow); }

/* ══ HERO ══════════════════════════════════════════════════ */
.kc-hero {
  background:var(--kc-pink-soft);
  padding:56px 0 0; overflow:hidden;
}
.kc-hero__inner {
  max-width:1280px; margin:0 auto; padding:0 var(--kc-gap);
  display:flex; flex-direction:column; gap:32px; align-items:center;
}
@media(min-width:900px) {
  .kc-hero__inner { flex-direction:row; align-items:flex-end; gap:0; }
}
.kc-hero__content {
  display:flex; flex-direction:column; gap:16px;
  flex:1; max-width:520px;
}
.kc-hero__title {
  font-family:var(--kc-head);
  font-size:clamp(3.2rem,8vw,6rem);
  color:var(--kc-ink); line-height:.92; margin:4px 0;
}
.kc-hero__tagline {
  font-family:var(--kc-head); font-size:clamp(1rem,2.5vw,1.3rem);
  color:var(--kc-body); margin:0;
}
.kc-hero__intro {
  font-family:var(--kc-text); font-size:.95rem;
  color:var(--kc-soft); line-height:1.7; margin:0;
}
.kc-hero__ctas { display:flex; flex-wrap:wrap; gap:12px; margin-top:4px; }
.kc-hero__proof { display:flex; align-items:center; gap:12px; margin-top:8px; }
.kc-hero__avatars { display:flex; align-items:center; }
.kc-hero__av {
  width:34px; height:34px; border-radius:50%; border:2.5px solid #fff;
  display:inline-block; margin-left:-8px;
}
.kc-hero__av:first-child { margin-left:0; }
.kc-hero__av--1 { background:var(--kc-pink-light); }
.kc-hero__av--2 { background:var(--kc-orange); opacity:.8; }
.kc-hero__av--3 { background:var(--kc-green); opacity:.7; }
.kc-hero__av--4 { background:#FFE071; opacity:.7; }
.kc-hero__proof-text { display:flex; flex-direction:column; gap:2px; }
.kc-hero__proof-text span { font-family:var(--kc-text); font-size:.78rem; color:var(--kc-soft); }
.kc-hero__media { flex-shrink:0; position:relative; display:flex; align-items:flex-end; justify-content:center; }
@media(min-width:900px) { .kc-hero__media { width:48%; } }
.kc-hero__img {
  width:100%; max-width:500px; display:block;
  border-radius:32px 32px 0 0; object-fit:cover; object-position:center top;
}
@media(min-width:900px) { .kc-hero__img { border-radius:40px 40px 0 0; max-width:none; } }
.kc-hero__img-ph {
  width:100%; height:300px; background:var(--kc-pink-light);
  border-radius:32px; display:flex; align-items:center; justify-content:center; color:var(--kc-pink);
}
.kc-hero__bubble {
  position:absolute; top:24px; right:12px;
  background:#fff; border-radius:20px; padding:14px 18px;
  box-shadow:0 4px 20px rgba(231,84,128,.18);
  font-family:var(--kc-head); font-size:1rem;
  color:var(--kc-ink); max-width:170px; text-align:center; line-height:1.35;
}
.kc-hero__bubble svg { width:18px; height:18px; color:var(--kc-pink); display:block; margin:4px auto 0; }
@media(min-width:900px) { .kc-hero__bubble { top:40px; right:0; } }

/* ══ PIJLERS ═══════════════════════════════════════════════ */
.kc-pijlers { background:#fff; padding:72px 0; }
.kc-pijlers__grid {
  display:grid; grid-template-columns:repeat(2,1fr); gap:32px 20px;
}
@media(min-width:768px) { .kc-pijlers__grid { grid-template-columns:repeat(4,1fr); } }
.kc-pijler { display:flex; flex-direction:column; align-items:center; text-align:center; gap:14px; }
.kc-pijler__icon {
  width:68px; height:68px; border-radius:50%;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.kc-pijler__icon svg { width:30px; height:30px; }
.kc-pijler__title { font-family:var(--kc-head); font-size:1rem; color:var(--kc-ink); line-height:1.2; }
.kc-pijler__desc { font-family:var(--kc-text); font-size:.82rem; color:var(--kc-soft); line-height:1.6; max-width:180px; }

/* ══ KWISPELAAR VAN DE MAAND ════════════════════════════════ */
.kc-motm { background:var(--kc-pink-soft); padding:64px 0; }
.kc-motm__inner {
  display:flex; flex-direction:column; gap:40px; align-items:center;
}
@media(min-width:768px) { .kc-motm__inner { flex-direction:row; align-items:center; gap:60px; } }
.kc-motm__photo { flex-shrink:0; display:flex; justify-content:center; }
.kc-polaroid {
  background:#fff; padding:12px 12px 52px;
  border-radius:4px; box-shadow:0 8px 32px rgba(231,84,128,.18);
  transform:rotate(-3deg); max-width:220px; position:relative;
}
.kc-polaroid__img { width:100%; border-radius:2px; display:block; aspect-ratio:1; object-fit:cover; }
.kc-polaroid__label { position:absolute; bottom:10px; left:0; right:0; text-align:center; padding:0 8px; }
.kc-polaroid__name { font-family:var(--kc-head); font-size:.95rem; color:var(--kc-ink); display:block; }
.kc-polaroid__caption { font-family:var(--kc-text); font-size:.68rem; color:var(--kc-soft); margin-top:2px; display:block; }
.kc-polaroid__heart { position:absolute; bottom:-14px; left:12px; display:flex; color:var(--kc-pink); }
.kc-polaroid__heart svg { width:26px; height:26px; }
.kc-polaroid--ph {
  width:200px; height:260px; display:flex; align-items:center; justify-content:center; color:var(--kc-pink-light);
}
.kc-motm__content { display:flex; flex-direction:column; gap:16px; max-width:480px; }
.kc-motm__title {
  font-family:var(--kc-head); font-size:clamp(1.7rem,4vw,2.4rem);
  color:var(--kc-ink); display:flex; align-items:center; gap:10px; margin:0;
}
.kc-motm__desc { font-family:var(--kc-text); font-size:.95rem; color:var(--kc-soft); line-height:1.7; margin:0; }

/* ══ ZO WERKT HET ═══════════════════════════════════════════ */
.kc-how { background:var(--kc-cream); padding:72px 0; }
.kc-how__steps {
  display:flex; flex-wrap:wrap; justify-content:center; gap:24px 0;
}
@media(min-width:768px) { .kc-how__steps { flex-wrap:nowrap; } }
.kc-step {
  display:flex; flex-direction:column; align-items:center; text-align:center;
  gap:12px; flex:1; min-width:120px; position:relative; padding:0 8px;
}
.kc-step__icon {
  width:64px; height:64px; border-radius:50%;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.kc-step__icon svg { width:28px; height:28px; }
.kc-step__arrow {
  position:absolute; top:20px; right:-10px;
  color:var(--kc-line); display:none; z-index:1;
}
@media(min-width:768px) { .kc-step__arrow { display:flex; } }
.kc-step__num { font-family:var(--kc-head); font-size:.9rem; color:var(--kc-ink); }
.kc-step__desc { font-family:var(--kc-text); font-size:.78rem; color:var(--kc-soft); line-height:1.55; max-width:130px; }

/* ══ NEWSLETTER ══════════════════════════════════════════════ */
.kc-nl { background:#4d7a30; }
.kc-nl__inner {
  display:flex; flex-direction:column; gap:24px; padding:40px var(--kc-gap);
}
@media(min-width:768px) { .kc-nl__inner { flex-direction:row; align-items:center; gap:40px; } }
.kc-nl__left { display:flex; align-items:flex-start; gap:16px; flex:1; }
.kc-nl__icon {
  width:56px; height:56px; border-radius:50%;
  background:rgba(255,255,255,.15); display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.kc-nl__icon svg { width:26px; height:26px; color:#fff; }
.kc-nl__title { font-family:var(--kc-head); font-size:1.3rem; color:#fff; display:block; margin-bottom:4px; }
.kc-nl__desc { font-family:var(--kc-text); font-size:.82rem; color:rgba(255,255,255,.72); line-height:1.55; margin:0; }
.kc-nl__form { display:flex; gap:8px; flex:1; max-width:480px; }
.kc-nl__input {
  flex:1; height:52px; padding:0 20px; border:none; border-radius:999px;
  font-family:var(--kc-text); font-size:.95rem; color:var(--kc-ink); outline:none;
}
.kc-nl__input::placeholder { color:var(--kc-soft); }

/* ══ TRUST ═══════════════════════════════════════════════════ */
.kc-trust { background:var(--kc-cream); border-top:1.5px solid var(--kc-line); }
.kc-trust__inner {
  display:grid; grid-template-columns:repeat(2,1fr);
  max-width:1280px; margin:0 auto; padding:0;
}
@media(min-width:768px) { .kc-trust__inner { grid-template-columns:repeat(4,1fr); } }
.kc-trust__item {
  display:flex; align-items:center; gap:14px;
  padding:22px 20px; border-right:1px solid var(--kc-line);
}
.kc-trust__item:last-child { border-right:none; }
@media(max-width:767px) {
  .kc-trust__item:nth-child(2n) { border-right:none; }
  .kc-trust__item:nth-child(n+3) { border-top:1px solid var(--kc-line); }
}
.kc-trust__icon {
  width:46px; height:46px; border-radius:50%;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.kc-trust__icon svg { width:20px; height:20px; }
.kc-trust__text { display:flex; flex-direction:column; gap:2px; }
.kc-trust__text strong { font-family:var(--kc-head); font-size:.95rem; color:var(--kc-ink); line-height:1.1; }
.kc-trust__text span { font-family:var(--kc-text); font-size:.78rem; color:var(--kc-soft); line-height:1.3; }
.kc-trust__stars { display:flex; gap:2px; margin-top:3px; }
.kc-trust__stars svg { width:12px; height:12px; color:var(--kc-orange); fill:var(--kc-orange); }
{% endstylesheet %}

