<section class="puppy">

  <!-- ═══ HOOFD BLOK ══════════════════════════════════════ -->
  <div class="puppy__main">

    <!-- Links: grote lifestyle foto met organische vorm -->
    <div class="puppy__hero-col">
      <div class="puppy__hero-img-wrap">
        {%- if section.settings.hero_image != blank -%}
          <img
            src="{{ section.settings.hero_image | image_url: width: 900 }}"
            srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w,
                    {{ section.settings.hero_image | image_url: width: 900 }} 900w"
            sizes="(max-width: 899px) 100vw, 48vw"
            alt="{{ section.settings.hero_image.alt | default: 'Puppy' | escape }}"
            width="900" loading="lazy" class="puppy__hero-img"
          >
        {%- else -%}
          <div class="puppy__hero-ph">
            {{- 'icon-puppy.svg' | inline_asset_content -}}
            <span>Voeg puppy foto toe</span>
          </div>
        {%- endif -%}
        <!-- Decoratief hartje zweeft over foto -->
        <div class="puppy__hero-deco puppy__hero-deco--heart" aria-hidden="true">
          <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M30 52 C30 52 8 38 8 22 C8 14 14 8 22 8 C26 8 29 10 30 12 C31 10 34 8 38 8 C46 8 52 14 52 22 C52 38 30 52 30 52Z" stroke="#e75480" stroke-width="3" fill="none"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Rechts: content -->
    <div class="puppy__content-col">

      <!-- Eyebrow + titel + intro -->
      <div class="puppy__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="puppy__eyebrow">
            {{- 'icon-sparkle.svg' | inline_asset_content -}}
            {{ section.settings.eyebrow }}
          </p>
        {%- endif -%}
        <h2 class="puppy__title">{{ section.settings.title }}</h2>
        {%- if section.settings.intro != blank -%}
          <p class="puppy__intro">{{ section.settings.intro }}</p>
        {%- endif -%}
      </div>

      <!-- Benefits + side image -->
      <div class="puppy__mid">

        <!-- 3 benefit rijen -->
        <div class="puppy__benefits">
          {%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}
          {%- for block in benefit_blocks -%}
            <div class="puppy__benefit" {{ block.shopify_attributes }}>
              <span class="puppy__benefit-icon puppy__benefit-icon--{{ block.settings.color }}" aria-hidden="true">
                {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
              </span>
              <div class="puppy__benefit-text">
                <strong>{{ block.settings.title }}</strong>
                <p>{{ block.settings.description }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <!-- Side image + badge -->
        {%- if section.settings.side_image != blank -%}
          <div class="puppy__side">
            <!-- Wrapper met lagen -->
            <div class="puppy__side-layers">
              <!-- Laag 1: foto -->
              <img
                src="{{ section.settings.side_image | image_url: width: 300 }}"
                alt="{{ section.settings.side_image.alt | default: 'Puppy speelgoed' | escape }}"
                width="300" loading="lazy" class="puppy__side-img"
              >
              <!-- Laag 2: sparkle zweeft rechtsboven BUITEN de foto -->
              <div class="puppy__side-sparkle" aria-hidden="true">
                {{- 'icon-sparkle.svg' | inline_asset_content -}}
              </div>
              <!-- Laag 3: badge overlapt de onderkant -->
              {%- if section.settings.side_badge != blank -%}
                <div class="puppy__side-badge">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                  {{ section.settings.side_badge }}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

  <!-- ═══ FAVORIETEN STRIP ════════════════════════════════ -->
  <div class="puppy__favs">
    <div class="puppy__favs-inner">

      <!-- Links: paw + titel + cta -->
      <div class="puppy__favs-left">
        <div class="puppy__favs-head">
          <span class="puppy__favs-paw" aria-hidden="true">
            {{- 'icon-paw.svg' | inline_asset_content -}}
          </span>
          <strong>
            {{ section.settings.favs_title }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" style="color:#FFB8CD;vertical-align:middle"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </strong>
          <span>{{ section.settings.favs_subtitle }}</span>
        </div>
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url }}" class="puppy__cta">
            {{ section.settings.cta_label }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        {%- endif -%}
      </div>

      <!-- Product items -->
      {%- assign product_blocks = section.blocks | where: 'type', 'product_item' -%}
      {%- for block in product_blocks -%}
        <div class="puppy__product" {{ block.shopify_attributes }}>
          <div class="puppy__product-img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 240 }}"
                alt="{{ block.settings.title | escape }}"
                width="240" loading="lazy"
                class="puppy__product-img"
              >
            {%- else -%}
              <div class="puppy__product-ph">
                {{- 'icon-toy.svg' | inline_asset_content -}}
              </div>
            {%- endif -%}
          </div>
          <strong class="puppy__product-title">{{ block.settings.title }}</strong>
          <p class="puppy__product-desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}

    </div>
  </div>

  <!-- ═══ TRUST STRIP ═════════════════════════════════════ -->
  {%- assign trust_blocks = section.blocks | where: 'type', 'trust' -%}
  {%- if trust_blocks.size > 0 -%}
    <div class="puppy__trust">
      <div class="puppy__trust-inner">
        {%- for block in trust_blocks -%}
          <div class="puppy__trust-item" {{ block.shopify_attributes }}>
            <span class="puppy__trust-icon puppy__trust-icon--{{ block.settings.color }}" aria-hidden="true">
              {{- 'icon-' | append: block.settings.icon | append: '.svg' | inline_asset_content -}}
            </span>
            <div class="puppy__trust-text">
              <strong>{{ block.settings.title }}</strong>
              {%- if block.settings.subtitle != blank -%}
                <span>{{ block.settings.subtitle }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</section>

{% stylesheet %}
/* ── Sectie ─────────────────────────────────────────────── */
.puppy { background: #FFF5F8; overflow: hidden; }

/* ── Decoratief hartje over grote foto ─────────────────── */
.puppy__hero-deco {
  position: absolute;
  pointer-events: none; z-index: 3;
}
.puppy__hero-deco--heart {
  top: 18%; right: -20px;
  width: 64px; height: 64px;
  animation: puppy-float 3s ease-in-out infinite;
}
.puppy__hero-deco--heart svg { width: 100%; height: 100%; }
@keyframes puppy-float {
  0%, 100% { transform: translateY(0) rotate(-8deg); }
  50%       { transform: translateY(-8px) rotate(-8deg); }
}
@media(prefers-reduced-motion: reduce) { .puppy__hero-deco { animation: none; } }

/* ── Hoofd blok grid ────────────────────────────────────── */
.puppy__main {
  display: grid;
  grid-template-columns: 1fr;
  min-height: 560px;
}
@media(min-width: 900px) {
  .puppy__main { grid-template-columns: 48% 52%; }
}

/* ══ LINKS: lifestyle foto ══════════════════════════════ */
.puppy__hero-col {
  position: relative;
  overflow: hidden;
  min-height: 340px;
}
.puppy__hero-img-wrap {
  width: 100%; height: 100%;
  position: relative;
}
.puppy__hero-img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 20%;
  display: block;
}
/* Organische afgeronde rechterkant op desktop */
@media(min-width: 900px) {
  .puppy__hero-col {
    border-radius: 0 48% 48% 0 / 0 40% 40% 0;
  }
}
.puppy__hero-ph {
  width: 100%; height: 100%; min-height: 340px;
  background: #FFE5EE;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 12px; color: #FFB8CD; font-size: .875rem;
}
.puppy__hero-ph svg { width: 40px; height: 40px; }

/* ══ RECHTS: content ═══════════════════════════════════ */
.puppy__content-col {
  padding: 48px 28px 48px 40px;
  display: flex; flex-direction: column; gap: 24px;
  justify-content: center;
}
@media(max-width: 899px) { .puppy__content-col { padding: 36px 20px; } }

/* Header */
.puppy__eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: 'Karla', sans-serif;
  font-size: .72rem; font-weight: 800;
  letter-spacing: .1em; text-transform: uppercase;
  color: #e75480;
}
.puppy__eyebrow svg { width: 12px; height: 12px; color: #F7A048; flex-shrink: 0; }

.puppy__title {
  font-family: 'Lilita One', cursive;
  font-size: clamp(2rem, 4vw, 2.8rem);
  color: #3d2209; line-height: 1.05;
  margin: 4px 0 0;
}
.puppy__intro {
  font-family: 'Karla', sans-serif;
  font-size: .9rem; color: #A88259; line-height: 1.75;
}

/* ── Midden: benefits + side image ─────────────────────── */
.puppy__mid {
  display: flex; gap: 16px; align-items: flex-start;
}
.puppy__benefits {
  display: flex; flex-direction: column; gap: 10px; flex: 1;
}

/* Benefit rij */
.puppy__benefit {
  display: flex; align-items: center; gap: 12px;
}
.puppy__benefit-icon {
  width: 44px; height: 44px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.puppy__benefit-icon svg { width: 20px; height: 20px; }
.puppy__benefit-icon--pink   { background: #ffd6e3; color: #e75480; }
.puppy__benefit-icon--green  { background: #d4f0c8; color: #2d7a1a; }
.puppy__benefit-icon--yellow { background: #ffe9a0; color: #8a6200; }
.puppy__benefit-icon--orange { background: #ffd4b0; color: #b86a1e; }

.puppy__benefit-text strong {
  display: block;
  font-family: 'Lilita One', cursive;
  font-size: .95rem; color: #3d2209; margin-bottom: 2px; line-height: 1.2;
}
.puppy__benefit-text p {
  font-family: 'Karla', sans-serif;
  font-size: .78rem; color: #A88259; line-height: 1.5; margin: 0;
}

/* Side image + badge */
.puppy__side {
  width: 145px; flex-shrink: 0;
  padding-top: 14px;  /* ruimte boven voor sparkle */
  padding-bottom: 28px; /* ruimte onder voor badge */
}
@media(max-width: 1024px) { .puppy__side { width: 125px; } }
@media(max-width: 899px)  { .puppy__side { display: none; } }

/* Lagen wrapper: foto + badge + sparkle gestapeld */
.puppy__side-layers {
  position: relative;
  width: 100%;
}

.puppy__side-img {
  width: 100%; border-radius: 18px;
  box-shadow: 0 6px 20px rgba(96,58,21,.14);
  display: block; aspect-ratio: 3/4; object-fit: cover;
  position: relative; z-index: 1;
}

/* Sparkle: zweeft rechtsboven buiten de foto (laag 2) */
.puppy__side-sparkle {
  position: absolute;
  top: -14px; right: -14px;
  width: 28px; height: 28px;
  color: #66AA44; z-index: 2;
  animation: puppy-spin 4s linear infinite;
}
.puppy__side-sparkle svg { width: 100%; height: 100%; }
@keyframes puppy-spin {
  0%, 100% { transform: rotate(0deg) scale(1); }
  50%       { transform: rotate(20deg) scale(1.15); }
}
@media(prefers-reduced-motion: reduce) { .puppy__side-sparkle { animation: none; } }
.puppy__side-badge {
  position: absolute;
  bottom: -18px;
  left: 50%;
  transform: translateX(-50%);
  background: #FFF0F5;
  color: #c0394b;
  font-family: 'Karla', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  text-align: center;
  line-height: 1.35;
  padding: 8px 14px;
  border-radius: 14px;
  border: 1.5px solid #FFB8CD;
  display: flex;
  align-items: flex-start;
  gap: 5px;
  min-width: 130px;
  max-width: 150px;
  white-space: normal;
  box-shadow: 0 4px 14px rgba(231,84,128,.18);
  z-index: 4;
}
.puppy__side-badge svg {
  width: 11px; height: 11px;
  flex-shrink: 0; margin-top: 2px; color: #e75480;
}

/* ══ FAVORIETEN STRIP ══════════════════════════════════ */
.puppy__favs {
  background: #fff;
  border-top: 1.5px solid #FFD6E3;
}
.puppy__favs-inner {
  max-width: 1280px; margin: 0 auto;
  padding: 0 20px;
  display: flex; align-items: center; gap: 0;
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.puppy__favs-inner::-webkit-scrollbar { display: none; }
@media(min-width: 1200px) { .puppy__favs-inner { padding: 0 40px; } }

/* Links blok */
.puppy__favs-left {
  display: flex; flex-direction: column; gap: 8px;
  padding: 24px 28px 24px 0;
  min-width: 190px; flex-shrink: 0;
  border-right: 1.5px solid #FFD6E3;
}
.puppy__favs-head {
  display: flex; flex-direction: column; gap: 4px;
}
.puppy__favs-paw {
  width: 40px; height: 40px; border-radius: 50%;
  background: #e8f5e2; color: #66AA44;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 4px;
}
.puppy__favs-paw svg { width: 18px; height: 18px; }
.puppy__favs-head strong {
  font-family: 'Lilita One', cursive;
  font-size: 1.05rem; color: #3d2209; line-height: 1.2;
  display: flex; align-items: center; gap: 5px;
}
.puppy__favs-head span {
  font-family: 'Karla', sans-serif;
  font-size: .75rem; color: #A88259; line-height: 1.4;
}
.puppy__cta {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: 'Lilita One', cursive; font-size: .85rem;
  background: #FFB8CD; color: #7a1a35;
  padding: 9px 16px; border-radius: 999px;
  text-decoration: none; white-space: nowrap;
  align-self: flex-start;
  transition: background 160ms, transform 200ms cubic-bezier(.34,1.56,.64,1);
}
.puppy__cta:hover { background: #f09ab2; transform: translateY(-2px); }
.puppy__cta svg { width: 13px; height: 13px; }

/* Product items */
.puppy__product {
  display: flex; flex-direction: column; align-items: center;
  text-align: center; gap: 8px;
  padding: 20px 20px;
  border-right: 1.5px solid #FFD6E3;
  min-width: 130px; flex-shrink: 0;
}
.puppy__product:last-child { border-right: none; }

.puppy__product-img-wrap {
  width: 100px; height: 100px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: transform 300ms cubic-bezier(.34,1.56,.64,1);
}
.puppy__product:hover .puppy__product-img-wrap { transform: scale(1.1) rotate(-3deg); }
.puppy__product-img {
  width: 100%; height: 100%;
  object-fit: contain; display: block;
  /* PNG met transparantie werkt hier perfect */
  filter: drop-shadow(0 4px 8px rgba(96,58,21,.15));
}
.puppy__product-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center; color: #FFB8CD;
}
.puppy__product-ph svg { width: 40px; height: 40px; }

.puppy__product-title {
  font-family: 'Lilita One', cursive;
  font-size: .85rem; color: #3d2209; line-height: 1.2;
}
.puppy__product-desc {
  font-family: 'Karla', sans-serif;
  font-size: .7rem; color: #A88259; line-height: 1.45; max-width: 120px;
}

/* ══ TRUST STRIP ═══════════════════════════════════════ */
.puppy__trust { background: #FFF5F8; border-top: 1.5px solid #FFD6E3; }
.puppy__trust-inner {
  max-width: 1280px; margin: 0 auto; padding: 0 20px;
  display: grid; grid-template-columns: repeat(2, 1fr);
}
@media(min-width: 768px) {
  .puppy__trust-inner { grid-template-columns: repeat(4, 1fr); padding: 0 60px; }
}
.puppy__trust-item {
  display: flex; align-items: center; gap: 12px;
  padding: 18px 16px; border-right: 1px solid #FFD6E3;
}
.puppy__trust-item:nth-child(2n) { border-right: none; }
.puppy__trust-item:last-child    { border-right: none; }
@media(min-width: 768px) {
  .puppy__trust-item:nth-child(2n) { border-right: 1px solid #FFD6E3; }
  .puppy__trust-item:last-child    { border-right: none; }
}
.puppy__trust-icon {
  width: 40px; height: 40px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.puppy__trust-icon svg { width: 18px; height: 18px; }
.puppy__trust-icon--green  { background: #e8f5e2; color: #66AA44; }
.puppy__trust-icon--pink   { background: #fff0f5; color: #e75480; }
.puppy__trust-icon--orange { background: #fff0e4; color: #F7A048; }
.puppy__trust-icon--yellow { background: #fffae0; color: #c49000; }
.puppy__trust-text strong { font-family: 'Karla', sans-serif; font-size: .82rem; font-weight: 800; color: #3d2209; display: block; }
.puppy__trust-text span   { font-size: .72rem; color: #A88259; }
{% endstylesheet %}

{% schema %}
{
  "name": "Puppy sectie",
  "tag": "section",
  "blocks": [
    {
      "type": "benefit", "name": "Voordeel",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icoon", "default": "puppy",
          "options": [{"value":"puppy","label":"Hond"},{"value":"leaf","label":"Blad"},{"value":"heart","label":"Hart"},{"value":"shield","label":"Schild"},{"value":"star","label":"Ster"},{"value":"gift","label":"Cadeau"}] },
        { "type": "select", "id": "color", "label": "Kleur", "default": "pink",
          "options": [{"value":"pink","label":"Roze"},{"value":"green","label":"Groen"},{"value":"yellow","label":"Geel"},{"value":"orange","label":"Oranje"}] },
        { "type": "text", "id": "title", "label": "Titel", "default": "Zacht & veilig" },
        { "type": "textarea", "id": "description", "label": "Beschrijving", "default": "Alle speeltjes zijn gemaakt van puppyveilige materialen." }
      ]
    },
    {
      "type": "product_item", "name": "Product item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Foto" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Knuffelvriendjes" },
        { "type": "text", "id": "description", "label": "Beschrijving", "default": "Zacht, lief en perfect om mee te knuffelen." }
      ]
    },
    {
      "type": "trust", "name": "Trust item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icoon", "default": "shield",
          "options": [{"value":"shield","label":"Schild"},{"value":"heart","label":"Hart"},{"value":"truck","label":"Vrachtwagen"},{"value":"gift","label":"Cadeau"},{"value":"paw","label":"Poot"}] },
        { "type": "select", "id": "color", "label": "Kleur", "default": "green",
          "options": [{"value":"green","label":"Groen"},{"value":"pink","label":"Roze"},{"value":"orange","label":"Oranje"},{"value":"yellow","label":"Geel"}] },
        { "type": "text", "id": "title",    "label": "Titel",    "default": "100% veilig voor puppy's" },
        { "type": "text", "id": "subtitle", "label": "Subtitel", "default": "Zorgvuldig getest en geselecteerd." }
      ]
    }
  ],
  "settings": [
    { "type": "image_picker", "id": "hero_image",  "label": "Grote puppy foto (links)" },
    { "type": "image_picker", "id": "side_image",  "label": "Kleine zijfoto (rechts)" },
    { "type": "text", "id": "side_badge",   "label": "Zijfoto badge",  "default": "Perfect voor puppy's van 8 weken tot 1 jaar" },
    { "type": "text", "id": "eyebrow",      "label": "Eyebrow",        "default": "Speciaal voor nieuwsgierige puppy's" },
    { "type": "text", "id": "title",        "label": "Titel",          "default": "Nieuw in de wereld van kwispels?" },
    { "type": "textarea", "id": "intro",    "label": "Intro",          "default": "Onze puppycollectie zit boordevol zachte speeltjes, veilige kauwsnacks en knuffels die perfect passen bij hun eerste avonturen. Zorgvuldig geselecteerd voor een goede start vol speelplezier." },
    { "type": "text", "id": "favs_title",   "label": "Favorieten titel",    "default": "Puppy favorieten" },
    { "type": "text", "id": "favs_subtitle","label": "Favorieten subtitel",  "default": "Onze meest gekozen items door baasjes van puppy's." },
    { "type": "text", "id": "cta_label",    "label": "CTA tekst",            "default": "Bekijk puppy favorieten" },
    { "type": "url",  "id": "cta_url",      "label": "CTA link" }
  ],
  "presets": [{ "name": "Puppy sectie" }]
}
{% endschema %}
